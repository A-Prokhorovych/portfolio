        <div>
          <p class="eyebrow">Kontakt</p>
          <h2>Lassen Sie uns gemeinsam Ihr naechstes Projekt umsetzen</h2>
          <p>Ich freue mich auf Ihre Anfrage und eine erfolgreiche Zusammenarbeit.</p>
        </div>
        <div class="contact-links">
          <a href="mailto:prohorovichandrey@gmail.com">prohorovichandrey@gmail.com</a>
          <a href="https://www.linkedin.com/in/andrii-prokhorovych-216846204" target="_blank" rel="noreferrer">LinkedIn</a>
          <a href="https://prokha.webflow.io/" target="_blank" rel="noreferrer">Altes Portfolio</a>
        </div>
      </section>
    </main>
    <script>
      const counters = Array.from(document.querySelectorAll("[data-count-target]"));
      const showProjectsButton = document.querySelector("[data-show-projects]");
      const projectCards = Array.from(document.querySelectorAll("[data-project-card]"));
      const categoryButtons = Array.from(document.querySelectorAll("[data-category-filter]"));
      const brandToggle = document.querySelector("[data-toggle-brands]");
      const brandPanel = document.querySelector("[data-brand-panel]");
      const brandStrip = document.querySelector("[data-brand-strip]");
      const brandFilterButtons = Array.from(document.querySelectorAll("[data-brand-filter]"));
      const activeBrand = document.querySelector("[data-active-brand]");
      const activeBrandLogo = document.querySelector("[data-active-brand-logo]");
      const activeBrandName = document.querySelector("[data-active-brand-name]");
      const clearBrandFilter = document.querySelector("[data-clear-brand-filter]");
      let visibleProjects = getFilteredRevealStep();
      let visibleFilteredProjects = getFilteredRevealStep();
      let currentBrand = null;
      let currentCategory = "all";
      const projectGrid = document.querySelector(".project-grid");
      const randomProjectOrder = [...projectCards];

      function animateCounter(counter) {
        const target = Number(counter.getAttribute("data-count-target") || 0);
        const duration = 1400;
        const startTime = performance.now();

        function updateCounter(currentTime) {
          const progress = Math.min((currentTime - startTime) / duration, 1);
          const easedProgress = 1 - Math.pow(1 - progress, 3);
          counter.textContent = `${Math.round(target * easedProgress)}+`;

          if (progress < 1) {
            requestAnimationFrame(updateCounter);
          }
        }

        requestAnimationFrame(updateCounter);
      }

      if (window.matchMedia("(prefers-reduced-motion: reduce)").matches || !("IntersectionObserver" in window)) {
        counters.forEach((counter) => {
          counter.textContent = `${counter.getAttribute("data-count-target")}+`;
        });
      } else {
        counters.forEach((counter) => {
          counter.textContent = "0+";
        });

        const counterObserver = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              animateCounter(entry.target);
              observer.unobserve(entry.target);
            }
          });
        }, { threshold: 0.6 });

        counters.forEach((counter) => counterObserver.observe(counter));
      }

      for (let index = randomProjectOrder.length - 1; index > 0; index -= 1) {
        const randomIndex = Math.floor(Math.random() * (index + 1));
        [randomProjectOrder[index], randomProjectOrder[randomIndex]] = [randomProjectOrder[randomIndex], randomProjectOrder[index]];
      }

      function orderProjectCards(cards) {
        cards.forEach((card) => projectGrid?.append(card));
      }

      function getFilteredRevealStep() {
        if (window.matchMedia("(max-width: 780px)").matches) {
          return 2;
        }

        if (window.matchMedia("(max-width: 1100px)").matches) {
          return 4;
        }

        return 8;
      }

      function resetAllFilters(showAllProjects = true) {
        currentBrand = null;
        currentCategory = "all";
        visibleProjects = showAllProjects ? projectCards.length : getFilteredRevealStep();
        visibleFilteredProjects = getFilteredRevealStep();

        if (activeBrand) {
          activeBrand.hidden = true;
        }

        categoryButtons.forEach((button) => {
          button.classList.toggle("is-active", button.getAttribute("data-category-filter") === "all");
        });

        updateProjects();
      }

      function updateProjects() {
        const hasActiveFilter = Boolean(currentBrand) || currentCategory !== "all";

        if (hasActiveFilter) {
          const sortedProjects = [...projectCards].sort((a, b) =>
            Number(b.getAttribute("data-project-year") || 0) - Number(a.getAttribute("data-project-year") || 0)
          );
          orderProjectCards(sortedProjects);

          const matchingProjects = sortedProjects.filter((card) => {
            const search = card.getAttribute("data-project-search") || "";
            const compact = card.getAttribute("data-project-compact") || "";
            const category = card.getAttribute("data-project-category") || "";
            const matchesBrand = !currentBrand ||
              (currentBrand.projectSlugs.length
                ? currentBrand.projectSlugs.some((slug) => search.includes(slug)) ||
                  currentBrand.projectCompacts.some((projectCompact) => compact.includes(projectCompact))
                : search.includes(currentBrand.slug) || compact.includes(currentBrand.compact));
            const matchesCategory = currentCategory === "all" || category === currentCategory;
            return matchesBrand && matchesCategory;
          });

          sortedProjects.forEach((card) => {
            const matchingIndex = matchingProjects.indexOf(card);
            card.classList.toggle("is-hidden", matchingIndex < 0 || matchingIndex >= visibleFilteredProjects);
          });

          if (showProjectsButton) {
            showProjectsButton.hidden = false;
            showProjectsButton.textContent = visibleFilteredProjects < matchingProjects.length
              ? "Mehr Projekte anzeigen"
              : "Alle Projekte anzeigen";
          }

          return;
        }

        orderProjectCards(randomProjectOrder);

        randomProjectOrder.forEach((card, index) => {
          card.classList.toggle("is-hidden", index >= visibleProjects);
        });

        if (showProjectsButton) {
          showProjectsButton.textContent = "Mehr Projekte anzeigen";
          showProjectsButton.hidden = visibleProjects >= projectCards.length;
        }
      }

      function setBrandFilter(button) {
        visibleFilteredProjects = getFilteredRevealStep();
        currentCategory = "all";
        categoryButtons.forEach((item) => {
          item.classList.toggle("is-active", item.getAttribute("data-category-filter") === "all");
        });
        currentBrand = {
          slug: button.getAttribute("data-brand-filter") || "",
          compact: button.getAttribute("data-brand-compact") || "",
          projectSlugs: (button.getAttribute("data-brand-project-slugs") || "").split("|").filter(Boolean),
          projectCompacts: (button.getAttribute("data-brand-project-compacts") || "").split("|").filter(Boolean),
          name: button.getAttribute("data-brand-name") || "",
          logo: button.getAttribute("data-brand-logo") || "",
        };

        if (activeBrand && activeBrandLogo && activeBrandName) {
          activeBrand.hidden = false;
          activeBrandLogo.setAttribute("src", currentBrand.logo);
          activeBrandLogo.setAttribute("alt", currentBrand.name);
          activeBrandName.textContent = currentBrand.name;
        }

        updateProjects();
        document.querySelector("[data-project-results]")?.scrollIntoView({ block: "start" });
      }

      function resetBrandFilter() {
        currentBrand = null;
        visibleFilteredProjects = getFilteredRevealStep();

        if (activeBrand) {
          activeBrand.hidden = true;
        }

        updateProjects();
      }

      showProjectsButton?.addEventListener("click", () => {
        if (currentBrand || currentCategory !== "all") {
          if (showProjectsButton.textContent?.trim() === "Alle Projekte anzeigen") {
            resetAllFilters();
          } else {
            visibleFilteredProjects += getFilteredRevealStep();
            updateProjects();
          }
          return;
        }

        visibleProjects += getFilteredRevealStep();
        updateProjects();
      });

      categoryButtons.forEach((button) => {
        button.addEventListener("click", () => {
          currentCategory = button.getAttribute("data-category-filter") || "all";

          if (currentCategory === "all") {
            resetAllFilters(false);
            return;
          }

          visibleFilteredProjects = getFilteredRevealStep();
          categoryButtons.forEach((item) => item.classList.toggle("is-active", item === button));
          updateProjects();
        });
      });

      brandFilterButtons.forEach((button) => {
        button.addEventListener("click", () => setBrandFilter(button));
      });

      clearBrandFilter?.addEventListener("click", resetBrandFilter);

      window.addEventListener("resize", () => {
        if (currentBrand || currentCategory !== "all") {
          visibleFilteredProjects = getFilteredRevealStep();
        } else {
          visibleProjects = getFilteredRevealStep();
        }

        updateProjects();
      });

      brandToggle?.addEventListener("click", () => {
        const isOpen = brandPanel?.classList.toggle("is-open");
        brandStrip?.classList.toggle("is-expanded", Boolean(isOpen));
        brandToggle.setAttribute("aria-expanded", String(Boolean(isOpen)));
        brandToggle.textContent = isOpen ? "Marken ausblenden" : "Alle Marken";
      });

      updateProjects();
    </script>
  </body>
</html>

