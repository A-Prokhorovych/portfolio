const base = import.meta.env.BASE_URL;
const campaignCover = (url) => {
  const slug = url
    .replace("https://www.edimdoma.ru/", "")
    .replace(/#.*$/, "")
    .replace(/[^a-zA-Z0-9]+/g, "-")
    .replace(/^-|-$/g, "")
    .toLowerCase();

  return `${base}projects/covers/${slug}.jpg`;
};

const slugify = (value) =>
  value
    .toLowerCase()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");

const compactSlug = (value) => slugify(value).replace(/-/g, "");

