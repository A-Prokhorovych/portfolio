---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/kommunalwahl`;

const facts = [
  ["Kunde", "CDU Kommunalwahl Ulm"],
  ["Plattform", "Campaign Website"],
  ["Jahr", "2024"],
  ["Rolle", "Webdesign, UX Struktur"],
];

const priorities = [
  ["Lokaler Kontext", "Ulm steht visuell im Vordergrund, damit die Kampagne nicht generisch wirkt."],
  ["Kandidaten", "Personen, Listen und Profile werden als schnell erreichbare Kerninformation behandelt."],
  ["Programm", "Themen und Positionen werden in klare Inhaltsbereiche aufgeteilt."],
  ["Tempo", "Der Mockup entstand in kurzer Zeit und zeigt trotzdem ein tragfaehiges Seitensystem."],
];

const screens = [
  ["home-preview.jpg", "Campaign Home", "Hero, lokale Bildwelt und Einstiege in Themen und Kandidaten."],
  ["candidates-preview.jpg", "Kandidatenuebersicht", "Listen, Profile und direkte Orientierung fuer Waehlerinnen und Waehler."],
  ["program-preview.jpg", "Wahlprogramm", "Politische Inhalte werden scanbar und modular strukturiert."],
];

const candidateScreens = [
  ["candidate-home-preview.jpg", "Persoenlicher Einstieg"],
  ["candidate-program-preview.jpg", "Themen und Programm"],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="CDU Kommunalwahl Ulm Case Study - Campaign Website und Kandidaten-Mockup von Andrii Prokhorovych." />
    <title>CDU Kommunalwahl Website - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=kommunalwahl`}>Редактировать</a>
        <a class="button dark small" data-owner-only hidden href="https://prokha.webflow.io/works/kommunalwahl" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2024</p>
          <div class="party-mark">CDU</div>
          <h1>Kommunale Kampagne mit Kandidatenfokus und klarer Orientierung</h1>
          <p class="intro">
            Ein Website-Mockup fuer die Kommunalwahl 2024 in Ulm: lokale Bildwelt,
            Kandidatinnen und Kandidaten, Programmstruktur und eine persoenliche
            Kandidatenseite in einem kompakten digitalen Kampagnensystem.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Ueberblick</a>
          <a href="#prioritaeten">02 Prioritaeten</a>
          <a href="#screens">03 Website</a>
          <a href="#kandidat">04 Kandidat</a>
          <a href="#ergebnis">05 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Political Campaign · Local Election</p>
            <h2>Eine Wahlkampagne muss in Sekunden orientieren</h2>
            <p>
              Fuer eine kommunale Kampagne zaehlt nicht nur die visuelle Wiedererkennbarkeit.
              Besucher muessen sofort verstehen, wer kandidiert, welche Themen wichtig sind
              und wo sie tiefer einsteigen koennen.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero.jpg`} alt="CDU Kommunalwahl 2024 in Ulm Cover" />
            <span>Campaign Website · Kommunalwahl 2024 in Ulm</span>
          </div>
        </section>

        <section id="prioritaeten" class="priority-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Design-Prioritaeten</p>
            <h2>Lokale Wiedererkennung, klare Wege, politische Inhalte ohne Chaos</h2>
            <p>
              Der Case zeigt eine schnelle, aber belastbare Struktur: starke lokale
              Bildwelt, deutliche Navigationspunkte, Kandidaten als Menschen und das
              Programm als modular lesbare Information.
            </p>
          </div>
          <div class="priority-grid">
            {priorities.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="screens" class="screens-section">
          <div class="section-copy">
            <p class="eyebrow">Campaign System</p>
            <h2>Aus Landing Page, Kandidaten und Programm wird ein System</h2>
            <p>
              Die Screens zeigen die Kernlogik der Kampagne: Einstieg ueber die Stadt,
              klare Kandidatenbereiche und ein Wahlprogramm, das nicht als langer Text,
              sondern als strukturierter Informationsraum funktioniert.
            </p>
          </div>
          <div class="screen-grid">
            {screens.map(([image, title, text]) => (
              <article>
                <img src={`${media}/${image}`} alt={`CDU Kommunalwahl ${title} Screen`} loading="lazy" />
                <div>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section id="kandidat" class="candidate-section">
          <div class="section-copy">
            <p class="eyebrow">Candidate Mockup</p>
            <h2>Eine zweite Ebene fuer persoenliche Kampagnenkommunikation</h2>
            <p>
              Zusaetzlich zum Parteiauftritt entstand ein Mockup fuer eine einzelne
              Kandidatenseite. Dort wird die Kommunikation persoenlicher: Profil,
              Themen, Positionen und direkter Bezug zur Waehlergruppe.
            </p>
          </div>
          <div class="candidate-grid">
            {candidateScreens.map(([image, title]) => (
              <figure>
                <img src={`${media}/${image}`} alt={`CDU Kandidatenseite ${title}`} loading="lazy" />
                <figcaption>{title}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">05</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Ein schneller Mockup, der digitale Kampagnenlogik sichtbar macht</h2>
            <p>
              Der Case zeigt nicht nur eine politische Oberflaeche, sondern eine
              Informationsarchitektur fuer lokale Wahlkommunikation: Stadt, Partei,
              Kandidaten, Programm und persoenliche Profile greifen ineinander.
            </p>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />
  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f3fbfc;
    --paper: #fff;
    --ink: #102333;
    --muted: #617381;
    --line: rgba(16, 35, 51, .12);
    --cyan: #4cb8c0;
    --navy: #123449;
    --red: #df001f;
    --gold: #f4b321;
    --soft: #eaf7f8;
    --radius: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(243, 251, 252, .92);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(18px);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
  }
  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { min-height: 42px; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(16, 35, 51, .18) !important;
    color: rgba(16, 35, 51, .46) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--cyan);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .party-mark {
    align-items: center;
    background: #fff;
    border-left: 10px solid var(--red);
    box-shadow: inset 0 -10px 0 var(--gold);
    color: #211d1d;
    display: inline-flex;
    font-size: 44px;
    font-style: italic;
    font-weight: 950;
    height: 72px;
    margin-bottom: 30px;
    padding: 0 18px;
  }
  h1 { font-size: clamp(25px, 2.25vw, 38px); line-height: 1.08; }
  h2 { font-size: clamp(34px, 4.5vw, 72px); letter-spacing: -.055em; line-height: .98; max-width: 980px; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; gap: 18px; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 430px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media, .screen-grid article, .candidate-grid figure {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 30px 90px rgba(16, 35, 51, .12);
    overflow: hidden;
  }
  .hero-media img { aspect-ratio: 18 / 10; object-fit: cover; object-position: center; width: 100%; }
  .hero-media span, figcaption {
    color: var(--muted);
    display: block;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    padding: 16px 18px;
    text-transform: uppercase;
  }

  .priority-section {
    background:
      radial-gradient(circle at 84% 16%, rgba(244, 179, 33, .18), transparent 25%),
      #fff;
    display: grid;
    gap: 36px;
    grid-template-columns: 70px minmax(0, 1fr);
  }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 900px; }
  .priority-grid { display: grid; gap: 14px; grid-column: 2; grid-template-columns: repeat(4, 1fr); margin-top: 18px; }
  .priority-grid article {
    background: var(--soft);
    border: 1px solid rgba(76, 184, 192, .18);
    border-radius: var(--radius);
    min-height: 260px;
    padding: 24px;
  }
  .priority-grid span { color: var(--cyan); font-size: 12px; font-weight: 950; }
  .priority-grid h3 { font-size: 22px; line-height: 1.12; margin-top: 70px; }
  .priority-grid p { color: var(--muted); font-size: 14px; line-height: 1.58; margin-top: 14px; }

  .screens-section { background: #f8fcfd; }
  .screen-grid { display: grid; gap: 18px; grid-template-columns: repeat(3, 1fr); margin-top: 48px; }
  .screen-grid img { aspect-ratio: 4 / 3; object-fit: cover; object-position: top; width: 100%; }
  .screen-grid div { padding: 24px; }
  .screen-grid h3 { font-size: 22px; }
  .screen-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 12px; }

  .candidate-section { background: #fff; }
  .candidate-grid { display: grid; gap: 18px; grid-template-columns: 1fr 1fr; margin-top: 48px; }
  .candidate-grid img { aspect-ratio: 16 / 10; object-fit: cover; object-position: top; width: 100%; }

  .result {
    background:
      radial-gradient(circle at 76% 16%, rgba(244, 179, 33, .2), transparent 28%),
      linear-gradient(135deg, var(--navy), #071725);
    color: #fff;
    display: grid;
    gap: 36px;
    grid-template-columns: 70px minmax(0, 1fr);
  }
  .result .eyebrow, .result-copy > p { color: rgba(255, 255, 255, .74); }
  .result-copy { max-width: 980px; }

  @media (max-width: 1180px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
    .hero-copy { grid-template-columns: 1fr; }
    .priority-grid, .screen-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    main, .case-sidebar, .case-content { max-width: 100vw; min-width: 0; width: 100%; }
    .case-sidebar { overflow: hidden; padding: 36px 18px; }
    .case-content { overflow: hidden; }
    .case-content > section { max-width: 100vw; padding-left: 18px; padding-right: 18px; width: 100%; }
    .priority-section, .result { grid-template-columns: minmax(0, 1fr); }
    .hero-copy .eyebrow, .priority-grid { grid-column: 1; }
    .priority-grid, .screen-grid, .candidate-grid { grid-template-columns: 1fr; }
    .section-number { display: none; }
    .hero-media img { aspect-ratio: 4 / 3; }
    h2 { font-size: clamp(32px, 12vw, 48px); }
  }
</style>
