---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/green-ray`;
const cover = `${base}projects/covers/2019-astratomat.jpg`;
const logo = `${base}brands/logotypes/${encodeURIComponent("green ray.svg")}`;
const originalUrl = "https://www.edimdoma.ru/2019/astratomat#1";
const canonicalUrl = "https://a-prokhorovych.github.io/portfolio/projects/green-ray/";
const seoTitle = "Green Ray Astra Tomat Campaign Case Study - Andrii Prokhorovych";
const seoDescription =
  "Green Ray Astra Tomat case study by Andrii Prokhorovych: food campaign design, video-led landing page, yellow visual direction, content modules, recipe photography and UI kit for Edim Doma.";

const facts = [
  ["Kunde", "Green Ray"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2019"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Video als Einstieg", "Die Kampagne beginnt mit einem appetitlichen, bewegten Produktmoment statt mit einer statischen Anzeige."],
  ["Gelbe Themenwelt", "Der Astratomat-Hintergrund wird als klare, sofort wiedererkennbare Kampagnenbuehne genutzt."],
  ["Content Cards", "Kurze Wissens- und Rezeptmodule machen das Produkt konkreter und geben der Seite redaktionellen Nutzen."],
];

const benefitCards = [
  ["natural-product.jpg", "100% натуральный продукт"],
  ["seven-kg-tomatoes.jpg", "1 кг пасты это 7 кг томата"],
  ["lycopene.jpg", "Суточная норма ликопина"],
  ["only-tomatoes.jpg", "Только помидоры"],
  ["no-starch.jpg", "Без крахмала"],
  ["no-sugar.jpg", "Без сахара"],
  ["no-salt.jpg", "Без соли"],
  ["no-e.jpg", "Без Е"],
  ["grown-in-russia.jpg", "Выращено в России"],
];

const editorialCards = [
  ["seven-myths.jpg", "7 мифов о томатной пасте"],
  ["how-to-choose.jpg", "Как выбрать качественный продукт"],
  ["health-elixir.jpg", "Эликсир здоровья и молодости"],
];

const tokenCards = [
  ["color-yellow.svg", "FEE934"],
  ["color-green.svg", "00A717"],
  ["color-red.svg", "E12229"],
  ["color-brown.svg", "5E2A2C"],
];

const stateCards = [
  ["state-passive.svg", "Passive"],
  ["state-hover.svg", "Hover"],
  ["state-active.svg", "Active"],
];

const recipePhotos = [
  ["recipe-photo-01.jpg", "Tomato rice dish with Green Ray tomato paste"],
  ["recipe-photo-02.jpg", "Vegetable pasta recipe with Green Ray packaging"],
  ["recipe-photo-03.jpg", "Grilled chicken recipe with tomato paste"],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={seoDescription} />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="article" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content="https://a-prokhorovych.github.io/portfolio/projects/green-ray/background-yellow.jpg" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDescription} />
    <title>{seoTitle}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}archive/#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zum Archiv
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=green-ray`}>Редактировать</a>
        <a class="button dark small" href={originalUrl} target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2019</p>
          <img class="client-logo" src={logo} alt="Green Ray" />
          <h1>Eine gelbe Food-Kampagne rund um Tomaten und Rezeptideen</h1>
          <p class="intro">
            Ein Special Project fuer Green Ray auf Edim Doma: bewegter Einstieg, markante
            Astratomat-Farbwelt, kurze Content-Module und Rezeptkarten als schneller Weg vom
            Produkt zur Anwendung.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#video">02 Video</a>
          <a href="#system">03 Elemente</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Food & Beverage · Digital Campaign</p>
            <h2>Green Ray als interaktive Produktgeschichte</h2>
            <p>
              Die Kampagne fuehrt Nutzer nicht nur zu einer Marke, sondern zu einem kleinen
              Produktkosmos: Tomaten, Gerichte, kurze Wissenskarten und visuelle Produktmomente
              werden auf einer kompakten Landing Page zusammengefuehrt.
            </p>
          </div>
          <div class="hero-media">
            <video autoplay muted loop playsinline preload="auto" poster={cover}>
              <source src={`${media}/screenvideo.mp4`} type="video/mp4" />
            </video>
            <span>Screen recording · Green Ray Special Project</span>
          </div>
        </section>

        <section id="video" class="yellow-stage" style={`--astratomat-bg: url("${media}/background-yellow.jpg")`}>
          <div class="stage-copy">
            <p class="eyebrow">Astratomat Visual Direction</p>
            <h2>Der gelbe Hintergrund macht die Kampagne sofort wiedererkennbar</h2>
            <p>
              Der gelbe Astratomat-Bereich aus dem Projekt wird als visuelles Zentrum genutzt:
              genug Energie fuer eine Food-Kampagne, aber klar genug fuer kleine redaktionelle
              Inhalte und Rezeptkarten.
            </p>
          </div>
        </section>

        <section class="product-video-section" aria-labelledby="product-video-title">
          <div class="section-copy">
            <p class="eyebrow">Product Video</p>
            <h2 id="product-video-title">Kurzer Produktmoment fuer den Einstieg in die Food-Welt</h2>
            <p>
              Neben dem langen Screen Recording zeigt das Material auch einen kompakten
              Produktclip. Er funktioniert als atmosphaerischer Auftakt und gibt der Kampagne
              mehr Bewegung, ohne die Seite zu ueberladen.
            </p>
          </div>
          <div class="product-video-frame">
            <video autoplay muted loop playsinline preload="auto" poster={`${media}/video-frame-02.jpg`}>
              <source src={`${media}/productvideo.mp4`} type="video/mp4" />
            </video>
          </div>
        </section>

        <section id="system" class="story-section">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Page System</p>
            <h2>Aus einer Produktkampagne wird eine kleine Content-Seite</h2>
            <p>
              Die Seite kombiniert Markenmoment, Produktvorteile und Rezeptideen. Dadurch wirkt
              sie nicht wie ein Banner, sondern wie ein kurzer redaktioneller Einstieg in die
              Green-Ray-Welt.
            </p>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="assets-section" aria-labelledby="assets-title">
          <div class="section-copy">
            <p class="eyebrow">Campaign Content Modules</p>
            <h2 id="assets-title">Die Kampagne lebt von modularen Wissens- und Produktkarten</h2>
            <p>
              Die Originalmaterialien zeigen ein klares visuelles System: Benefit-Karten fuer
              Produktargumente und redaktionelle Teaser fuer vertiefende Inhalte rund um
              Tomatenpaste.
            </p>
          </div>
          <div class="benefit-grid">
            {benefitCards.map(([file, label]) => (
              <figure>
                <img src={`${media}/${file}`} alt={`Green Ray: ${label}`} loading="lazy" />
              </figure>
            ))}
          </div>
        </section>

        <section class="editorial-section" aria-labelledby="editorial-title">
          <div class="section-copy">
            <p class="eyebrow">Editorial Cards</p>
            <h2 id="editorial-title">Redaktionelle Teaser ergaenzen die Produktargumente</h2>
            <p>
              Diese kleineren Karten fuehren zu Wissensinhalten: Mythen, Produktauswahl und
              gesundheitliche Benefits. So bekommt die Kampagne eine Content-Ebene statt nur
              eine reine Produktpraesentation.
            </p>
          </div>
          <div class="editorial-grid">
            {editorialCards.map(([file, label]) => (
              <figure>
                <img src={`${media}/${file}`} alt={`Green Ray Editorial Card: ${label}`} loading="lazy" />
                <figcaption>{label}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <section class="kit-section" aria-labelledby="kit-title">
          <div class="section-copy">
            <p class="eyebrow">Visual Kit</p>
            <h2 id="kit-title">Farben, Typografie und States aus den Kampagnenmaterialien</h2>
            <p>
              Die Seite nutzt die Materiallogik des Originals: Gelb als Kampagnenflaeche,
              Gruen und Rot fuer Food- und Markenakzente, handschriftliche Display-Typografie
              und einfache Button-States.
            </p>
          </div>
          <div class="kit-grid">
            <div class="token-grid" aria-label="Color tokens">
              {tokenCards.map(([file, label]) => (
                <figure>
                  <img src={`${media}/${file}`} alt={`Green Ray color token ${label}`} loading="lazy" />
                  <figcaption>#{label}</figcaption>
                </figure>
              ))}
            </div>
            <div class="type-grid" aria-label="Typography samples">
              <figure>
                <img src={`${media}/type-amatic-bold.svg`} alt="Amatic SC Bold typography sample" loading="lazy" />
                <figcaption>Amatic SC Bold</figcaption>
              </figure>
              <figure>
                <img src={`${media}/type-montserrat-semibold.svg`} alt="Montserrat SemiBold typography sample" loading="lazy" />
                <figcaption>Montserrat SemiBold</figcaption>
              </figure>
            </div>
            <div class="state-grid" aria-label="Button states">
              {stateCards.map(([file, label]) => (
                <figure>
                  <img src={`${media}/${file}`} alt={`Green Ray button state ${label}`} loading="lazy" />
                  <figcaption>{label}</figcaption>
                </figure>
              ))}
            </div>
          </div>
        </section>

        <section class="gallery" aria-label="Green Ray recipe photography">
          {recipePhotos.map(([file, label]) => (
            <figure>
              <img src={`${media}/${file}`} alt={label} loading="lazy" />
            </figure>
          ))}
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Ein Green-Ray-Projekt, das jetzt als Case Study statt nur als Link funktioniert</h2>
            <p>
              Im Archiv fuehrt Green Ray nun zuerst auf diese interne Portfolio-Seite. Das Video,
              die gelbe Astratomat-Buehne und die Content-Karten zeigen den Charakter des Projekts,
              bevor Nutzer optional das Original auf Edim Doma oeffnen.
            </p>
            <a class="button project-button" href={originalUrl} target="_blank" rel="noreferrer">Originalprojekt oeffnen</a>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />

    <script>
      const params = new URLSearchParams(location.search);
      const ownerParam = params.get("owner");
      const editParam = params.get("edit");
      if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
      if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
      localStorage.removeItem("prokha-edit-links");

      let editLinksVisible = editParam === "1";
      const revealOwnerControls = () => {
        const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
        const showEditLinks = isOwner && editLinksVisible;
        document.querySelectorAll("[data-owner-only]").forEach((element) => {
          element.hidden = !isOwner;
        });
        document.querySelectorAll("[data-edit-only]").forEach((element) => {
          element.hidden = !showEditLinks;
        });
      };

      revealOwnerControls();

      let editCommand = "";
      document.addEventListener("keydown", (event) => {
        if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
        editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
        if (editCommand === "edit") {
          editLinksVisible = true;
          revealOwnerControls();
        }
      });
    </script>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #fff8df;
    --paper: #fff;
    --ink: #172b20;
    --muted: #6d6a58;
    --line: rgba(23, 43, 32, .16);
    --accent: #ffe233;
    --green: #4f8f40;
    --red: #e64231;
    --radius: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img, video { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(255, 248, 223, .9);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand { font-size: 28px; font-weight: 900; letter-spacing: 0; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 900;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: #fff; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(23, 43, 32, .2) !important;
    color: rgba(23, 43, 32, .5) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 72px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 130px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(34px, 4.8vw, 76px); line-height: 1.02; max-width: 980px; }
  h3 { line-height: 1.18; }
  .intro, .section-copy > p:last-child, .result-copy > p, .stage-copy p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; gap: 18px; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 900; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 900; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media { background: var(--green); border-radius: var(--radius); box-shadow: 0 24px 80px rgba(62, 70, 29, .16); overflow: hidden; }
  .hero-media video { aspect-ratio: 16 / 10; background: #111; object-fit: cover; width: 100%; }
  .hero-media video,
  .product-video-frame video { pointer-events: none; }
  .hero-media span { color: #fff; display: block; font-size: 12px; font-weight: 900; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .yellow-stage {
    background:
      linear-gradient(90deg, rgba(254, 233, 52, .92), rgba(254, 233, 52, .72)),
      var(--astratomat-bg) center / cover no-repeat,
      var(--accent);
    min-height: 560px;
    display: flex;
    align-items: center;
  }
  .stage-copy { max-width: 980px; }
  .yellow-stage .eyebrow { color: rgba(23, 43, 32, .58); }

  .story-section, .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 860px; }
  .highlight-grid { display: grid; gap: 18px; grid-column: 2; grid-template-columns: repeat(3, 1fr); margin-top: 24px; }
  .highlight-grid article {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    min-height: 260px;
    padding: 26px;
  }
  .highlight-grid span { color: var(--green); font-size: 12px; font-weight: 900; }
  .highlight-grid h3 { font-size: 20px; margin-top: 52px; }
  .highlight-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .product-video-section {
    background: #f4f8ee;
  }
  .product-video-frame {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 24px 70px rgba(35, 65, 27, .12);
    margin-top: 48px;
    overflow: hidden;
  }
  .product-video-frame video { aspect-ratio: 16 / 10; background: #111; object-fit: cover; width: 100%; }

  .assets-section { background: #fee934; }
  .benefit-grid { display: grid; gap: 18px; grid-template-columns: repeat(3, 1fr); margin-top: 48px; }
  .benefit-grid figure { overflow: hidden; }
  .benefit-grid img { aspect-ratio: 1; object-fit: cover; width: 100%; }

  .editorial-section { background: #f4f8ee; }
  .editorial-grid { display: grid; gap: 18px; grid-template-columns: repeat(3, 1fr); margin-top: 48px; }
  .editorial-grid figure { background: #fff; border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; }
  .editorial-grid img { aspect-ratio: 487 / 325; object-fit: cover; width: 100%; }

  .kit-section { background: #fff; }
  .kit-grid {
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr 1.25fr;
    margin-top: 48px;
  }
  .token-grid,
  .type-grid,
  .state-grid {
    display: grid;
    gap: 18px;
  }
  .token-grid { grid-template-columns: repeat(2, 1fr); }
  .type-grid { grid-template-columns: 1fr; }
  .state-grid { grid-column: 1 / -1; grid-template-columns: repeat(3, 1fr); }
  .kit-grid figure { display: grid; overflow: hidden; }
  .token-grid img,
  .type-grid img,
  .state-grid img {
    aspect-ratio: 16 / 7;
    background: #fff;
    object-fit: contain;
    padding: 20px;
    width: 100%;
  }
  .token-grid img { aspect-ratio: 4 / 3; padding: 0; }
  .state-grid img { aspect-ratio: 16 / 5; }

  .gallery { display: grid; gap: 18px; grid-template-columns: repeat(3, 1fr); }
  .gallery figure { overflow: hidden; }
  .gallery img { aspect-ratio: 4 / 3; object-fit: cover; width: 100%; }
  figcaption { color: var(--muted); font-size: 12px; font-weight: 900; padding: 16px; text-transform: uppercase; }

  .result { background: var(--ink); color: #fff; }
  .result .eyebrow, .result-copy > p { color: rgba(255, 255, 255, .72); }
  .result-copy { max-width: 960px; }
  .result .button { margin-top: 34px; }
  .project-button {
    background: #fee934;
    border-color: #fee934;
    color: #172b20;
  }

  @media (max-width: 1100px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
    .product-video-section { grid-template-columns: 1fr; }
    .benefit-grid, .editorial-grid { grid-template-columns: repeat(2, 1fr); }
    .kit-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    .header-actions { gap: 5px; }
    .case-sidebar { padding: 36px 18px; }
    .case-content > section { padding-left: 18px; padding-right: 18px; }
    .hero-copy, .story-section, .result { grid-template-columns: 1fr; }
    .hero-copy .eyebrow, .highlight-grid { grid-column: 1; }
    .highlight-grid, .benefit-grid, .editorial-grid, .gallery, .token-grid, .state-grid { grid-template-columns: 1fr; }
    .section-number { display: none; }
  }
</style>
