  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); overflow-x: hidden; }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, h4, dl, dd, figure, ul { margin: 0; }
  ul { list-style: none; padding: 0; }
  img, video { display: block; max-width: 100%; }
  button { font: inherit; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(238, 244, 251, .92);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand {
    align-items: center;
    display: inline-flex;
    font-size: 28px;
    font-weight: 900;
    gap: 10px;
    justify-self: start;
  }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(5, 7, 10, .18) !important;
    color: rgba(5, 7, 10, .46) !important;
  }

  main {
    display: grid;
    grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr);
    min-width: 0;
    transition: grid-template-columns .42s cubic-bezier(.16, 1, .3, 1);
  }
  body.case-nav-collapsed main {
    grid-template-columns: 0 minmax(0, 1fr);
  }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
    overflow: hidden;
    transition: opacity .28s ease, transform .42s cubic-bezier(.16, 1, .3, 1), visibility .28s ease;
  }
  body.case-nav-collapsed .case-sidebar {
    opacity: 0;
    pointer-events: none;
    transform: translateX(-20px);
    visibility: hidden;
  }
