---
const base = import.meta.env.BASE_URL;
const media = `${base}projects/faberlic`;

const facts = [
  ["Kunde", "Faberlic"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2018"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Hover statt Katalog", "Produktkarten reagieren wie im Original: Bild, Nutzen und der Impuls 'mehr erfahren' werden zu einer kleinen Interaktion."],
  ["Rezepte als Anwendung", "Der Rezeptbereich zeigt sofort, wofuer die Helfer gebraucht werden: vorbereiten, schneiden, backen, servieren."],
  ["Editoriale Tiefe", "Artikel und Tipps erweitern die Produktwelt zu einer warmen Geschichte ueber die Kueche als Mittelpunkt des Zuhauses."],
];

const productCards = [
  ["product-chopper.jpg", "Zerkleinerer", "Schneller Vorbereiten", "Kleine Helfer werden im Hover als konkrete Alltagserleichterung lesbar."],
  ["product-cheese-grater.jpg", "Kaesereibe", "Praezision am Tisch", "Die Karte fuehrt vom Produktfoto direkt zum Nutzen beim Kochen."],
  ["product-fine-grater.jpg", "Feine Reibe", "Textur als Detail", "Ein zweiter Reibentyp zeigt, wie breit der Slider kleine Aufgaben im Kochprozess abdeckt."],
  ["product-bowl-large.jpg", "Schuessel mit Deckel", "Vorbereiten & Aufbewahren", "Ein einzelnes Objekt erklaert Mise en Place, Ordnung und Servieren."],
  ["product-bowl-small.jpg", "Kleine Schuessel", "Portionieren", "Die kleinere Variante macht das Sortiment systematisch statt zufaellig."],
  ["product-baking-form.jpg", "Backform", "Vom Rezept zum Ergebnis", "Der Hover verbindet Produkt und Rezeptmoment ohne lange Erklaerung."],
  ["product-fish-scraper.jpg", "Fischschaber", "Spezialwerkzeug", "Auch sehr konkrete Tools bekommen im Hover eine klare Aufgabe."],
  ["product-container-small.jpg", "Kleiner Container", "Ordnung im Vorrat", "Aufbewahrung wird als Teil der Kuechenroutine sichtbar."],
  ["product-container-medium.jpg", "Mittlerer Container", "Meal Prep", "Die Produktfamilie zeigt, dass das Special nicht nur einzelne Gadgets verkauft."],
  ["product-spice-mill.jpg", "Gewuerzmuehle", "Geschmack als Detail", "Kleine Accessoires geben der Kampagne redaktionelle Naehe."],
  ["product-spice-jar.jpg", "Gewuerzbehaelter", "Griffbereit", "Der Hover macht selbst kleine Organisationsprodukte aktiv und klickbar."],
  ["product-board.jpg", "Schneidebrett", "Arbeitsflaeche als Buehne", "Der ruhige Produktstil macht das Sortiment vergleichbar und klar."],
];

const recipes = [
  ["recipe-dorada.jpg", "Dorada mit Kraeutern", "Fischrezept als natuerliche Anwendung fuer Brett, Reibe und Gewuerze."],
  ["recipe-trout.jpg", "Forelle mit Sauce", "Der warme Food-Shot uebersetzt die Produktwelt in ein Abendessen."],
  ["recipe-pear-pie.jpg", "Honig-Birnen-Kuchen", "Backform und Schuesseln bekommen einen emotionalen Zielmoment."],
  ["recipe-vegetable-pie.jpg", "Offener Gemuesekuchen", "Frische Zutaten, Vorbereiten und Servieren werden in einem Bild gebuendelt."],
  ["recipe-casserole.jpg", "Quarkauflauf", "Suesse Rezepte erweitern die Kueche vom Alltag zum Wochenendmoment."],
  ["recipe-farfalle.jpg", "Farfalle mit Pilzen", "Pasta bringt den Alltagsmoment in die Kampagne und erdet das Sortiment."],
  ["recipe-chicken.jpg", "Gebackene Haehnchenkeulen", "Der Ofenmoment gibt Backform, Gewuerzen und Vorbereitung einen gemeinsamen Kontext."],
  ["recipe-salad.jpg", "Warmer Kuerbissalat", "Der Rezeptmix macht das Sortiment vielseitig statt nur dekorativ."],
];

const campaignSteps = [
  ["01", "Hero", "Die Kueche wird nicht als Raum, sondern als Gefuehl inszeniert: hell, warm, ruhig, nutzbar."],
  ["02", "Goods Slider", "Produkte erscheinen als klickbare Karten mit Hover-Logik und klaren Anwendungsmomenten."],
  ["03", "Recipe Carousel", "Das Karussell zeigt, wie aus einzelnen Tools konkrete Gerichte und Rituale werden."],
  ["04", "Articles", "Redaktionelle Tipps geben dem Auftritt Tiefe und verbinden Produkt, Kochen und Zuhause."],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Faberlic Kitchen Lifestyle Campaign 2018 - Case Study von Andrii Prokhorovych." />
    <title>Faberlic Kitchen Campaign 2018 - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=faberlic`}>Редактировать</a>
        <a class="button dark small" data-owner-only hidden href="https://www.edimdoma.ru/2018/faberlic" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2018</p>
          <img class="client-logo" src={`${media}/logo.svg`} alt="Faberlic" />
          <h1>Die Kueche als Herz des Zuhauses</h1>
          <p class="intro">
            Eine wohnliche Lifestyle-Kampagne fuer Faberlic by Julia Vysotskaya, die
            Kuechenaccessoires, Rezeptinspiration und redaktionelle Tipps verbindet.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#konzept">02 Konzept</a>
          <a href="#highlights">03 Highlights</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Lifestyle · Product Campaign</p>
            <h2>Kuechenhelfer werden zu kleinen Alltagsritualen</h2>
            <p>
              Der neue Case zeigt Faberlic nicht als trockenen Produktkatalog, sondern als
              warme Kuechenwelt: Produkte, Rezepte und Tipps greifen ineinander und fuehren
              von der Entdeckung direkt zur Anwendung.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero-concept.jpg`} alt="Faberlic Kuechenwelt mit Produkten und warmer Wohnkueche" />
            <span>Hero · neu gezeichnete Kampagnenbuehne</span>
          </div>
        </section>

        <section id="konzept" class="story-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Konzept</p>
            <h2>Eine helle Kueche als System fuer Produkte, Rezepte und Tipps</h2>
            <p>
              Die Gestaltung nimmt die Idee des Originals auf: Die Kueche ist der emotionale
              Mittelpunkt. Der Portfolio-Case ordnet diese Welt jetzt in klare Bereiche:
              Hero, Hover-Produkte, Rezeptbuehne und redaktionelle Anwendung.
            </p>
          </div>
          <div class="quote">
            <p>„Ein guter Produktcase verkauft nicht nur Dinge. Er zeigt, wann man sie anfassen will.“</p>
          </div>
        </section>

        <section class="product-system" aria-labelledby="product-title">
          <div class="section-copy">
            <p class="eyebrow">Originalbereich · Goods Slider</p>
            <h2 id="product-title">Produktkarten mit Hover-Effekt und klarem Nutzen</h2>
            <p>
              Der alte Slider wird als dichtes Produktsystem erzaehlt: Jede Karte hat ein
              eigenes Bild aus dem Special und einen Hover, der wie im Original die naechste
              Aktion andeutet.
            </p>
          </div>
          <div class="product-grid">
            {productCards.map(([image, title, kicker, text]) => (
              <article class="product-card">
                <div class="product-image">
                  <img src={`${media}/${image}`} alt={title} loading="lazy" />
                </div>
                <div class="product-copy">
                  <span>{kicker}</span>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </div>
                <div class="hover-note">подробнее</div>
              </article>
            ))}
          </div>
        </section>

        <section class="journey-section" aria-label="Kampagnenlogik">
          <div class="section-copy">
            <p class="eyebrow">Struktur</p>
            <h2>Vom ersten Bild bis zum Rezeptmoment</h2>
          </div>
          <div class="journey-grid">
            {campaignSteps.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="highlights" class="highlights">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was den Auftritt besonders macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="recipe-stage" aria-labelledby="recipe-title">
          <div class="section-copy">
            <p class="eyebrow">Originalbereich · Rezeptkarussell</p>
            <h2 id="recipe-title">Rezepte zeigen, wofuer die Tools im Alltag gebraucht werden</h2>
            <p>
              Statt das Hero-Bild zu wiederholen, nutzt dieser Bereich die Food-Bilder aus
              dem Originalkarussell. So wird der Nutzen klickbar: vorbereiten, wuerzen,
              backen, anrichten.
            </p>
          </div>
          <div class="recipe-grid">
            {recipes.map(([image, title, text]) => (
              <figure class="recipe-card">
                <img src={`${media}/${image}`} alt={title} loading="lazy" />
                <figcaption>
                  <strong>{title}</strong>
                  <span>{text}</span>
                </figcaption>
              </figure>
            ))}
          </div>
        </section>

        <section class="gallery" aria-label="Kampagnenansichten">
          <figure class="large">
            <img src={`${media}/recipe-farfalle.jpg`} alt="Farfalle Rezept aus dem Faberlic Special" loading="lazy" />
            <figcaption>Rezeptwelt · Food-Bild als Anwendung der Kuechenhelfer</figcaption>
          </figure>
          <figure>
            <img src={`${media}/product-fish-scraper.jpg`} alt="Faberlic Fischschaber Produktkarte" loading="lazy" />
            <figcaption>Produktdetail · Hover-Slider</figcaption>
          </figure>
          <figure>
            <img src={`${media}/product-container-medium.jpg`} alt="Faberlic Aufbewahrungscontainer Produktkarte" loading="lazy" />
            <figcaption>Sortiment · Aufbewahrung und Ordnung</figcaption>
          </figure>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Aus Sortiment wird ein lebendiger Kuechenkosmos</h2>
            <p>
              Der Case zeigt nun die eigentliche Staerke des Specials: Produkte sind nicht
              isoliert, sondern werden ueber Hover, Rezepte und redaktionelle Themen in ein
              zusammenhaengendes Alltagserlebnis uebersetzt.
            </p>
            <a class="button light" data-owner-only hidden href="https://www.edimdoma.ru/2018/faberlic" target="_blank" rel="noreferrer">
              Originalprojekt oeffnen
            </a>
          </div>
        </section>
      </article>
    </main>
  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f7f7f5;
    --paper: #fff;
    --ink: #080808;
    --muted: #5f5f5f;
    --line: #dededb;
    --accent: #8dc7d8;
    --accent-dark: #0c5b78;
    --soft: #eaf6f8;
    --warm: #efe4d5;
    --radius: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img, video { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(247, 247, 245, .9);
    border-bottom: 1px solid rgba(222, 222, 219, .75);
    backdrop-filter: blur(18px);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
  }

  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(8, 8, 8, 0.18) !important;
    color: rgba(8, 8, 8, 0.46) !important;
  }
  .edit-page:hover,
  .edit-page:focus-visible {
    border-color: var(--ink) !important;
    color: var(--ink) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 70px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 100px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(32px, 4.5vw, 68px); line-height: 1.02; max-width: 900px; }
  .intro { hyphens: auto; overflow-wrap: anywhere; }
  .intro,
  .section-copy > p:last-child,
  .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media {
    background: linear-gradient(135deg, var(--soft), var(--warm));
    border-radius: var(--radius);
    box-shadow: 0 28px 80px rgba(12, 91, 120, .12);
    overflow: hidden;
  }
  .hero-media img { aspect-ratio: 16 / 9; object-fit: cover; width: 100%; }
  .hero-media span { color: var(--accent-dark); display: block; font-size: 12px; font-weight: 900; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .story-section,
  .highlights,
  .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 850px; }
  .quote {
    background: linear-gradient(135deg, var(--accent-dark), #73b7cf);
    border-radius: var(--radius);
    color: #fff;
    font-size: clamp(26px, 4vw, 52px);
    font-weight: 800;
    grid-column: 2;
    line-height: 1.12;
    margin-top: 28px;
    padding: clamp(28px, 5vw, 70px);
  }

  .product-system { background: #101819; color: #fff; }
  .product-system .eyebrow,
  .product-system .section-copy > p:last-child { color: rgba(255, 255, 255, .68); }
  .product-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 48px;
  }
  .product-card {
    background: #fff;
    border-radius: 16px;
    color: var(--ink);
    min-height: 390px;
    overflow: hidden;
    position: relative;
    transition: transform .35s ease, box-shadow .35s ease;
  }
  .product-card:hover {
    box-shadow: 0 22px 60px rgba(0, 0, 0, .26);
    transform: translateY(-8px);
  }
  .product-image {
    align-items: center;
    background: linear-gradient(180deg, #f8fbfb, #eef6f8);
    display: flex;
    height: 210px;
    justify-content: center;
    padding: 24px;
  }
  .product-image img {
    max-height: 170px;
    object-fit: contain;
    transition: transform .35s ease;
    width: 100%;
  }
  .product-card:hover .product-image img { transform: scale(1.08) rotate(-1.5deg); }
  .product-copy { padding: 24px; }
  .product-copy span {
    color: var(--accent-dark);
    display: block;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .product-copy h3 { font-size: 24px; line-height: 1.05; }
  .product-copy p { color: var(--muted); font-size: 14px; line-height: 1.55; margin-top: 14px; }
  .hover-note {
    background: var(--accent-dark);
    border-radius: 999px;
    bottom: 18px;
    color: #fff;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    opacity: 0;
    padding: 10px 16px;
    position: absolute;
    right: 18px;
    text-transform: uppercase;
    transform: translateY(10px);
    transition: opacity .25s ease, transform .25s ease;
  }
  .product-card:hover .hover-note { opacity: 1; transform: translateY(0); }

  .journey-section { background: var(--soft); }
  .journey-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(4, 1fr);
    margin-top: 46px;
  }
  .journey-grid article {
    background: rgba(255, 255, 255, .78);
    border: 1px solid rgba(12, 91, 120, .12);
    border-radius: 16px;
    min-height: 250px;
    padding: 24px;
  }
  .journey-grid span { color: var(--accent-dark); font-size: 13px; font-weight: 900; }
  .journey-grid h3 { font-size: 21px; margin-top: 48px; }
  .journey-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .highlight-grid { display: grid; gap: 18px; grid-column: 2; grid-template-columns: repeat(3, 1fr); margin-top: 24px; }
  .highlight-grid article { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); min-height: 260px; padding: 26px; }
  .highlight-grid span { color: var(--muted); font-size: 12px; font-weight: 900; }
  .highlight-grid h3 { font-size: 20px; line-height: 1.2; margin-top: 54px; }
  .highlight-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .recipe-stage { background: #fff; }
  .recipe-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 48px;
  }
  .recipe-card {
    background: var(--paper);
    border: 1px solid var(--line);
    border-radius: 18px;
    overflow: hidden;
    transition: transform .3s ease, box-shadow .3s ease;
  }
  .recipe-card:hover {
    box-shadow: 0 20px 50px rgba(12, 91, 120, .13);
    transform: translateY(-6px);
  }
  .recipe-card img { aspect-ratio: 4 / 3; object-fit: cover; width: 100%; }
  .recipe-card figcaption { display: grid; gap: 10px; padding: 20px; text-transform: none; }
  .recipe-card strong { font-size: 18px; }
  .recipe-card span { color: var(--muted); font-size: 14px; font-weight: 500; line-height: 1.55; }

