---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/maguro-travel`;

const facts = [
  ["Kunde", "Maguro"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2017"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Travel-Metapher als Navigation", "Die Kampagne rahmt Fisch und Seafood als kulinarische Reise mit Karte, Routen und Entdeckungsstationen."],
  ["Rezeptwelt mit Nutzwert", "Sechs Rezeptkarten fuehren schnell zu konkreten Gerichten und machen die Produktwelt alltagstauglich."],
  ["Menu-Konstruktor als Interaktion", "Der Nutzer kann Zutaten kombinieren und ein eigenes Gericht zusammenstellen - eine spielerische Aktivierung im Kampagnenfluss."],
];

const recipes = [
  ["recipe-01.jpg", "Bruschetta mit Thunfisch"],
  ["recipe-02.jpg", "Poke mit Thunfisch"],
  ["recipe-03.jpg", "Fisch mit Sauce und Zucchini"],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Maguro Travel Special Project 2017 - Case Study von Andrii Prokhorovych." />
    <title>Maguro Travel Campaign 2017 - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=maguro-travel`}>Редактировать</a>
        <a class="button dark small" data-owner-only hidden href="https://www.edimdoma.ru/magurotravel" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2017</p>
          <img class="client-logo" src={`${media}/logo.svg`} alt="Maguro" />
          <h1>Seafood als kulinarische Reise</h1>
          <p class="intro">
            Ein Special Project, das Fisch, Meeresfruechte, Rezepte und Wettbewerb
            als spielerisches Reiseformat zusammenfuehrt.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#konzept">02 Konzept</a>
          <a href="#highlights">03 Highlights</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Food & Beverage · Seafood Campaign</p>
            <h2>Ein Geschmackstrip durch die Welt von Fisch und Meeresfruechten</h2>
            <p>
              Maguro Travel baut eine redaktionelle Markenwelt: Nutzer starten mit einer
              Reiseidee, entdecken Seafood-Produkte auf einer Karte, finden passende
              Rezepte und werden ueber einen Wettbewerb zur Teilnahme gefuehrt.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero-original.jpg`} alt="Maguro Travel Special Project Startscreen" />
            <span>Startseite · Reise-Inszenierung</span>
          </div>
        </section>

        <section id="konzept" class="story-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Konzept</p>
            <h2>Eine Produktwelt wird zur Reiseplanung</h2>
            <p>
              Statt Seafood nur als Produktliste zu zeigen, wird die Kampagne wie ein
              Notizbuch fuer kulinarische Entdeckungen aufgebaut. Die Karte erzeugt
              Orientierung, Rezepte geben konkrete Anwendung, der Konstruktor macht das
              Thema interaktiv.
            </p>
          </div>
          <div class="quote">
            <p>„Die Kampagne verkauft nicht nur Fisch, sie laedt zu einer kleinen Expedition ein.“</p>
          </div>
        </section>

        <section class="journey-section" aria-labelledby="journey-title">
          <div class="section-copy">
            <p class="eyebrow">Interaktion</p>
            <h2 id="journey-title">Vom Kartenmotiv zum eigenen Gericht</h2>
          </div>
          <div class="journey-grid">
            <article class="journey-card map-card">
              <img src={`${media}/hero.jpg`} alt="Maguro Kampagnenuebersicht" loading="lazy" />
              <h3>Reise-Einstieg</h3>
              <p>Die Kampagne nutzt Reiserouten, Laender und Produkte als Orientierungssystem.</p>
            </article>
            <article class="journey-card image-card">
              <img src={`${media}/constructor.jpg`} alt="Maguro Menu-Konstruktor" loading="lazy" />
              <h3>Menu-Konstruktor</h3>
              <p>Ein spielerischer Modulbereich fuehrt Zutaten und Seafood-Produkte zusammen.</p>
            </article>
          </div>
        </section>

        <section id="highlights" class="highlights">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was den Auftritt besonders macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="recipes" aria-label="Rezeptkarten">
          <div class="section-copy">
            <p class="eyebrow">Dary Morya</p>
            <h2>Rezepte als direkter Nutzwert</h2>
          </div>
          <div class="recipe-grid">
            {recipes.map(([image, title]) => (
              <figure>
                <img src={`${media}/${image}`} alt={title} loading="lazy" />
                <figcaption>{title}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <section class="gallery" aria-label="Kampagnenansichten">
          <figure class="large">
            <img src={`${media}/contest.jpg`} alt="Maguro Rezeptwettbewerb" loading="lazy" />
            <figcaption>Contest-Modul als Aktivierung am Ende der Reise</figcaption>
          </figure>
          <figure>
            <img src={`${media}/cover-legacy.jpg`} alt="Maguro Cover" loading="lazy" />
          </figure>
          <figure>
            <img src={`${media}/constructor.jpg`} alt="Maguro interaktiver Menu-Konstruktor" loading="lazy" />
          </figure>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Aus Seafood-Produkten wird eine entdeckbare Kampagnenplattform</h2>
            <p>
              Das Projekt verbindet Markeninszenierung, redaktionelle Inhalte, Rezeptnutzen
              und Wettbewerb in einer klaren Reise-Dramaturgie. So bekommt die Produktwelt
              eine emotionale und interaktive Oberflaeche.
            </p>
            <a class="button light" data-owner-only hidden href="https://www.edimdoma.ru/magurotravel" target="_blank" rel="noreferrer">
              Originalprojekt oeffnen
            </a>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />

  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f0f3f7;
    --paper: #fff;
    --ink: #101820;
    --muted: #5e6d76;
    --line: rgba(16, 24, 32, .12);
    --accent: #cc1427;
    --sea: #396a81;
    --yellow: #fff13c;
    --radius: 10px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(240, 243, 247, .92);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(16, 24, 32, 0.18) !important;
    color: rgba(16, 24, 32, 0.46) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 64px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 170px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(32px, 4.5vw, 68px); line-height: 1.02; max-width: 900px; }
  .intro { hyphens: auto; overflow-wrap: anywhere; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media { background: var(--accent); border-radius: var(--radius); overflow: hidden; position: relative; }
  .hero-media > img:first-child { aspect-ratio: 16 / 9; object-fit: cover; object-position: center top; width: 100%; }
  .hero-media span { color: #fff; display: block; font-size: 12px; font-weight: 800; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .story-section, .highlights, .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 850px; }
  .quote {
    background: var(--sea);
    border-radius: var(--radius);
    color: #fff;
    font-size: clamp(26px, 4vw, 52px);
    font-weight: 800;
    grid-column: 2;
    line-height: 1.12;
    margin-top: 28px;
    padding: clamp(28px, 5vw, 70px);
  }

  .journey-section { background: #fff; }
  .journey-grid { display: grid; gap: 18px; grid-template-columns: 1fr 1fr; margin-top: 48px; }
  .journey-card { background: var(--bg); border-radius: var(--radius); overflow: hidden; }
  .journey-card img { aspect-ratio: 16 / 10; object-fit: cover; width: 100%; }
  .journey-card h3 { color: var(--sea); font-size: 24px; line-height: 1.15; padding: 24px 24px 0; }
  .journey-card p { color: var(--muted); font-size: 15px; line-height: 1.6; padding: 12px 24px 28px; }

  .highlight-grid { display: grid; gap: 18px; grid-column: 2; grid-template-columns: repeat(3, 1fr); margin-top: 24px; }
  .highlight-grid article { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); min-height: 260px; padding: 26px; }
  .highlight-grid span { color: var(--accent); font-size: 12px; font-weight: 900; }
  .highlight-grid h3 { font-size: 20px; line-height: 1.2; margin-top: 54px; }
  .highlight-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .recipes { background: #f7f5e8; }
  .recipe-grid { display: grid; gap: 18px; grid-template-columns: repeat(3, 1fr); margin-top: 42px; }
  .recipe-grid figure { background: #fff; border-radius: var(--radius); overflow: hidden; }
  .recipe-grid img { aspect-ratio: 1; object-fit: cover; width: 100%; }
  .recipe-grid figcaption { color: var(--sea); font-size: 18px; font-weight: 900; padding: 18px; text-transform: none; }

  .gallery { display: grid; gap: 18px; grid-template-columns: 1fr 1fr; }
  .gallery figure { background: var(--paper); border-radius: var(--radius); overflow: hidden; }
  .gallery .large { grid-column: 1 / -1; }
  .gallery img { aspect-ratio: 16 / 10; object-fit: cover; width: 100%; }
  .gallery .large img { aspect-ratio: 16 / 7; object-position: top center; }
  figcaption { color: var(--muted); font-size: 12px; font-weight: 800; padding: 16px; text-transform: uppercase; }

  .result { background: var(--accent); color: #fff; }
  .result .eyebrow, .result-copy > p { color: #ffe2e5; }
  .result-copy { max-width: 900px; }
  .result .button { border-color: #fff; margin-top: 34px; }

  @media (max-width: 1100px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
    .journey-grid, .recipe-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    .header-actions { gap: 5px; }
    .case-sidebar { padding: 36px 18px; }
    .case-content > section { padding-left: 18px; padding-right: 18px; }
    .hero-copy, .story-section, .highlights, .result { grid-template-columns: 1fr; }
    .hero-copy .eyebrow, .quote, .highlight-grid { grid-column: 1; }
    .highlight-grid, .gallery { grid-template-columns: 1fr; }
    .gallery .large { grid-column: 1; }
    .section-number { display: none; }
  }
</style>
