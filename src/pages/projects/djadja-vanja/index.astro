---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/djadja-vanja`;

const facts = [
  ["Kunde", "Djadja Vanja"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2021"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Atmosphaerische Buehne", "Ein bildschirmfuellendes Video fuehrt direkt in die warme, naturnahe Welt der Marke."],
  ["Editoriale Navigation", "Die Themenbereiche verbinden Produktwissen, Rezepte und Markenstory in einer klaren Dramaturgie."],
  ["Food Storytelling", "Grosszuegige Rezeptbilder machen die Produktanwendung unmittelbar und appetitlich erlebbar."],
];

const productSlides = [
  ["jar-01.png", "jar-01-hover.png", "Bulgur nach Samarkand-Art"],
  ["jar-02.png", "jar-02-hover.png", "Gebackene Bohnen nach Hausart"],
  ["jar-03.png", "jar-03-hover.png", "Letscho nach Transkarpatien-Art"],
  ["jar-04.png", "jar-04-hover.png", "Lobio Alt-Tiflis"],
  ["jar-05.png", "jar-05-hover.png", "Ungarischer Gemuesesnack"],
  ["jar-06.png", "jar-06-hover.png", "Auberginenkaviar nach Balkan-Art"],
  ["jar-07.png", "jar-07-hover.png", "Zucchinikaviar"],
  ["jar-08.png", "jar-08-hover.png", "Zucchini in Adjika"],
  ["jar-09.png", "jar-09-hover.png", "Melitopoler Gemuesesnack"],
  ["jar-10.png", "jar-10-hover.png", "Toskanischer Bohnensnack"],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Djadja Vanja Special Project - Case Study von Andrii Prokhorovych." />
    <title>Djadja Vanja - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=djadja-vanja`}>Редактировать</a>
        <a class="button dark small" href="https://www.edimdoma.ru/2021/dv" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2021</p>
          <img class="client-logo" src={`${media}/logo.svg`} alt="Djadja Vanja" />
          <h1>Digitales Storytelling fuer eine Traditionsmarke</h1>
          <p class="intro">
            Ein saisonales Special Project, das Produkte, Rezepte und Markenwerte in einer warmen,
            atmosphaerischen Web-Erfahrung verbindet.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#konzept">02 Konzept</a>
          <a href="#highlights">03 Highlights</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Food & Beverage · Digital Campaign</p>
            <h2>Eine digitale Reise zu ehrlichem Geschmack</h2>
            <p>
              Für Djadja Vanja entstand eine Content-Plattform innerhalb von Edim Doma. Das Projekt
              inszeniert die Marke nicht nur als Produkt, sondern als Teil einer vertrauten,
              genussvollen Lebenswelt.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero.jpg`} alt="Startseite des Djadja-Vanja-Special-Projects" />
            <span>Startseite · Desktop</span>
          </div>
        </section>

        <section id="konzept" class="story-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Konzept</p>
            <h2>Die Marke als redaktionelle Geschichte</h2>
            <p>
              Der visuelle Ansatz kombiniert die Vertrautheit einer traditionellen Food-Marke mit
              einer modernen, grosszuegigen Web-Praesentation. Die Navigation fuehrt durch Produkte,
              saisonale Menues, Wissenswertes und persoenliche Empfehlungen.
            </p>
          </div>
          <div class="quote">
            <p>„Eine Seite, die sich eher wie ein Besuch als wie Werbung anfuehlt.“</p>
          </div>
        </section>

        <section class="video-section" aria-labelledby="video-title">
          <div class="section-copy">
            <p class="eyebrow">Bewegtes Key Visual</p>
            <h2 id="video-title">Atmosphaere beginnt bereits im ersten Moment</h2>
          </div>
          <div class="video-frame">
            <video controls muted loop playsinline poster={`${media}/hero.jpg`}>
              <source src="https://www.edimdoma.ru/ads//backgrounds/video/uncle_vanya/uncle_vanya_720.mp4" type="video/mp4" />
            </video>
          </div>
        </section>

        <section class="products-section" aria-labelledby="products-title">
          <div class="section-copy">
            <p class="eyebrow">Interaktive Produktwelt</p>
            <h2 id="products-title">Jede Zutat wird beim Hover sichtbar</h2>
            <p>
              Die zehn Produktglaeser wechseln automatisch. Beim Ueberfahren verwandelt sich
              jedes Glas in seine individuelle Zutatenkomposition aus dem Originalprojekt.
            </p>
          </div>
          <div class="product-slider" data-product-slider>
            <button class="product-arrow previous" type="button" aria-label="Vorheriges Produkt" data-product-previous>←</button>
            <div class="product-stage">
              {productSlides.map(([regular, hover, label], index) => (
                <figure
                  class:list={["product-slide", { "is-active": index === 0 }]}
                  aria-hidden={index === 0 ? "false" : "true"}
                  data-label={label}
                  data-product-slide
                  tabindex={index === 0 ? "0" : "-1"}
                >
                  <div class="product-visual">
                    <img class="product-regular" src={`${media}/${regular}`} alt={`Djadja Vanja: ${label}`} loading={index === 0 ? "eager" : "lazy"} />
                    <img class="product-hover" src={`${media}/${hover}`} alt="" aria-hidden="true" loading="lazy" />
                  </div>
                </figure>
              ))}
            </div>
            <button class="product-arrow next" type="button" aria-label="Naechstes Produkt" data-product-next>→</button>
            <div class="product-slider-footer">
              <span data-product-caption>{productSlides[0][2]}</span>
              <div class="product-dots" aria-label="Produkt auswaehlen">
                {productSlides.map(([, , label], index) => (
                  <button
                    class:list={{ "is-active": index === 0 }}
                    type="button"
                    aria-label={label}
                    aria-current={index === 0 ? "true" : "false"}
                    data-product-dot
                  ></button>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section id="highlights" class="highlights">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was den Auftritt besonders macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="gallery" aria-label="Rezeptauswahl">
          <figure class="large">
            <img src={`${media}/recipe-01.jpg`} alt="Rezept aus dem Djadja-Vanja-Projekt" loading="lazy" />
            <figcaption>Food Content als visuelle Einladung</figcaption>
          </figure>
          <figure>
            <img src={`${media}/recipe-02.jpg`} alt="Rezept aus dem Djadja-Vanja-Projekt" loading="lazy" />
          </figure>
          <figure>
            <img src={`${media}/recipe-03.jpg`} alt="Rezept aus dem Djadja-Vanja-Projekt" loading="lazy" />
          </figure>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Ein Kampagnenauftritt mit eigener Welt</h2>
            <p>
              Das Special Project verbindet Markenkommunikation und nuetzlichen Food Content in
              einer klaren, emotionalen Nutzerreise. Die visuelle Gestaltung bleibt eigenstaendig,
              fuegt sich aber nahtlos in die Edim-Doma-Plattform ein.
            </p>
            <a class="button light" data-owner-only hidden href="https://www.edimdoma.ru/2021/dv" target="_blank" rel="noreferrer">
              Originalprojekt oeffnen
            </a>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />

  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });

  const productSlider = document.querySelector("[data-product-slider]");
  const productSlides = Array.from(document.querySelectorAll("[data-product-slide]"));
  const productDots = Array.from(document.querySelectorAll("[data-product-dot]"));
  const productCaption = document.querySelector("[data-product-caption]");
  const previousProduct = document.querySelector("[data-product-previous]");
  const nextProduct = document.querySelector("[data-product-next]");

  if (productSlider && productSlides.length > 1) {
    let activeProduct = 0;
    let autoplay;

    const showProduct = (nextIndex) => {
      productSlides[activeProduct].classList.remove("is-active");
      productSlides[activeProduct].setAttribute("aria-hidden", "true");
      productSlides[activeProduct].setAttribute("tabindex", "-1");
      productDots[activeProduct]?.classList.remove("is-active");
      productDots[activeProduct]?.setAttribute("aria-current", "false");

      activeProduct = (nextIndex + productSlides.length) % productSlides.length;
      const activeSlide = productSlides[activeProduct];
      activeSlide.classList.add("is-active");
      activeSlide.setAttribute("aria-hidden", "false");
      activeSlide.setAttribute("tabindex", "0");
      productDots[activeProduct]?.classList.add("is-active");
      productDots[activeProduct]?.setAttribute("aria-current", "true");
      if (productCaption) productCaption.textContent = activeSlide.dataset.label || "";
    };

    const stopAutoplay = () => clearInterval(autoplay);
    const startAutoplay = () => {
      stopAutoplay();
      if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
        autoplay = setInterval(() => showProduct(activeProduct + 1), 3200);
      }
    };

    previousProduct?.addEventListener("click", () => {
      showProduct(activeProduct - 1);
      startAutoplay();
    });
    nextProduct?.addEventListener("click", () => {
      showProduct(activeProduct + 1);
      startAutoplay();
    });
    productDots.forEach((dot, index) => dot.addEventListener("click", () => {
      showProduct(index);
      startAutoplay();
    }));
    productSlider.addEventListener("pointerenter", stopAutoplay);
    productSlider.addEventListener("pointerleave", startAutoplay);
    productSlider.addEventListener("focusin", stopAutoplay);
    productSlider.addEventListener("focusout", startAutoplay);
    startAutoplay();
  }
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f7f7f5;
    --paper: #fff;
    --ink: #080808;
    --muted: #5f5f5f;
    --line: #dededb;
    --accent: #173e36;
    --radius: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img, video { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(247, 247, 245, .9);
    border-bottom: 1px solid rgba(222, 222, 219, .75);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(8, 8, 8, 0.18) !important;
    color: rgba(8, 8, 8, 0.46) !important;
  }

  .edit-page:hover,
  .edit-page:focus-visible {
    border-color: var(--ink) !important;
    color: var(--ink) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 70px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 100px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(32px, 4.5vw, 68px); line-height: 1.02; max-width: 900px; }
  .intro { hyphens: auto; overflow-wrap: anywhere; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media { background: var(--accent); border-radius: var(--radius); overflow: hidden; }
  .hero-media img { aspect-ratio: 16 / 9; object-fit: cover; width: 100%; }
  .hero-media span { color: #fff; display: block; font-size: 12px; font-weight: 800; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .story-section, .highlights, .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 850px; }
  .quote {
    background: var(--accent);
    border-radius: var(--radius);
    color: #fff;
    font-size: clamp(26px, 4vw, 52px);
    font-weight: 800;
    grid-column: 2;
    line-height: 1.12;
    margin-top: 28px;
    padding: clamp(28px, 5vw, 70px);
  }

  .video-section { background: #111; color: #fff; }
  .video-section .eyebrow { color: #aaa; }
  .video-frame { border: 1px solid #333; border-radius: var(--radius); margin-top: 48px; overflow: hidden; }
  .video-frame video { aspect-ratio: 16 / 9; background: #000; object-fit: cover; width: 100%; }

  .products-section { background: #e9e3d4; }
  .products-section .section-copy > p:last-child { max-width: 700px; }
  .product-slider {
    background: #173e36;
    border-radius: var(--radius);
    display: grid;
    grid-template-columns: 68px minmax(0, 1fr) 68px;
    margin-top: 48px;
    overflow: hidden;
  }
  .product-stage { min-height: 590px; position: relative; }
  .product-slide {
    align-items: center;
    display: flex;
    inset: 0;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    transform: translateX(24px);
    transition: opacity .55s ease, transform .55s ease;
    visibility: hidden;
  }
  .product-slide.is-active {
    opacity: 1;
    pointer-events: auto;
    transform: translateX(0);
    visibility: visible;
  }
  .product-visual { height: 530px; position: relative; width: 324px; }
  .product-visual img {
    height: 100%;
    inset: 0;
    object-fit: contain;
    position: absolute;
    transition: opacity .35s ease, transform .45s cubic-bezier(.2, .8, .2, 1);
    width: 100%;
  }
  .product-hover { opacity: 0; transform: scale(.96); }
  .product-slide:hover .product-regular,
  .product-slide:focus-visible .product-regular { opacity: 0; transform: scale(1.04); }
  .product-slide:hover .product-hover,
  .product-slide:focus-visible .product-hover { opacity: 1; transform: scale(1); }
  .product-slide:focus-visible { outline: 2px solid #fff; outline-offset: -8px; }
  .product-arrow {
    background: transparent;
    border: 0;
    color: #fff;
    cursor: pointer;
    font-size: 30px;
    transition: background .2s ease;
    z-index: 2;
  }
  .product-arrow:hover { background: rgba(255, 255, 255, .08); }
  .product-slider-footer {
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, .18);
    color: #fff;
    display: flex;
    font-size: 13px;
    font-weight: 800;
    grid-column: 1 / -1;
    justify-content: space-between;
    min-height: 62px;
    padding: 12px 22px;
  }
  .product-dots { display: flex; gap: 7px; }
  .product-dots button {
    background: rgba(255, 255, 255, .32);
    border: 0;
    border-radius: 999px;
    cursor: pointer;
    height: 7px;
    padding: 0;
    transition: background .2s ease, width .2s ease;
    width: 7px;
  }
  .product-dots button.is-active { background: #fff; width: 22px; }

  .highlight-grid { display: grid; gap: 18px; grid-column: 2; grid-template-columns: repeat(3, 1fr); margin-top: 24px; }
  .highlight-grid article { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); min-height: 260px; padding: 26px; }
  .highlight-grid span { color: var(--muted); font-size: 12px; font-weight: 900; }
  .highlight-grid h3 { font-size: 20px; line-height: 1.2; margin-top: 54px; }
  .highlight-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .gallery { display: grid; gap: 18px; grid-template-columns: 1fr 1fr; }
  .gallery figure { background: var(--paper); border-radius: var(--radius); overflow: hidden; }
  .gallery .large { grid-column: 1 / -1; }
  .gallery img { aspect-ratio: 16 / 10; object-fit: cover; width: 100%; }
  .gallery .large img { aspect-ratio: 16 / 8; }
  figcaption { color: var(--muted); font-size: 12px; font-weight: 800; padding: 16px; text-transform: uppercase; }

  .result { background: var(--accent); color: #fff; }
  .result .eyebrow, .result-copy > p { color: #c6d1ce; }
  .result-copy { max-width: 900px; }
  .result .button { border-color: #fff; margin-top: 34px; }

  @media (max-width: 1100px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    .header-actions { gap: 5px; }
    .case-sidebar { padding: 36px 18px; }
    .case-content > section { padding-left: 18px; padding-right: 18px; }
    .hero-copy, .story-section, .highlights, .result { grid-template-columns: 1fr; }
    .hero-copy .eyebrow, .quote, .highlight-grid { grid-column: 1; }
    .highlight-grid, .gallery { grid-template-columns: 1fr; }
    .gallery .large { grid-column: 1; }
    .section-number { display: none; }
    .product-slider { grid-template-columns: 46px minmax(0, 1fr) 46px; }
    .product-stage { min-height: 470px; }
    .product-visual { height: 420px; width: 257px; }
    .product-slider-footer { align-items: flex-start; flex-direction: column; gap: 12px; }
    .product-dots { flex-wrap: wrap; }
  }
</style>
