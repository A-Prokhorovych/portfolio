---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/scotch-brite`;

const facts = [
  ["Kunde", "Scotch-Brite"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2017"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Expertenteam als Story-Motor", "Fuenf Figuren strukturieren die Themen von Menue und Einladung bis Tischdeko und Reinigung."],
  ["Video-Tipps mit Nutzwert", "Kurze How-to-Module machen Haushaltswissen greifbar und fuehren direkt in die Produktwelt."],
  ["Produktwelt im Kontext", "Schwaemme und Tuecher werden nicht isoliert gezeigt, sondern als Helfer rund um ein gelungenes Fest."],
];

const modules = [
  ["team-bg.jpg", "Expertenteam", "Eine Slider-Buehne stellt die Helfer fuer Planung, Dekoration, Kochen und Reinigung vor."],
  ["video-01.jpg", "Video-Tipps", "Kompakte Ratgeberclips beantworten konkrete Reinigungsfragen in der Kueche."],
  ["product-01.jpg", "Produktlinie", "Die Produktmodule verbinden Anwendungsszenario, Nutzen und weiterfuehrende Aktion."],
  ["product-02.jpg", "Wissensbasis", "Artikel und Masterclasses erweitern die Kampagne zu einem nutzbaren Haushaltsratgeber."],
];

const guideSteps = [
  ["01", "Planen", "Das Special nimmt den Stress vor dem Fest ernst."],
  ["02", "Vorbereiten", "Expertinnen fuehren durch Kochen, Deko und Einladung."],
  ["03", "Reinigen", "Video-Tipps machen Produkte als Helfer konkret."],
  ["04", "Feiern", "Der saubere Raum wird Teil der Gastgebergeschichte."],
];

const originalScreens = [
  ["hero.jpg", "Originalscreen · Kampagnenstart mit Headline"],
  ["hero-original.jpg", "Originalfoto · Reinigung als freundliche Situation"],
  ["video-02.jpg", "Video-Modul · konkreter Haushaltstipp"],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Scotch-Brite Special Project 2017 - Case Study von Andrii Prokhorovych." />
    <title>Scotch-Brite Special Project 2017 - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=scotch-brite`}>Редактировать</a>
        <a class="button dark small" data-owner-only hidden href="https://www.edimdoma.ru/2017/scotch-brite" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2017</p>
          <img class="client-logo" src={`${media}/logo.svg`} alt="Scotch-Brite" />
          <h1>Haushaltswissen als freundlicher Party-Guide</h1>
          <p class="intro">
            Ein Special Project, das die Angst vor Gastgeberpflichten in eine hilfreiche,
            spielerische Content-Erfahrung uebersetzt.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#konzept">02 Konzept</a>
          <a href="#highlights">03 Highlights</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Lifestyle · Household Campaign</p>
            <h2>Wie man aufhoert, sich vor Feiertagen zu fuerchten</h2>
            <p>
              Scotch-Brite wurde als Begleiter fuer die gesamte Vorbereitung eines Festes
              inszeniert: planen, einladen, kochen, dekorieren, reinigen. Die Kampagne
              verbindet Rat, Unterhaltung und Produktnutzen in einer scrollbaren Markenwelt.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero-concept.jpg`} alt="Scotch-Brite Hero mit vorbereiteter Festtafel und Reinigungshelfern" />
            <span>Hero · Fest vorbereiten ohne Stress</span>
          </div>
        </section>

        <section class="reel-section" aria-labelledby="reel-title">
          <div class="section-copy">
            <p class="eyebrow">Remotion Experiment</p>
            <h2 id="reel-title">Der Party-Guide als kurzer Motion-Reel</h2>
            <p>
              Der Preview-Film zeigt die Kampagnenlogik in Bewegung: Hero, Expertenteam,
              Video-Tipps und Produktnutzen werden zu einer kompakten Gastgebergeschichte.
            </p>
          </div>
          <div class="reel-frame">
            <video controls preload="metadata" poster={`${media}/hero-concept.jpg`}>
              <source src={`${media}/reel-preview.mp4`} type="video/mp4" />
            </video>
            <span>Remotion Preview · Scotch-Brite Party Guide Reel</span>
          </div>
        </section>

        <section id="konzept" class="story-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Konzept</p>
            <h2>Eine Marke wird zum hilfreichen Gastgeber-Team</h2>
            <p>
              Statt Produkte nur zu praesentieren, arbeitet die Seite mit Rollen: Expertinnen
              fuer Kochen, Einladungen, Dekoration, Organisation und Reinigung fuehren durch
              typische Stresspunkte vor einem Fest. So wird die Produktwelt emotionaler und
              zugleich praktischer.
            </p>
          </div>
          <div class="quote">
            <p>„Reinigung wird interessanter, wenn sie Teil einer groesseren Geschichte wird.“</p>
          </div>
        </section>

        <section class="module-section" aria-labelledby="module-title">
          <div class="section-copy">
            <p class="eyebrow">Interaktive Kampagne</p>
            <h2 id="module-title">Slider, Videos und Wissensmodule als Content-System</h2>
            <p>
              Die Kampagne funktioniert nicht als einzelne Produktanzeige, sondern als
              Gastgeber-Guide: Expertenteam, How-to-Videos, Produktmodule und Wissensbasis
              bilden zusammen eine brauchbare Vorbereitung auf das Fest.
            </p>
          </div>
          <div class="module-grid">
            {modules.map(([image, title, text], index) => (
              <article>
                <img src={`${media}/${image}`} alt={title} loading="lazy" />
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="highlights" class="highlights">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was den Auftritt besonders macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="guide-section" aria-label="Guide-Dramaturgie">
          <div class="section-copy">
            <p class="eyebrow">Dramaturgie</p>
            <h2>Vom Feiertagsstress zur klaren Gastgeberroutine</h2>
          </div>
          <div class="guide-grid">
            {guideSteps.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="original-section" aria-label="Originalmechaniken">
          <article class="system-card">
            <p class="eyebrow">Originalmechanik</p>
            <h2>Das Original bleibt sichtbar, aber nicht dreifach wiederholt</h2>
            <p>
              Statt denselben Startscreen in jedem Block zu zeigen, trennt der Case die
              Mechaniken: Startscreen, Foto-Tonality und Video-Tipp. So wird der Aufbau des
              Specials klarer.
            </p>
          </article>
          {originalScreens.map(([image, caption]) => (
            <figure>
              <img src={`${media}/${image}`} alt={caption} loading="lazy" />
              <figcaption>{caption}</figcaption>
            </figure>
          ))}
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Aus Haushaltsprodukten wird ein aktivierender Content-Hub</h2>
            <p>
              Die Kampagne erweitert Scotch-Brite um eine freundliche Service-Rolle. Videos,
              Artikel, Expertenfiguren und Produktmodule machen die Marke im Alltag nutzbar
              und schaffen einen klaren Anlass zur Interaktion.
            </p>
            <a class="button light" data-owner-only hidden href="https://www.edimdoma.ru/2017/scotch-brite" target="_blank" rel="noreferrer">
              Originalprojekt oeffnen
            </a>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />

  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f5f8f4;
    --paper: #fff;
    --ink: #080808;
    --muted: #5f675f;
    --line: #dce4da;
    --accent: #0b7f5b;
    --accent-dark: #06543f;
    --fresh: #b8f04f;
    --mint: #dff7ef;
    --yellow: #ffe35c;
    --radius: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img, video { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(245, 248, 244, .9);
    border-bottom: 1px solid rgba(220, 228, 218, .75);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(8, 8, 8, 0.18) !important;
    color: rgba(8, 8, 8, 0.46) !important;
  }
  .edit-page:hover,
  .edit-page:focus-visible {
    border-color: var(--ink) !important;
    color: var(--ink) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 70px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 140px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(32px, 4.5vw, 68px); line-height: 1.02; max-width: 900px; }
  .intro { hyphens: auto; overflow-wrap: anywhere; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero {
    background:
      radial-gradient(circle at 12% 12%, rgba(184, 240, 79, .22), transparent 28%),
      radial-gradient(circle at 82% 22%, rgba(11, 127, 91, .14), transparent 28%),
      var(--bg);
    min-height: calc(100vh - 83px);
  }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media {
    background: linear-gradient(135deg, var(--mint), #fff);
    border-radius: 24px;
    box-shadow: 0 30px 90px rgba(6, 84, 63, .16);
    overflow: hidden;
    position: relative;
  }
  .hero-media > img:first-child { aspect-ratio: 16 / 9; object-fit: cover; width: 100%; }
  .hero-media span { color: var(--accent-dark); display: block; font-size: 12px; font-weight: 900; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .reel-section {
    background:
      radial-gradient(circle at 14% 18%, rgba(184, 240, 79, .22), transparent 28%),
      radial-gradient(circle at 84% 70%, rgba(11, 127, 91, .16), transparent 30%),
      linear-gradient(135deg, #fff, #eff7f2);
  }
  .reel-frame {
    background: #fff;
    border: 1px solid rgba(11, 127, 91, .14);
    border-radius: 24px;
    box-shadow: 0 28px 84px rgba(6, 84, 63, .12);
    margin-top: 48px;
    overflow: hidden;
  }
  .reel-frame video {
    aspect-ratio: 16 / 9;
    background: #000;
    display: block;
    width: 100%;
  }
  .reel-frame span {
    color: var(--accent);
    display: block;
    font-size: 12px;
    font-weight: 950;
    letter-spacing: .08em;
    padding: 16px 18px;
    text-transform: uppercase;
  }

  .story-section, .highlights, .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 850px; }
  .quote {
    background:
      radial-gradient(circle at 84% 18%, rgba(255, 227, 92, .3), transparent 26%),
      linear-gradient(135deg, var(--accent-dark), var(--accent));
    border-radius: var(--radius);
    color: #fff;
    font-size: clamp(26px, 4vw, 52px);
    font-weight: 800;
    grid-column: 2;
    line-height: 1.12;
    margin-top: 28px;
    padding: clamp(28px, 5vw, 70px);
  }

  .module-section {
    background:
      radial-gradient(circle at 18% 0%, rgba(184, 240, 79, .2), transparent 30%),
      linear-gradient(135deg, #fff, #eff7f2);
  }
  .module-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(4, 1fr);
    margin-top: 48px;
  }
  .module-grid article {
    background: rgba(255, 255, 255, .9);
    border: 1px solid rgba(11, 127, 91, .14);
    border-radius: 22px;
    box-shadow: 0 24px 70px rgba(6, 84, 63, .09);
    color: var(--ink);
    overflow: hidden;
    transition: box-shadow .35s ease, transform .35s ease;
  }
  .module-grid article:hover {
    box-shadow: 0 32px 86px rgba(6, 84, 63, .16);
    transform: translateY(-8px);
  }
  .module-grid img {
    aspect-ratio: 4 / 3;
    object-fit: cover;
    transition: transform .45s ease;
    width: 100%;
  }
  .module-grid article:hover img { transform: scale(1.05); }
  .module-grid span {
    color: var(--accent);
    display: block;
    font-size: 12px;
    font-weight: 900;
    padding: 20px 20px 0;
  }
  .module-grid h3 {
    font-size: 20px;
    line-height: 1.2;
    padding: 14px 20px 0;
  }
  .module-grid p {
    color: var(--muted);
    font-size: 14px;
    line-height: 1.55;
    padding: 12px 20px 24px;
  }

  .highlight-grid { display: grid; gap: 18px; grid-column: 2; grid-template-columns: repeat(3, 1fr); margin-top: 24px; }
  .highlight-grid article { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); min-height: 260px; padding: 26px; }
  .highlight-grid span { color: var(--muted); font-size: 12px; font-weight: 900; }
  .highlight-grid h3 { font-size: 20px; line-height: 1.2; margin-top: 54px; }
  .highlight-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .guide-section {
    background:
      radial-gradient(circle at 82% 16%, rgba(255, 227, 92, .22), transparent 26%),
      linear-gradient(135deg, var(--accent-dark), var(--accent));
    color: #fff;
  }
  .guide-section .eyebrow,
  .guide-grid p { color: rgba(255, 255, 255, .72); }
  .guide-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 48px;
  }
  .guide-grid article {
    background: rgba(255, 255, 255, .09);
    border: 1px solid rgba(255, 255, 255, .16);
    border-radius: 18px;
    min-height: 230px;
    padding: 24px;
  }
  .guide-grid span { color: var(--yellow); font-size: 13px; font-weight: 950; }
  .guide-grid h3 { font-size: 24px; line-height: 1.08; margin-top: 58px; }
  .guide-grid p { font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .original-section {
    background:
      linear-gradient(90deg, rgba(11, 127, 91, .07) 1px, transparent 1px),
      linear-gradient(180deg, #f5f8f4, #eaf5ee);
    background-size: 42px 42px, auto;
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }
  .original-section figure,
  .system-card {
    background: var(--paper);
    border-radius: 24px;
    box-shadow: 0 28px 80px rgba(6, 84, 63, .1);
    overflow: hidden;
  }
  .system-card {
    background:
      radial-gradient(circle at 82% 16%, rgba(184, 240, 79, .24), transparent 28%),
      linear-gradient(135deg, #fff, #eef8f1);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 420px;
    padding: clamp(28px, 4vw, 56px);
  }
  .system-card h2 { font-size: clamp(34px, 4vw, 58px); }
  .system-card p:last-child { color: var(--muted); font-size: 16px; line-height: 1.7; margin-top: 24px; max-width: 640px; }
  .original-section img { aspect-ratio: 16 / 10; object-fit: cover; width: 100%; }
  .original-section figure:first-of-type { grid-column: 2; grid-row: 1 / span 2; }
  .original-section figure:first-of-type img { aspect-ratio: 16 / 13.4; }
  figcaption { color: var(--muted); font-size: 12px; font-weight: 800; padding: 16px; text-transform: uppercase; }

  .result {
    background:
      radial-gradient(circle at 22% 18%, rgba(255, 227, 92, .24), transparent 24%),
      linear-gradient(135deg, var(--accent-dark), var(--accent));
    color: #fff;
  }
  .result .eyebrow, .result-copy > p { color: #d8f0e7; }
  .result-copy { max-width: 900px; }
  .result .button { border-color: #fff; margin-top: 34px; }

  @media (max-width: 1100px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
    .module-grid { grid-template-columns: repeat(2, 1fr); }
    .guide-grid { grid-template-columns: repeat(2, 1fr); }
    .original-section { grid-template-columns: 1fr; }
    .original-section figure:first-of-type { grid-column: auto; grid-row: auto; }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    .header-actions { gap: 5px; }
    .case-sidebar { padding: 36px 18px; }
