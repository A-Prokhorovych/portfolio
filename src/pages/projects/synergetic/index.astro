---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/synergetic`;

const facts = [
  ["Kunde", "Synergetic"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2018"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Acht Produkte klar navigiert", "Ein Slider mit Kategorieauswahl verbindet detaillierte Eigenschaften, Anwendungsbereiche und direkte Produktlinks."],
  ["Eco-Nutzen sofort sichtbar", "Biologische Abbaubarkeit, Hypoallergenität und antibakterielle Wirkung werden als wiederkehrende Produktargumente strukturiert."],
  ["Familienalltag als Kontext", "Ratgeber und Fotowettbewerb zeigen sichere Reinigung in Haushalten mit Kindern und Haustieren statt abstrakter Ökologie."],
];

const productCards = [
  ["product-bathroom.png", "Bad & Sanitär", "Desinfektion, Kalk, Rost und Geruch in einem Produktargument."],
  ["product-laundry.png", "Wäsche", "Hypoallergene Konzentratformel fuer Familienwaesche."],
  ["product-dish.png", "Geschirr", "Sichere Anwendung fuer Geschirr, Obst und Kindersachen."],
  ["product-soap.png", "Handpflege", "Alltagstouchpoint: Reinigung wird weich, nahbar und wiederkehrend."],
];

const campaignBlocks = [
  ["icon-bathroom.png", "Produktnavigator", "Acht Kategorien werden ueber Select, Slider und Sticky-Menue direkt vergleichbar."],
  ["icon-glass.png", "Ratgeber", "Artikel zu Kindern, Haustieren und gesunder Reinigung geben der Marke redaktionelle Tiefe."],
  ["icon-kitchen.png", "Fotowettbewerb", "Der Contest „Kinder ueberraschen“ macht Flecken und Alltagssituationen zur Aktivierung."],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Synergetic Eco Cleaning Campaign 2018 - Case Study von Andrii Prokhorovych." />
    <title>Synergetic Eco Cleaning Campaign 2018 - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=synergetic`}>Редактировать</a>
        <a class="button dark small" href="https://www.edimdoma.ru/2018/synergetic" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2018</p>
          <img class="client-logo" src={`${media}/logo.svg`} alt="Synergetic" />
          <h1>Ökologische Reinigung für den Familienalltag</h1>
          <p class="intro">
            Eine interaktive Produktkampagne für biologisch abbaubare Haushaltsreiniger,
            die Sortiment, Sicherheitsvorteile, praktische Ratgeber und Handel verbindet.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#konzept">02 Konzept</a>
          <a href="#highlights">03 Highlights</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Lifestyle · Eco Product Campaign</p>
            <h2>Wirksame Reinigung auf pflanzlicher Basis</h2>
            <p>
              Die Seite führt durch acht Mittel für Bad, Wäsche, Böden, Geschirr, Fenster,
              Hände, Rohre und Küche. Jede Kategorie kombiniert Produktbild, Eigenschaften,
              geeignete Oberflächen und einen direkten Weg zu weiteren Informationen.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero-concept.jpg`} alt="Synergetic Hero-Konzept mit Eco-Reinigungsprodukten und frischem Zuhause" />
            <span>Hero concept · Eco cleaning system</span>
          </div>
        </section>

        <section class="reel-section" aria-labelledby="reel-title">
          <div class="section-copy">
            <p class="eyebrow">Remotion Experiment</p>
            <h2 id="reel-title">Eco-Produktlogik als kurzer Motion-Reel</h2>
            <p>
              Der Preview-Film verdichtet den Case auf vier Momente: frische Eco-Welt,
              Produktnavigator, Originalscreen und der Weg von Produktleistung zu Vertrauen
              im Familienalltag.
            </p>
          </div>
          <div class="reel-frame">
            <video controls preload="metadata" poster={`${media}/hero-concept.jpg`}>
              <source src={`${media}/reel-preview.mp4`} type="video/mp4" />
            </video>
            <span>Remotion Preview · Synergetic Eco Cleaning Reel</span>
          </div>
        </section>

        <section id="konzept" class="story-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Konzept</p>
            <h2>Natur und Produktleistung in einem Bild</h2>
            <p>
              Frisches Blattgrün, Gras und viel Licht rahmen die Produktfamilie ein. Kräftiges
              Pink bringt Energie und hebt zentrale Aussagen hervor, während Illustration
              und klare Typografie die technische Produktinformation zugänglich machen.
            </p>
          </div>
          <div class="quote">
            <p>„Nachhaltigkeit überzeugt, wenn ökologische Werte und konkrete Reinigungsleistung gleich klar sichtbar sind.“</p>
          </div>
        </section>

        <section class="product-system" aria-labelledby="video-title">
          <div class="section-copy">
            <p class="eyebrow">Produktsystem</p>
            <h2 id="video-title">Ein Slider, der das Sortiment wirklich erklaert</h2>
            <p>
              Im Original ist die staerkste Mechanik der Produktnavigator: acht Reiniger,
              jeweils mit Illustration, Eigenschaften, Anwendungsbereich und Produktbild.
              Fuer das Portfolio wird daraus ein kuratiertes System statt eines wiederholten
              Startseiten-Screens.
            </p>
          </div>
          <div class="product-stage">
            <div class="product-copy">
              <img src={`${media}/logo-small.png`} alt="Synergetic" loading="lazy" />
              <h3>Antibakteriell, hypoallergen, biologisch abbaubar</h3>
              <p>
                Der Case verbindet Produktleistung mit Haushaltsmomenten: Bad, Waesche,
                Geschirr und Handpflege werden nicht als Katalog, sondern als Alltagssystem
                erzaehlt.
              </p>
            </div>
            <div class="product-cards">
              {productCards.map(([image, title, text]) => (
                <article>
                  <img src={`${media}/${image}`} alt={`Synergetic ${title}`} loading="lazy" />
                  <h3>{title}</h3>
                  <p>{text}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="highlights" class="highlights">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was den Auftritt besonders macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="gallery" aria-label="Kampagnenansichten">
          <figure class="large concept-card">
            <img src={`${media}/hero-concept.jpg`} alt="Synergetic Hero-Konzept als frische Eco-Reinigungswelt" loading="lazy" />
            <figcaption>Rebranding · Frische Eco-Welt statt statischem Startscreen</figcaption>
          </figure>
          {campaignBlocks.map(([image, title, text]) => (
            <article class="campaign-card">
              <img src={`${media}/${image}`} alt={title} loading="lazy" />
              <p>{title}</p>
              <h3>{text}</h3>
            </article>
          ))}
          <article class="contest-card">
            <span>Фотоконкурс</span>
            <h3>„Дети удивляют“</h3>
            <p>
              Внутренняя страница конкурса превращает уборку из сухой темы в живой
              семейный повод: дети, пятна, творчество, призы и участие.
            </p>
          </article>
          <article class="retail-card">
            <span>Где купить</span>
            <h3>Официальный магазин + 16 retail-точек</h3>
            <p>
              Финальный блок закрывает путь пользователя: от пользы и советов к месту
              покупки, а не просто к красивой промо-странице.
            </p>
          </article>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Eine Eco-Marke mit verständlicher Produkttiefe</h2>
            <p>
              Das Special verbindet einen umfangreichen Katalog mit lebensnaher Beratung.
              Produktnavigation, Tipps für Kinder und Haustiere, Fotowettbewerb und Händler-
              übersicht führen von der Markenidee bis zur konkreten Kaufentscheidung.
            </p>
            <a class="button light" data-owner-only hidden href="https://www.edimdoma.ru/2018/synergetic" target="_blank" rel="noreferrer">
              Originalprojekt oeffnen
            </a>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />

  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f7f7f5;
    --paper: #fff;
    --ink: #080808;
    --muted: #5f5f5f;
    --line: #dededb;
    --accent: #61a732;
    --radius: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img, video { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(247, 247, 245, .9);
    border-bottom: 1px solid rgba(222, 222, 219, .75);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(8, 8, 8, 0.18) !important;
    color: rgba(8, 8, 8, 0.46) !important;
  }

  .edit-page:hover,
  .edit-page:focus-visible {
    border-color: var(--ink) !important;
    color: var(--ink) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 70px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 100px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(32px, 4.5vw, 68px); line-height: 1.02; max-width: 900px; }
  .intro { hyphens: auto; overflow-wrap: anywhere; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media { background: var(--accent); border-radius: var(--radius); overflow: hidden; }
  .hero-media img { aspect-ratio: 16 / 9; object-fit: cover; width: 100%; }
  .hero-media span { color: #fff; display: block; font-size: 12px; font-weight: 800; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .reel-section {
    background:
      radial-gradient(circle at 14% 18%, rgba(97, 167, 50, .25), transparent 28%),
      radial-gradient(circle at 84% 70%, rgba(226, 0, 122, .16), transparent 30%),
      linear-gradient(135deg, #f8fbf5, #eef8e8 52%, #fff);
  }
  .reel-frame {
    background: #fff;
    border: 1px solid rgba(97, 167, 50, .18);
    border-radius: var(--radius);
    box-shadow: 0 28px 84px rgba(38, 104, 20, .13);
    margin-top: 48px;
    overflow: hidden;
  }
  .reel-frame video {
    aspect-ratio: 16 / 9;
    background: #000;
    display: block;
    width: 100%;
  }
  .reel-frame span {
    color: var(--accent);
    display: block;
    font-size: 12px;
    font-weight: 950;
    letter-spacing: .08em;
    padding: 16px 18px;
    text-transform: uppercase;
  }

  .story-section, .highlights, .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 850px; }
  .quote {
    background: var(--accent);
    border-radius: var(--radius);
    color: #fff;
    font-size: clamp(26px, 4vw, 52px);
    font-weight: 800;
    grid-column: 2;
    line-height: 1.12;
    margin-top: 28px;
    padding: clamp(28px, 5vw, 70px);
  }

  .product-system {
    background:
      radial-gradient(circle at 12% 0%, rgba(151, 215, 60, .22), transparent 32%),
      linear-gradient(135deg, #f8fbf5, #eef8e8 46%, #fff);
  }

  .product-stage {
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(260px, .78fr) 1.5fr;
    margin-top: 48px;
  }

  .product-copy,
  .product-cards article,
  .campaign-card,
  .contest-card,
  .retail-card {
    background: rgba(255, 255, 255, .86);
    border: 1px solid rgba(97, 167, 50, .18);
    border-radius: var(--radius);
    box-shadow: 0 24px 70px rgba(38, 104, 20, .11);
  }

  .product-copy {
    align-content: end;
    display: grid;
    min-height: 430px;
    padding: clamp(28px, 4vw, 54px);
  }

  .product-copy img {
    margin-bottom: auto;
    max-width: 180px;
  }

  .product-copy h3 {
    color: var(--accent);
    font-size: clamp(30px, 4vw, 54px);
    line-height: .96;
    margin-top: 60px;
  }

  .product-copy p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }

  .product-cards {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .product-cards article {
    display: grid;
    min-height: 430px;
    overflow: hidden;
    padding: 22px;
  }

  .product-cards img {
    align-self: center;
    filter: drop-shadow(0 24px 34px rgba(57, 97, 35, .18));
    height: 230px;
    justify-self: center;
    object-fit: contain;
    width: 100%;
  }

  .product-cards h3 {
    font-size: 19px;
    line-height: 1.1;
    margin-top: 20px;
  }

  .product-cards p {
    color: var(--muted);
    font-size: 13px;
    line-height: 1.55;
    margin-top: 12px;
  }

  .highlight-grid { display: grid; gap: 18px; grid-column: 2; grid-template-columns: repeat(3, 1fr); margin-top: 24px; }
  .highlight-grid article { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); min-height: 260px; padding: 26px; }
  .highlight-grid span { color: var(--muted); font-size: 12px; font-weight: 900; }
  .highlight-grid h3 { font-size: 20px; line-height: 1.2; margin-top: 54px; }
  .highlight-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .gallery { display: grid; gap: 18px; grid-template-columns: repeat(6, 1fr); }
  .gallery figure { background: var(--paper); border-radius: var(--radius); overflow: hidden; }
  .gallery .large { grid-column: 1 / -1; }
  .gallery img { aspect-ratio: 16 / 10; object-fit: cover; width: 100%; }
  .gallery .large img { aspect-ratio: 16 / 8; }
  figcaption { color: var(--muted); font-size: 12px; font-weight: 800; padding: 16px; text-transform: uppercase; }

  .campaign-card {
    grid-column: span 2;
    min-height: 310px;
    overflow: hidden;
    padding: 24px;
  }

  .campaign-card img {
    aspect-ratio: 1 / .7;
    height: 150px;
    margin: 0 auto 26px;
    object-fit: contain;
    width: 100%;
  }

  .campaign-card p,
  .contest-card span,
  .retail-card span {
    color: var(--accent);
    font-size: 12px;
    font-weight: 950;
    letter-spacing: .08em;
    text-transform: uppercase;
  }

  .campaign-card h3,
  .contest-card h3,
  .retail-card h3 {
    font-size: clamp(22px, 2.5vw, 34px);
    line-height: 1.05;
    margin-top: 18px;
  }

  .contest-card,
  .retail-card {
    align-content: end;
    display: grid;
    grid-column: span 3;
    min-height: 320px;
    padding: clamp(24px, 4vw, 44px);
  }

  .contest-card {
    background:
      radial-gradient(circle at 82% 8%, rgba(255, 219, 67, .8), transparent 22%),
      linear-gradient(135deg, #ffffff, #f8e7f0);
  }

  .retail-card {
    background:
      radial-gradient(circle at 12% 12%, rgba(97, 167, 50, .2), transparent 28%),
      linear-gradient(135deg, #fff, #eef8e8);
  }

  .contest-card p,
  .retail-card p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.6;
    margin-top: 18px;
  }

  .result { background: var(--accent); color: #fff; }
  .result .eyebrow, .result-copy > p { color: #c6d1ce; }
  .result-copy { max-width: 900px; }
  .result .button { border-color: #fff; margin-top: 34px; }

  @media (max-width: 1100px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
    .product-stage { grid-template-columns: 1fr; }
    .product-cards { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    .header-actions { gap: 5px; }
    .case-sidebar { padding: 36px 18px; }
