---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/hochland-2018`;

const facts = [
  ["Kunde", "Hochland"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2018"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Hero als Festtafel", "Der neue Hero zeigt Hochland nicht als Packshot, sondern als Zutat im Zentrum eines Oster-Menues."],
  ["Suess und herzhaft", "Kuchen, Tartlets und Brote bekommen eigene Bilder, damit die Vielseitigkeit sofort sichtbar wird."],
  ["Rezeptlogik", "Die Rezeptuebersicht macht aus zehn Einzelideen ein kuratiertes Menue fuer die Festtafel."],
];

const recipeCards = [
  ["recipe-sweet.jpg", "Suesse Anwendung", "Osterkuchen mit Frischkaese-Glasur", "Der suesse Teil der Kampagne: Hochland wird zur cremigen Basis fuer Glasur, Fuellung und festliche Gebaeckideen."],
  ["recipe-savory.jpg", "Herzhafte Anwendung", "Tartlets und Brote fuer den Ostertisch", "Die herzhafte Seite zeigt den Nutzen im Alltag: schnell streichbar, kombinierbar mit Kraeutern, Lachs und Gemuese."],
  ["product-focus.jpg", "Produkt im Zentrum", "Frischkaese als verbindende Zutat", "Die dritte Karte zeigt nicht noch einmal die Rezeptuebersicht, sondern das Produkt selbst: cremig, streichbar und direkt im Einsatz."],
];

const processSteps = [
  ["01", "Produkt", "Frischkaese bleibt als verbindende Zutat sichtbar."],
  ["02", "Rezepte", "Suesse und herzhafte Motive zeigen die Bandbreite."],
  ["03", "Saison", "Eier, Tulpen und Blau-Gelb codieren Ostern sofort."],
  ["04", "Planung", "Die Rezeptuebersicht macht daraus ein komplettes Menue."],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Hochland Easter Campaign 2018 - Case Study von Andrii Prokhorovych." />
    <title>Hochland Easter Campaign 2018 - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=hochland-2018`}>Редактировать</a>
        <a class="button dark small" href="https://www.edimdoma.ru/2018/hochland" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2018</p>
          <img class="client-logo" src={`${media}/logo.svg`} alt="Hochland" />
          <h1>Festliche Osterrezepte mit Frischkäse</h1>
          <p class="intro">
            Eine kompakte saisonale Kampagne, die Hochland Frischkaese fuer die Kueche
            mit zehn suessen und herzhaften Osterrezepten sowie Serviertipps verbindet.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#konzept">02 Konzept</a>
          <a href="#highlights">03 Highlights</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="floating-easter" aria-hidden="true">
            <span class="easter-orb egg-one"></span>
            <span class="easter-orb egg-two"></span>
            <span class="easter-orb egg-three"></span>
          </div>
          <div class="hero-copy">
            <p class="eyebrow">Food & Beverage · Seasonal Campaign</p>
            <h2>Ein vielseitiger Frischkäse für die ganze Festtafel</h2>
            <p>
              Hochland „Fuer die Kueche“ wird als einfacher Weg zu einem professionellen
              Ergebnis positioniert. Osterkuchen, Gebaeck, Tartlets und herzhafte Snacks
              zeigen das Produkt in sehr unterschiedlichen kulinarischen Rollen.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero-concept.jpg`} alt="Hochland Osterkampagne mit Frischkaese, Osterkuchen, Eiern und Tulpen" />
            <span>Hero · neu inszenierte Oster-Festtafel</span>
          </div>
        </section>

        <section id="konzept" class="story-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Konzept</p>
            <h2>Frühlingsfarben und Food-Styling mit Produktfokus</h2>
            <p>
              Der Hero kombiniert Osterkuchen, farbige Eier und gelbe Tulpen mit der
              Frischkaeseverpackung. Hochland-Blau sorgt fuer Markenpraesenz, waehrend
              Pastellfarben und textile Details eine warme, handgemachte Festwelt schaffen.
            </p>
          </div>
          <div class="quote">
            <p>„Ein starkes Saisonformat zeigt ein Produkt in vielen Rezepten, ohne seine Rolle aus dem Blick zu verlieren.“</p>
          </div>
        </section>

        <section class="recipe-system" aria-labelledby="recipe-title">
          <div class="section-copy">
            <p class="eyebrow">Rezeptwelten</p>
            <h2 id="recipe-title">Drei Bilder zeigen, warum das Produkt gebraucht wird</h2>
            <p>
              Statt den Startscreen zu wiederholen, trennt der Case die wichtigsten
              Anwendungen: suess, herzhaft und als Rezeptuebersicht. So wird der Nutzen des
              Frischkaeses schneller begreifbar.
            </p>
          </div>
          <div class="recipe-grid">
            {recipeCards.map(([image, label, title, text]) => (
              <article class="recipe-card">
                <div class="recipe-image">
                  <img src={`${media}/${image}`} alt={title} loading="lazy" />
                </div>
                <div class="recipe-copy">
                  <span>{label}</span>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="overview-stage" aria-labelledby="overview-title">
          <div class="section-copy">
            <p class="eyebrow">Originalscreen + neue Ordnung</p>
            <h2 id="overview-title">Aus der Startseite wird ein Menue-System</h2>
            <p>
              Der originale Screen bleibt als Referenz erhalten, aber nicht als endlose
              Wiederholung. Daneben steht die neue Rezeptbuehne, die das Special als
              planbare Osterstrecke zeigt.
            </p>
          </div>
          <div class="overview-pair">
            <figure>
              <img src={`${media}/hero.jpg`} alt="Originaler Hochland Kampagnenstartscreen" loading="lazy" />
              <figcaption>Originalscreen · Kampagnenstart</figcaption>
            </figure>
            <figure>
              <img src={`${media}/recipes-overview.jpg`} alt="Rezeptuebersicht der Hochland Osterkampagne" loading="lazy" />
              <figcaption>Neue Buehne · Rezeptauswahl und Menueplanung</figcaption>
            </figure>
          </div>
        </section>

        <section id="highlights" class="highlights">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was den Auftritt besonders macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="process-section" aria-label="Kampagnenlogik">
          <div class="section-copy">
            <p class="eyebrow">Dramaturgie</p>
            <h2>Wie der Case die Kampagne lesbar macht</h2>
          </div>
          <div class="process-grid">
            {processSteps.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Eine klare saisonale Bühne für Produktvielfalt</h2>
            <p>
              Das Special fuehrt direkt vom Nutzenversprechen zu konkreten Anwendungen.
              Zehn Rezepte und zwei redaktionelle Artikel geben genug Inspiration fuer ein
              komplettes Oster-Menue und halten Hochland als verbindende Zutat sichtbar.
            </p>
            <a class="button light" data-owner-only hidden href="https://www.edimdoma.ru/2018/hochland" target="_blank" rel="noreferrer">
              Originalprojekt oeffnen
            </a>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />

  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f6f8f2;
    --paper: #fff;
    --ink: #080808;
    --muted: #5f655e;
    --line: #dce4d6;
    --accent: #075da7;
    --accent-dark: #003b7a;
    --yellow: #ffd642;
    --sky: #d7eef5;
    --radius: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img, video { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(246, 248, 242, .9);
    border-bottom: 1px solid rgba(220, 228, 214, .78);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(8, 8, 8, 0.18) !important;
    color: rgba(8, 8, 8, 0.46) !important;
  }

  .edit-page:hover,
  .edit-page:focus-visible {
    border-color: var(--ink) !important;
    color: var(--ink) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 70px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 100px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(32px, 4.5vw, 68px); line-height: 1.02; max-width: 900px; }
  .intro { hyphens: auto; overflow-wrap: anywhere; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); position: relative; }
  .floating-easter {
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    position: absolute;
    z-index: 0;
  }
  .easter-orb {
    border-radius: 999px;
    box-shadow: 0 24px 60px rgba(7, 93, 167, .14);
    display: block;
    opacity: .78;
    position: absolute;
  }
  .egg-one {
    background:
      radial-gradient(circle at 35% 28%, rgba(255, 255, 255, .8), transparent 28%),
      linear-gradient(135deg, #ffe86f, #f0c520);
    height: 92px;
    left: 7%;
    top: 48%;
    width: 72px;
  }
  .egg-two {
    background:
      radial-gradient(circle at 35% 28%, rgba(255, 255, 255, .8), transparent 28%),
      linear-gradient(135deg, #d7eef5, #7fc1d8);
    height: 118px;
    right: -24px;
    top: 12%;
    width: 92px;
  }
  .egg-three {
    background:
      radial-gradient(circle at 35% 28%, rgba(255, 255, 255, .8), transparent 28%),
      linear-gradient(135deg, #fff, #d8c7a4);
    bottom: 9%;
    height: 78px;
    right: 18%;
    width: 62px;
  }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy, .hero-media { position: relative; z-index: 1; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media {
    background: linear-gradient(135deg, var(--sky), #fff3b8);
    border-radius: 24px;
    box-shadow: 0 28px 80px rgba(7, 93, 167, .14);
    overflow: hidden;
  }
  .hero-media img { aspect-ratio: 16 / 9; object-fit: cover; width: 100%; }
  .hero-media span { color: var(--accent-dark); display: block; font-size: 12px; font-weight: 900; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .story-section, .highlights, .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 850px; }
  .quote {
    background:
      radial-gradient(circle at 86% 18%, rgba(255, 214, 66, .38), transparent 24%),
      linear-gradient(135deg, var(--accent-dark), var(--accent));
    border-radius: var(--radius);
    color: #fff;
    font-size: clamp(26px, 4vw, 52px);
    font-weight: 800;
    grid-column: 2;
    line-height: 1.12;
    margin-top: 28px;
    padding: clamp(28px, 5vw, 70px);
  }

  .recipe-system {
    background:
      radial-gradient(circle at 15% 12%, rgba(255, 214, 66, .24), transparent 22%),
      linear-gradient(135deg, #fff, #f3f8ee);
  }
  .recipe-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 48px;
  }
  .recipe-card {
    background: var(--paper);
    border: 1px solid rgba(7, 93, 167, .12);
    border-radius: 22px;
    box-shadow: 0 22px 70px rgba(7, 93, 167, .08);
    overflow: hidden;
    transition: box-shadow .35s ease, transform .35s ease;
  }
  .recipe-card:hover {
    box-shadow: 0 28px 80px rgba(7, 93, 167, .16);
    transform: translateY(-8px);
  }
  .recipe-image {
    aspect-ratio: 4 / 3;
    background: var(--sky);
    overflow: hidden;
  }
  .recipe-image img {
    height: 100%;
    object-fit: cover;
    transition: transform .45s ease;
    width: 100%;
  }
  .recipe-card:hover .recipe-image img { transform: scale(1.06); }
  .recipe-copy { padding: 26px; }
  .recipe-copy span {
    color: var(--accent);
    display: block;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .recipe-copy h3 { font-size: 24px; line-height: 1.08; }
  .recipe-copy p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .overview-stage {
    background:
      linear-gradient(90deg, rgba(7, 93, 167, .06) 1px, transparent 1px),
      linear-gradient(180deg, #f6f8f2, #e9f5f7);
    background-size: 42px 42px, auto;
  }
  .overview-pair {
    display: grid;
    gap: 20px;
    grid-template-columns: .9fr 1.1fr;
    margin-top: 48px;
  }
  .overview-pair figure {
    background: var(--paper);
    border-radius: 24px;
    box-shadow: 0 24px 70px rgba(7, 93, 167, .1);
    overflow: hidden;
  }
  .overview-pair img { aspect-ratio: 16 / 10; object-fit: cover; width: 100%; }

  .highlight-grid { display: grid; gap: 18px; grid-column: 2; grid-template-columns: repeat(3, 1fr); margin-top: 24px; }
  .highlight-grid article { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); min-height: 260px; padding: 26px; }
  .highlight-grid span { color: var(--muted); font-size: 12px; font-weight: 900; }
  .highlight-grid h3 { font-size: 20px; line-height: 1.2; margin-top: 54px; }
  .highlight-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  figcaption { color: var(--muted); font-size: 12px; font-weight: 800; padding: 16px; text-transform: uppercase; }

  .process-section {
    background: var(--paper);
  }
  .process-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 46px;
  }
  .process-grid article {
    background: #f6f8f2;
    border: 1px solid var(--line);
    border-radius: 18px;
    min-height: 240px;
    padding: 24px;
  }
  .process-grid span { color: var(--accent); font-size: 13px; font-weight: 900; }
  .process-grid h3 { font-size: 22px; margin-top: 52px; }
  .process-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .result {
    background:
      radial-gradient(circle at 16% 18%, rgba(255, 214, 66, .26), transparent 24%),
      linear-gradient(135deg, var(--accent-dark), var(--accent));
    color: #fff;
  }
  .result .eyebrow, .result-copy > p { color: rgba(255, 255, 255, .72); }
  .result-copy { max-width: 900px; }
  .result .button { border-color: #fff; margin-top: 34px; }

  @media (max-width: 1100px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
    .overview-pair { grid-template-columns: 1fr; }
    .process-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    .header-actions { gap: 5px; }
    .case-sidebar { padding: 36px 18px; }
    .case-content > section { padding-left: 18px; padding-right: 18px; }
    .hero-copy, .story-section, .highlights, .result { grid-template-columns: 1fr; }
    .hero-copy .eyebrow, .quote, .highlight-grid { grid-column: 1; }
    .recipe-grid, .highlight-grid, .process-grid { grid-template-columns: 1fr; }
    .section-number { display: none; }
  }
</style>
