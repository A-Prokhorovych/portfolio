---
const base = import.meta.env.BASE_URL;
---

<html lang="ru">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width" />
  <meta name="robots" content="noindex" />
  <title>Редактор проектов · PROKHA</title>
</head>
<body>
  <script define:vars={{ base }}>
    if (localStorage.getItem("prokha-owner-mode") !== "1") location.replace(base);
  </script>
  <header class="toolbar">
    <a href={base}>PROKHA</a>
    <div>
      <a class="toolbar-link" data-project-view hidden>Открыть страницу</a>
      <button data-import>Импорт JSON</button>
      <button data-reset>Новый проект</button>
      <button data-html>Скачать HTML</button>
      <button class="primary" data-export>Скачать JSON</button>
    </div>
    <input data-import-file hidden type="file" accept=".json,application/json" />
  </header>
  <p class="notice">Нажмите <b>Редактировать</b> возле нужного блока. Черновик сохраняется автоматически.</p>
  <main data-preview></main>

  <dialog data-dialog>
    <form data-form>
      <header>
        <div><small>Редактирование</small><h2 data-dialog-title></h2></div>
        <button class="close" type="button" data-close>×</button>
      </header>
      <label data-text-wrap>Текст<textarea data-text rows="7"></textarea></label>
      <div data-media-wrap hidden>
        <label>Ссылка на изображение или видео<input data-url type="url" placeholder="https://..." /></label>
        <p class="or">или</p>
        <label class="drop">Выбрать файл<input data-file type="file" accept="image/*,video/*" /></label>
        <small>Для видео лучше использовать ссылку, иначе JSON может стать слишком большим.</small>
      </div>
      <footer><button type="button" data-close>Отмена</button><button class="primary">Сохранить</button></footer>
    </form>
  </dialog>

  <dialog data-add-dialog>
    <div class="add-dialog">
      <header><div><small>Новый блок</small><h2>Что добавить?</h2></div><button class="close" type="button" data-add-close>×</button></header>
      <div class="block-types">
        <button data-add-type="text"><b>Текст</b><span>Заголовок и абзац</span></button>
        <button data-add-type="image"><b>Изображение</b><span>Фото или скриншот</span></button>
        <button data-add-type="gif"><b>GIF</b><span>Анимированное изображение</span></button>
        <button data-add-type="video"><b>Видео</b><span>Файл или ссылка</span></button>
      </div>
    </div>
  </dialog>

  <script define:vars={{ base }}>
    const projectSlug = new URLSearchParams(location.search).get("project") || "new-project";
    const key = `prokha-editor-v2-${projectSlug}`;
    const defaults = {
      slug:"new-project", year:"2026", client:"Название клиента", platform:"Платформа", role:"Web & Campaign Design",
      logo:`${base}projects/djadja-vanja/logo.svg`, sidebarTitle:"Заголовок проекта",
      sidebarText:"Короткое описание проекта: задача, идея и главная особенность.",
      category:"Категория · Тип проекта", heroTitle:"Главная идея проекта",
      heroText:"Расскажите, для кого создавался проект и какую задачу он решает.",
      heroImage:`${base}projects/djadja-vanja/hero.jpg`, conceptTitle:"Концепция и визуальный подход",
      conceptText:"Опишите выбранное решение, структуру страницы и визуальную идею.",
      quote:"Короткая яркая мысль о проекте.", videoTitle:"Проект в движении",
      video:"https://www.edimdoma.ru/ads//backgrounds/video/uncle_vanya/uncle_vanya_720.mp4",
      h1t:"Первое преимущество", h1p:"Что особенно хорошо получилось в этом проекте.",
      h2t:"Второе преимущество", h2p:"Как решение помогло пользователю или бренду.",
      h3t:"Третье преимущество", h3p:"Интересная деталь дизайна или реализации.",
      gallery1:`${base}projects/djadja-vanja/recipe-01.jpg`, gallery2:`${base}projects/djadja-vanja/recipe-02.jpg`,
      gallery3:`${base}projects/djadja-vanja/recipe-03.jpg`, resultTitle:"Результат проекта",
      resultText:"Подведите итог: что было создано и почему проект получился сильным.", customBlocks:[]
    };
    let state = {...defaults}, preset = {...defaults}, active = "", type = "text", insertAt = 0;
    const q = (s) => document.querySelector(s), preview = q("[data-preview]"), dialog = q("[data-dialog]"), addDialog = q("[data-add-dialog]");
    const esc = (v) => String(v || "").replaceAll("&","&amp;").replaceAll("<","&lt;").replaceAll(">","&gt;").replaceAll('"',"&quot;");
    async function load(){
      let project = {};
      if(projectSlug !== "new-project"){
        try{project=await fetch(`${base}projects/${projectSlug}/project.json`).then(response=>response.ok?response.json():{})}catch{}
      }
      preset={...defaults,...project,slug:projectSlug};
      try{const value={...preset,...JSON.parse(localStorage.getItem(key)||"{}")};value.customBlocks=Array.isArray(value.customBlocks)?value.customBlocks:[];return value}catch{return {...preset,customBlocks:[]}}
    }
    function save(){ try{localStorage.setItem(key,JSON.stringify(state))}catch{alert("Файл слишком большой для автосохранения. Скачайте JSON.")} }
    const edit = (k,l,t="text") => `<button class="edit" data-edit="${k}" data-label="${l}" data-type="${t}">Редактировать</button>`;
    const text = (k,l,tag="p",cls="") => `<div class="editable">${edit(k,l)}<${tag} class="${cls}">${esc(state[k])}</${tag}></div>`;
    const media = (k,l,cls="") => `<div class="media ${cls}"><img src="${esc(state[k])}" alt="">${edit(k,l,"media")}</div>`;
    const fact = (k,l) => `<div class="editable">${edit(k,l)}<dt>${l}</dt><dd>${esc(state[k])}</dd></div>`;
    const highlight = (n) => `<article><span>0${n}</span>${text(`h${n}t`,`Заголовок преимущества ${n}`,"h3")}${text(`h${n}p`,`Описание преимущества ${n}`)}</article>`;
    const plus = (index) => `<button class="add-block" data-add="${index}" aria-label="Добавить блок"><span>+</span><b>Добавить блок</b></button>`;
    function customBlock(block,index){
      const controls=`<div class="block-controls"><button data-move="${index}" data-direction="-1" title="Вверх">↑</button><button data-move="${index}" data-direction="1" title="Вниз">↓</button><button data-custom-edit="${index}">Редактировать</button><button data-delete="${index}">Удалить</button></div>`;
      if(block.type==="text")return `${plus(index)}<section class="custom-block custom-text">${controls}<h2>${esc(block.title||"Заголовок")}</h2><p>${esc(block.content||"Текст блока")}</p></section>`;
      if(block.type==="video")return `${plus(index)}<section class="custom-block custom-media">${controls}<video controls muted loop src="${esc(block.content)}"></video></section>`;
      return `${plus(index)}<section class="custom-block custom-media">${controls}<img src="${esc(block.content)}" alt=""></section>`;
    }
    const customBlocks = () => state.customBlocks.map(customBlock).join("")+plus(state.customBlocks.length);
    function render(){
      preview.innerHTML = `<aside>
        <div><p class="eyebrow">Case Study · ${esc(state.year)}</p>${media("logo","Логотип","logo")}
        ${text("sidebarTitle","Заголовок в сайдбаре","h1")}${text("sidebarText","Описание в сайдбаре","p","intro")}</div>
        <dl>${fact("client","Клиент")}${fact("platform","Платформа")}${fact("year","Год")}${fact("role","Роль")}</dl>
      </aside><article class="content">
        <section class="hero"><div class="hero-copy">${text("category","Категория","p","eyebrow")}${text("heroTitle","Главный заголовок","h2")}${text("heroText","Главное описание")}</div>${media("heroImage","Главное изображение","hero-image")}</section>
        <section class="two"><b>02</b><div><p class="eyebrow">Концепция</p>${text("conceptTitle","Заголовок концепции","h2")}${text("conceptText","Описание концепции","p","body-text")}</div><div class="quote">${text("quote","Цитата")}</div></section>
        <section class="video"><div>${text("videoTitle","Заголовок видео","h2")}</div><div class="media video-frame"><video controls muted loop src="${esc(state.video)}"></video>${edit("video","Видео","media")}</div></section>
        <section class="two"><b>03</b><div><p class="eyebrow">Основные моменты</p><h2>Что делает проект особенным</h2></div><div class="highlights">${highlight(1)}${highlight(2)}${highlight(3)}</div></section>
        <section class="gallery">${media("gallery1","Большой скриншот","large")}${media("gallery2","Второй скриншот")}${media("gallery3","Третий скриншот")}</section>
        <div class="custom-area">${customBlocks()}</div>
        <section class="two result"><b>04</b><div><p class="eyebrow">Результат</p>${text("resultTitle","Заголовок результата","h2")}${text("resultText","Описание результата","p","body-text")}</div></section>
      </article>`;
    }
    function openEditor(label,value,editorType){type=editorType;q("[data-dialog-title]").textContent=label;q("[data-text-wrap]").hidden=type==="media";q("[data-media-wrap]").hidden=type!=="media";q("[data-text]").value=type==="text"?value:"";q("[data-url]").value=type==="media"&&!String(value).startsWith("data:")?value:"";q("[data-file]").value="";dialog.showModal()}
    preview.addEventListener("click",(e)=>{
      const add=e.target.closest("[data-add]");if(add){insertAt=Number(add.dataset.add);addDialog.showModal();return}
      const move=e.target.closest("[data-move]");if(move){const from=Number(move.dataset.move),to=from+Number(move.dataset.direction);if(to>=0&&to<state.customBlocks.length){const [item]=state.customBlocks.splice(from,1);state.customBlocks.splice(to,0,item);save();render()}return}
      const del=e.target.closest("[data-delete]");if(del){if(confirm("Удалить этот блок?")){state.customBlocks.splice(Number(del.dataset.delete),1);save();render()}return}
      const custom=e.target.closest("[data-custom-edit]");if(custom){active=`custom:${custom.dataset.customEdit}`;const block=state.customBlocks[Number(custom.dataset.customEdit)];openEditor("Пользовательский блок",block.type==="text"?`${block.title}\n\n${block.content}`:block.content,block.type==="text"?"text":"media");return}
      const b=e.target.closest("[data-edit]");if(!b)return;active=b.dataset.edit;openEditor(b.dataset.label,state[active],b.dataset.type)
    });
    document.querySelectorAll("[data-close]").forEach(b=>b.addEventListener("click",()=>dialog.close()));
    q("[data-form]").addEventListener("submit",async(e)=>{e.preventDefault();let value=type==="text"?q("[data-text]").value.trim():q("[data-file]").files[0]?await read(q("[data-file]").files[0]):q("[data-url]").value.trim();if(active.startsWith("custom:")){const block=state.customBlocks[Number(active.split(":")[1])];if(block.type==="text"){const parts=value.split(/\n\s*\n/);block.title=parts.shift()||"Заголовок";block.content=parts.join("\n\n")||"Текст блока"}else block.content=value}else state[active]=value;save();render();dialog.close()});
    const read = (file) => new Promise((ok,no)=>{const r=new FileReader();r.onload=()=>ok(r.result);r.onerror=no;r.readAsDataURL(file)});
    q("[data-export]").addEventListener("click",()=>{const s=prompt("Адрес проекта латиницей:",state.slug)||state.slug;state.slug=s.toLowerCase().replace(/[^a-z0-9]+/g,"-").replace(/^-|-$/g,"")||"project";save();const a=document.createElement("a");a.href=URL.createObjectURL(new Blob([JSON.stringify(state,null,2)],{type:"application/json"}));a.download=`${state.slug}.json`;a.click();URL.revokeObjectURL(a.href)});
    q("[data-html]").addEventListener("click",async()=>{const copy=document.documentElement.cloneNode(true);copy.querySelector(".toolbar")?.remove();copy.querySelector(".notice")?.remove();copy.querySelectorAll("dialog")?.forEach(el=>el.remove());copy.querySelectorAll("script,.edit,.add-block,.block-controls,link[rel=stylesheet]").forEach(el=>el.remove());copy.querySelector("title").textContent=state.sidebarTitle;copy.querySelector("body").className="published-case";const css=(await Promise.all([...document.styleSheets].map(s=>s.href?fetch(s.href).then(r=>r.text()):""))).join("\n");const style=document.createElement("style");style.textContent=css+".published-case main{display:grid}.published-case .editable:hover,.published-case .media:hover{outline:0}";copy.querySelector("head").append(style);const a=document.createElement("a");a.href=URL.createObjectURL(new Blob(["<!DOCTYPE html>"+copy.outerHTML],{type:"text/html"}));a.download="index.html";a.click();URL.revokeObjectURL(a.href)});
    q("[data-import]").addEventListener("click",()=>q("[data-import-file]").click());
    q("[data-import-file]").addEventListener("change",async(e)=>{if(!e.target.files[0])return;state={...defaults,...JSON.parse(await e.target.files[0].text())};state.customBlocks=Array.isArray(state.customBlocks)?state.customBlocks:[];save();render()});
    q("[data-reset]").addEventListener("click",()=>{if(confirm("Удалить ваши изменения и вернуть опубликованную версию проекта?")){state={...preset,customBlocks:Array.isArray(preset.customBlocks)?structuredClone(preset.customBlocks):[]};save();render()}});
    q("[data-add-close]").addEventListener("click",()=>addDialog.close());
    document.querySelectorAll("[data-add-type]").forEach(button=>button.addEventListener("click",()=>{const blockType=button.dataset.addType;state.customBlocks.splice(insertAt,0,{id:Date.now(),type:blockType,title:blockType==="text"?"Новый текстовый блок":"",content:blockType==="text"?"Введите текст блока":""});save();render();addDialog.close();const newIndex=insertAt;active=`custom:${newIndex}`;openEditor("Новый блок",blockType==="text"?"Новый текстовый блок\n\nВведите текст блока":"",blockType==="text"?"text":"media")}));
    load().then(value=>{
      state=value;
      const view=q("[data-project-view]");
      if(projectSlug!=="new-project"){view.hidden=false;view.href=`${base}projects/${projectSlug}/`}
      render();
    });
  </script>
</body>
</html>

<style>
  :root{--bg:#f7f7f5;--paper:#fff;--ink:#080808;--muted:#5f5f5f;--line:#dededb;--accent:#173e36;--yellow:#ffdd57;--radius:8px;font-family:Inter,system-ui,sans-serif}*{box-sizing:border-box}body{margin:0;background:var(--bg);color:var(--ink)}button,input,textarea{font:inherit}p,h1,h2,h3,dl,dd{margin:0}img,video{display:block;max-width:100%}
  .toolbar{align-items:center;background:#111;color:#fff;display:flex;gap:18px;justify-content:space-between;padding:14px clamp(18px,4vw,64px);position:sticky;top:0;z-index:30}.toolbar>a{color:#fff;font-size:24px;font-weight:900;text-decoration:none}.toolbar div{display:flex;gap:8px}.toolbar button,dialog button,.toolbar-link{background:#fff;border:1px solid #777;border-radius:7px;color:#111;cursor:pointer;font-size:13px;font-weight:800;min-height:40px;padding:0 15px}.toolbar-link{align-items:center;display:inline-flex;text-decoration:none}.primary{background:var(--yellow)!important;border-color:var(--yellow)!important}.notice{background:var(--yellow);font-size:13px;padding:10px;text-align:center}
  main{display:grid;grid-template-columns:minmax(280px,25vw) minmax(0,1fr)}aside{align-content:space-between;background:var(--paper);border-right:1px solid var(--line);display:grid;gap:44px;height:calc(100vh - 111px);padding:clamp(36px,4vw,64px) clamp(24px,3vw,48px);position:sticky;top:111px}.eyebrow{color:var(--muted);font-size:12px;font-weight:900;letter-spacing:.08em;margin-bottom:16px;text-transform:uppercase}h1{font-size:clamp(25px,2.25vw,38px);hyphens:auto;line-height:1.08;overflow-wrap:anywhere}h2{font-size:clamp(32px,4.5vw,68px);line-height:1.02}.intro{hyphens:auto;overflow-wrap:anywhere}.intro,.body-text{color:var(--muted);font-size:16px;line-height:1.7;margin-top:22px}dl{border-top:1px solid var(--line)}dl>div{border-bottom:1px solid var(--line);display:flex;justify-content:space-between;padding:11px 0}dt{color:var(--muted);font-size:12px;font-weight:800;text-transform:uppercase}dd{font-size:13px;font-weight:800;text-align:right}
  .content>section{border-bottom:1px solid var(--line);padding:clamp(56px,7vw,110px) clamp(24px,6vw,100px)}.hero-copy{display:grid;gap:28px;grid-template-columns:1fr minmax(260px,420px);margin-bottom:58px}.hero-copy>:first-child{grid-column:1/-1}.hero-copy p:last-child{align-self:end;color:var(--muted);font-size:17px;line-height:1.7}.media{border-radius:var(--radius);overflow:hidden;position:relative}.hero-image img{aspect-ratio:16/9;object-fit:cover;width:100%}.logo{height:90px;margin-bottom:30px;overflow:visible;width:120px}.logo img{height:100%;object-fit:contain;object-position:left;width:100%}.two{display:grid;gap:36px;grid-template-columns:70px minmax(0,1fr)}.two>b{color:var(--muted);font-size:13px}.quote{background:var(--accent);border-radius:var(--radius);color:#fff;font-size:clamp(26px,4vw,52px);font-weight:800;grid-column:2;line-height:1.12;padding:clamp(28px,5vw,70px)}.video{background:#111;color:#fff}.video-frame{border:1px solid #333;margin-top:48px}.video-frame video{aspect-ratio:16/9;background:#000;object-fit:cover;width:100%}
  .highlights{display:grid;gap:18px;grid-column:2;grid-template-columns:repeat(3,1fr)}.highlights article{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);min-height:270px;padding:26px}.highlights span{color:var(--muted);font-size:12px;font-weight:900}.highlights h3{font-size:20px;margin-top:52px}.highlights p{color:var(--muted);font-size:14px;line-height:1.6;margin-top:14px}.gallery{display:grid;gap:18px;grid-template-columns:1fr 1fr}.gallery .large{grid-column:1/-1}.gallery img{aspect-ratio:16/10;object-fit:cover;width:100%}.gallery .large img{aspect-ratio:16/8}.result{background:var(--accent);color:#fff}.result .eyebrow,.result .body-text{color:#c6d1ce}
  .custom-area{background:#ecece8;padding:18px}.add-block{align-items:center;background:transparent;border:2px dashed #aaa;border-radius:var(--radius);color:#555;cursor:pointer;display:flex;gap:12px;justify-content:center;margin:12px 0;min-height:70px;width:100%}.add-block:hover{background:var(--yellow);border-color:#111;color:#111}.add-block span{font-size:30px;font-weight:400}.add-block b{font-size:13px}.custom-block{background:var(--paper);border:1px solid var(--line);border-radius:var(--radius);margin:14px 0;padding:clamp(32px,6vw,80px);position:relative}.custom-text p{color:var(--muted);font-size:18px;line-height:1.75;margin-top:24px;max-width:850px;white-space:pre-line}.custom-media{padding:0;overflow:hidden}.custom-media img,.custom-media video{max-height:800px;object-fit:cover;width:100%}.block-controls{display:flex;gap:6px;position:absolute;right:10px;top:10px;z-index:8}.block-controls button{background:#111;border:0;border-radius:6px;color:#fff;cursor:pointer;font-size:11px;font-weight:800;min-height:34px;padding:0 10px}.block-controls button:last-child{background:#a71919}
  .editable,.media{position:relative}.edit{background:var(--yellow);border:0;border-radius:6px;cursor:pointer;font-size:11px;font-weight:900;opacity:0;padding:7px 9px;position:absolute;right:8px;top:8px;transition:.15s;z-index:5}.editable:hover>.edit,.media:hover>.edit,.edit:focus{opacity:1}.editable:hover,.media:hover{outline:2px dashed var(--yellow);outline-offset:5px}
  dialog{border:0;border-radius:12px;max-width:620px;padding:0;width:calc(100% - 32px)}dialog::backdrop{background:#000a}form,.add-dialog{padding:26px}form header,form footer,.add-dialog header{align-items:center;display:flex;gap:16px;justify-content:space-between}form small,.add-dialog small{color:var(--muted);line-height:1.5}.close{background:transparent!important;border:0!important;font-size:30px!important;padding:0!important}label{display:grid;font-size:13px;font-weight:800;gap:8px;margin-top:24px}textarea,input[type=url]{border:1px solid #bbb;border-radius:8px;padding:12px;width:100%}.drop{background:var(--bg);border:2px dashed #bbb;border-radius:10px;padding:28px;text-align:center}.or{color:var(--muted);font-size:12px;margin-top:18px;text-align:center}form footer{border-top:1px solid var(--line);margin-top:26px;padding-top:20px}.block-types{display:grid;gap:12px;grid-template-columns:1fr 1fr;margin-top:26px}.block-types button{background:var(--bg);border:1px solid var(--line);border-radius:var(--radius);cursor:pointer;display:grid;gap:7px;min-height:110px;padding:20px;text-align:left}.block-types button:hover{background:var(--yellow);border-color:#111}.block-types span{color:var(--muted);font-size:12px}
  @media(max-width:1000px){main{grid-template-columns:1fr}aside{height:auto;position:static}.hero-copy,.two{grid-template-columns:1fr}.hero-copy>:first-child,.quote,.highlights{grid-column:1}}@media(max-width:700px){.toolbar{align-items:flex-start;flex-direction:column}.toolbar div{width:100%;flex-wrap:wrap}.toolbar button{flex:1}.content>section,aside{padding-left:18px;padding-right:18px}.highlights,.gallery,.block-types{grid-template-columns:1fr}.gallery .large{grid-column:1}.two>b{display:none}.edit{opacity:1;position:static;margin-bottom:10px}.block-controls{flex-wrap:wrap;position:static;margin-bottom:16px}.custom-block{padding:24px}}
</style>
