---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/ochakovo`;

const facts = [
  ["Kunde", "Ochakovo"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2017"],
  ["Rolle", "Web & Campaign Design"],
];

const scenarios = [
  ["heading-secrets.jpg", "Familienrezept", "Okroshka wird als Produktanwendung inszeniert: klassisch, pikant, suess und als Wettbewerbsidee.", "can-secrets.png"],
  ["heading-ochakovo.jpg", "Sommerparty", "Ochakovskiy Kvas bekommt einen Anlass: Erfrischung, Snacks und Tipps fuer Treffen im Freien.", "can-ochakovo.png"],
  ["heading-kvasenok.jpg", "Kinderfest", "Kvasenok oeffnet die Familienperspektive mit Getraenkeideen, Food-Pairings und Geburtstagscontent.", "bottle-kvasenok.png"],
];

const hoverStages = [
  ["hover-screen-01.png", "01", "Statischer Hero", "Der Originalscreen im ruhigen Zustand, bevor ein Hover eine der drei Karten oeffnet."],
  ["hover-screen-02.png", "02", "Hover Sommerparty", "Der erste Hover zeigt die linke Karte als vergroesserten Party-Einstieg."],
  ["hover-screen-03.png", "03", "Hover Familienrezept", "Der zweite Hover oeffnet die mittlere Karte mit dem Familienrezept-Bereich."],
  ["hover-screen-04.png", "04", "Hover Kinderfest", "Der dritte Hover zeigt die rechte Karte als Kvasenok-Kinderbereich."],
];

const contentBlocks = [
  ["Okroshka-Rezepte", "Eine grosse Rezeptstrecke macht den Nutzen von Kvas konkret und fuehrt direkt zum Produkt."],
  ["Sommer-Tipps", "Artikel zu Snacks, Erfrischung und Partyplanung geben der Marke einen saisonalen Lebenskontext."],
  ["Kinder-Content", "Die Seite uebersetzt Produktkommunikation in Elternfragen: Was trinken Kinder, was passt dazu, wie plant man ein Fest?"],
  ["Contest", "Der Rezeptwettbewerb sammelt UGC und macht aus der Kampagne eine aktive Beteiligung."],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Ochakovo Case Study - Sommerliches Special Project mit Kvas, Okroshka, Partycontent und Familienmechanik von Andrii Prokhorovych." />
    <title>Ochakovo Campaign - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=ochakovo`}>Редактировать</a>
        <a class="button dark small" href="https://www.edimdoma.ru/2017/ochakovo" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2017</p>
          <div class="logo-mark">
            <img src={`${base}brands/logotypes/ochakovo.svg`} alt="Ochakovo Logo" />
          </div>
          <h1>Sommerkampagne mit drei Produktgeschichten und Rezeptaktivierung</h1>
          <p class="intro">
            Fuer Ochakovo entstand ein Special Project im Rhythmus des Sommers:
            Okroshka mit Familien-Kvas, Partyideen mit Ochakovskiy und Kindercontent
            fuer Kvasenok wurden in eine leichte Kampagnenlogik gebracht.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Ueberblick</a>
          <a href="#system">02 System</a>
          <a href="#hover-demo">03 Hover Demo</a>
          <a href="#szenarien">04 Szenarien</a>
          <a href="#content">05 Content</a>
          <a href="#ergebnis">06 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Food & Beverage · Summer Campaign</p>
            <h2>Ein Sommerprojekt, das Kvas nicht nur zeigt, sondern benutzt</h2>
            <p>
              Die Seite verbindet Produkt, Anlass und Handlung. Besucher waehlen
              nicht abstrakt eine Marke, sondern steigen ueber vertraute Situationen ein:
              Kochen, Picknick, Sommerparty oder Kindergeburtstag.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/cover.jpg`} alt="Ochakovo Special Project Startscreen mit drei Sommerszenarien" />
            <span>Originalbereich · Drei Einstiege fuer drei Produktgeschichten</span>
          </div>
        </section>

        <section id="system" class="system-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Campaign System</p>
            <h2>Der Hauptscreen wird zur Navigationsmechanik</h2>
            <p>
              Das Projekt laesst drei Produktwelten nebeneinander auftreten. Jede Welt
              bekommt ein eigenes Bild, eine eigene Farbe, einen eigenen Anlass und einen
              direkten Nutzen fuer den Nutzer.
            </p>
          </div>
          <div class="wide-shot">
            <img src={`${media}/intro-full.jpg`} alt="Ochakovo Okroshka Food-Fotografie aus dem Special Project" loading="lazy" />
            <div>
              <h3>Vom Sommerbild zur Rezeptstrecke</h3>
              <p>
                Das Food-Motiv verankert die Kampagne in einem konkreten Gericht. Dadurch
                wirkt der Kvas nicht wie ein isoliertes Packshot-Produkt, sondern wie ein
                Bestandteil einer sommerlichen Esssituation.
              </p>
            </div>
          </div>
        </section>

        <section id="hover-demo" class="hover-demo-section">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Originalmechanik · Hover-Reveals</p>
            <h2>Der Hero reagiert wie eine kleine Sommerbuehne</h2>
            <p>
              Im Originalprojekt war der Startscreen nicht nur Bild, sondern Interaktion:
              Beim Hover oeffneten sich drei Produktgeschichten. Hier laeuft diese Mechanik
              als kurze Demo automatisch durch und bleibt trotzdem per Hover steuerbar.
            </p>
          </div>

          <div class="hover-reveal" data-hover-reveal>
            <div class="hover-screens" aria-label="Ochakovo Startscreen mit wechselnden Hover-Zustaenden">
              {hoverStages.map(([image, step, title, text], index) => (
                <figure
                  class:list={["hover-screen", { "is-active": index === 0 }]}
                  aria-hidden={index === 0 ? "false" : "true"}
                  data-hover-layer
                  data-title={title}
                  data-text={text}
                  tabindex={index === 0 ? "0" : "-1"}
                >
                  <img src={`${media}/${image}`} alt={`Ochakovo ${title}`} loading={index === 0 ? "eager" : "lazy"} />
                </figure>
              ))}
            </div>
            <div class="hover-panel">
              <div>
                <p class="eyebrow">Aktiver Hover</p>
                <h3 data-hover-title>{hoverStages[0][2]}</h3>
                <p data-hover-text>{hoverStages[0][3]}</p>
              </div>
              <div class="hover-dots" aria-label="Hover-Zustand auswaehlen">
                {hoverStages.map(([, step, title], index) => (
                  <button
                    class:list={{ "is-active": index === 0 }}
                    type="button"
                    aria-label={`${step} ${title}`}
                    aria-current={index === 0 ? "true" : "false"}
                    data-hover-dot
                  >
                    {step}
                  </button>
                ))}
              </div>
            </div>
          </div>
        </section>

        <section id="szenarien" class="scenario-section">
          <div class="section-copy">
            <p class="eyebrow">Drei Einstiege</p>
            <h2>Jede Produktlinie bekommt eine eigene Rolle</h2>
            <p>
              Die drei Kacheln funktionieren wie kleine Landingpages innerhalb einer Seite:
              Familienrezept, Sommerparty und Kinderfest sprechen unterschiedliche Motive an.
            </p>
          </div>
          <div class="scenario-grid">
            {scenarios.map(([image, title, text, product]) => (
              <article>
                <img class="scenario-image" src={`${media}/${image}`} alt={`Ochakovo ${title} Bereich`} loading="lazy" />
                <img class="scenario-product" src={`${media}/${product}`} alt={`Ochakovo ${title} Produkt`} loading="lazy" />
                <div>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section id="content" class="content-section">
          <div class="section-number">04</div>
          <div class="section-copy">
            <p class="eyebrow">Content Layers</p>
            <h2>Rezepte, Tipps und Wettbewerb halten die Kampagne in Bewegung</h2>
            <p>
              Der Case zeigt, wie ein saisonales Markenprojekt mehr Tiefe bekommt:
              Rezeptlisten, Ratgebertexte und Contest-Mechanik schaffen mehr Kontaktpunkte
              als ein einzelner Produktbanner.
            </p>
          </div>
          <div class="content-grid">
            {contentBlocks.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">05</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Eine leichte Sommerwelt mit klarer Produktarchitektur</h2>
            <p>
              Ochakovo wird als Marke mit mehreren Alltagssituationen sichtbar:
              Erfrischung, Familienkueche und Kinderfeier. Der Nutzer bekommt sofort
              einen Grund, weiterzuklicken, zu lesen, zu kochen oder am Contest teilzunehmen.
            </p>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />
  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });

  const hoverReveal = document.querySelector("[data-hover-reveal]");
  const hoverLayers = Array.from(document.querySelectorAll("[data-hover-layer]"));
  const hoverDots = Array.from(document.querySelectorAll("[data-hover-dot]"));
  const hoverTitle = document.querySelector("[data-hover-title]");
  const hoverText = document.querySelector("[data-hover-text]");

  if (hoverReveal && hoverLayers.length > 1) {
    let activeHover = 0;
    let hoverAutoplay;

    const showHover = (nextIndex) => {
      hoverLayers[activeHover].classList.remove("is-active");
      hoverLayers[activeHover].setAttribute("aria-hidden", "true");
      hoverLayers[activeHover].setAttribute("tabindex", "-1");
      hoverDots[activeHover]?.classList.remove("is-active");
      hoverDots[activeHover]?.setAttribute("aria-current", "false");

      activeHover = (nextIndex + hoverLayers.length) % hoverLayers.length;
      const activeLayer = hoverLayers[activeHover];
      activeLayer.classList.add("is-active");
      activeLayer.setAttribute("aria-hidden", "false");
      activeLayer.setAttribute("tabindex", "0");
      hoverDots[activeHover]?.classList.add("is-active");
      hoverDots[activeHover]?.setAttribute("aria-current", "true");
      if (hoverTitle) hoverTitle.textContent = activeLayer.dataset.title || "";
      if (hoverText) hoverText.textContent = activeLayer.dataset.text || "";
    };

    const stopHoverAutoplay = () => clearInterval(hoverAutoplay);
    const startHoverAutoplay = () => {
      stopHoverAutoplay();
      if (!matchMedia("(prefers-reduced-motion: reduce)").matches) {
        hoverAutoplay = setInterval(() => showHover(activeHover + 1), 2600);
      }
    };

    hoverDots.forEach((dot, index) => dot.addEventListener("click", () => {
      showHover(index);
      startHoverAutoplay();
    }));
    hoverReveal.addEventListener("pointerenter", stopHoverAutoplay);
    hoverReveal.addEventListener("pointerleave", startHoverAutoplay);
    hoverReveal.addEventListener("focusin", stopHoverAutoplay);
    hoverReveal.addEventListener("focusout", startHoverAutoplay);
    startHoverAutoplay();
  }
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f7fbf0;
    --paper: #fff;
    --ink: #142031;
    --muted: #65717e;
    --line: rgba(20, 32, 49, .13);
    --green: #83a63d;
    --red: #ed1b48;
    --blue: #4f94c9;
    --yellow: #edba20;
    --soft: #f2f7e7;
    --radius: 10px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(255, 255, 255, .92);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(18px);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
  }
  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { min-height: 42px; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(20, 32, 49, .18) !important;
    color: rgba(20, 32, 49, .46) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--green);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .logo-mark {
    align-items: center;
    background: #f4f4f4;
    border-radius: 16px 16px 16px 4px;
    display: inline-flex;
    height: 72px;
    justify-content: center;
    margin-bottom: 30px;
    padding: 0 18px;
    width: 150px;
  }
  .logo-mark img { width: 112px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); line-height: 1.08; }
  h2 { font-size: clamp(34px, 4.5vw, 72px); letter-spacing: -.055em; line-height: .98; max-width: 980px; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; gap: 18px; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 430px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media, .wide-shot, .scenario-grid article, .content-grid article {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 30px 90px rgba(20, 32, 49, .12);
    overflow: hidden;
  }
  .hero-media img { aspect-ratio: 16 / 9; object-fit: cover; object-position: center; width: 100%; }
  .hero-media span {
    color: var(--muted);
    display: block;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    padding: 16px 18px;
    text-transform: uppercase;
  }

  .system-section {
    background: #fff;
    display: grid;
    gap: 36px;
    grid-template-columns: 70px minmax(0, 1fr);
  }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 900px; }
  .wide-shot {
    display: grid;
    grid-column: 2;
    grid-template-columns: minmax(0, 1.4fr) minmax(260px, .6fr);
    margin-top: 18px;
  }
  .wide-shot img { height: 100%; object-fit: cover; object-position: center; width: 100%; }
  .wide-shot div { align-self: end; padding: clamp(24px, 4vw, 48px); }
  .wide-shot h3 { font-size: clamp(26px, 3vw, 44px); letter-spacing: -.04em; line-height: 1; }
  .wide-shot p { color: var(--muted); line-height: 1.65; margin-top: 18px; }

  .hover-demo-section {
    background: #fff;
    display: grid;
    gap: 36px;
    grid-template-columns: 70px minmax(0, 1fr);
  }
  .hover-reveal {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 34px 100px rgba(20, 32, 49, .11);
    grid-column: 2;
    margin-top: 18px;
    overflow: hidden;
  }
  .hover-screens {
    aspect-ratio: 3456 / 2234;
    background: #fff;
    overflow: hidden;
    position: relative;
  }
  .hover-screen {
    inset: 0;
    margin: 0;
    opacity: 0;
    pointer-events: none;
    position: absolute;
    transition: opacity .55s ease;
  }
  .hover-screen.is-active,
  .hover-screen:hover,
  .hover-screen:focus-visible {
    opacity: 1;
    pointer-events: auto;
  }
  .hover-screen:focus-visible { outline: 2px solid var(--green); outline-offset: -6px; }
  .hover-screen img {
    height: 100%;
    object-fit: cover;
    object-position: center;
    width: 100%;
  }
  .hover-panel {
    align-items: end;
    background: #102018;
    color: #fff;
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1fr) auto;
    padding: clamp(22px, 3vw, 34px);
  }
  .hover-panel .eyebrow {
    color: rgba(255, 255, 255, .62);
    margin-bottom: 12px;
  }
  .hover-panel h3 {
    font-size: clamp(28px, 3vw, 44px);
    letter-spacing: -.04em;
    line-height: 1;
  }
  .hover-panel p:not(.eyebrow) {
    color: rgba(255, 255, 255, .72);
    line-height: 1.6;
    margin-top: 12px;
    max-width: 620px;
  }
  .hover-dots { display: flex; gap: 8px; }
  .hover-dots button {
    background: rgba(255, 255, 255, .08);
    border: 1px solid rgba(255, 255, 255, .2);
    border-radius: 999px;
    color: #fff;
    cursor: pointer;
    font-size: 12px;
    font-weight: 900;
    height: 42px;
    transition: background .2s ease, transform .2s ease;
    width: 42px;
  }
  .hover-dots button:hover,
  .hover-dots button.is-active {
    background: #fff;
    color: #102018;
    transform: translateY(-2px);
  }

  .scenario-section {
    background:
      radial-gradient(circle at 88% 12%, rgba(237, 27, 72, .12), transparent 24%),
      linear-gradient(180deg, #f7fbf0, #eef6df);
  }
  .scenario-grid { display: grid; gap: 18px; grid-template-columns: repeat(3, 1fr); margin-top: 48px; }
  .scenario-grid article { position: relative; }
  .scenario-image { aspect-ratio: 1 / 1; object-fit: cover; width: 100%; }
  .scenario-product {
    bottom: 118px;
    filter: drop-shadow(0 18px 28px rgba(20, 32, 49, .18));
    max-height: 170px;
    object-fit: contain;
    position: absolute;
    right: 18px;
    width: 28%;
  }
  .scenario-grid div { padding: 24px; }
  .scenario-grid h3 { font-size: 26px; line-height: 1.05; }
  .scenario-grid p { color: var(--muted); font-size: 14px; line-height: 1.58; margin-top: 12px; }

  .content-section {
    background:
      linear-gradient(90deg, rgba(131, 166, 61, .08), rgba(79, 148, 201, .08)),
      #fff;
    display: grid;
    gap: 36px;
    grid-template-columns: 70px minmax(0, 1fr);
  }
  .content-grid { display: grid; gap: 16px; grid-column: 2; grid-template-columns: repeat(4, 1fr); margin-top: 18px; }
  .content-grid article {
    box-shadow: none;
    min-height: 270px;
