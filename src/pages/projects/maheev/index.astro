---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/maheev`;

const facts = [
  ["Kunde", "Maheev"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2017"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Produktkategorien als Einstieg", "Mayonnaise, Ketchups, Marmeladen, Gewuerze und Konserven werden als klare, klickbare Sortimentwelt inszeniert."],
  ["Rezeptkarte mit Entdeckungslogik", "Eine interaktive Weltkarte fuehrt Nutzer zu festlichen Rezeptideen aus unterschiedlichen Laendern."],
  ["Contest als Aktivierung", "Der Rezeptwettbewerb verlaengert die Kampagne von Inspiration in konkrete Teilnahme und User-Generated-Content."],
];

const products = [
  ["product-mayo.png", "Mayonnaise", "Basis fuer Salate und festliche Klassiker."],
  ["product-ketchup.png", "Ketchup", "Wuerzige Begleitung fuer warme Gerichte."],
  ["product-jam.png", "Marmelade", "Suesse Komponente fuer Desserts und Gebaeck."],
  ["product-preserve.png", "Konserven", "Vorrat und schnelle Zutaten fuer den Festtisch."],
];

const journeySteps = [
  ["01", "Sortiment", "Der Nutzer sieht zuerst, welche Produktgruppen den Festtisch tragen."],
  ["02", "Rezeptkarte", "Die Karte verwandelt Produkte in konkrete internationale Menueideen."],
  ["03", "Tipps", "Artikel helfen bei Planung, Servieren und kleinen saisonalen Entscheidungen."],
  ["04", "Contest", "Der Wettbewerb macht aus Inspiration eigene Rezepte und Beteiligung."],
];

const featureScreens = [
  ["map.jpg", "Rezeptkarte", "Interaktive Laenderlogik", "Die Weltkarte macht das Festmenue spielerisch: Nutzer springen von Land zu Land und entdecken passende Gerichte."],
  ["articles.jpg", "Artikel", "Redaktionelle Vorbereitung", "Tipps und saisonale Inhalte geben der Kampagne Nutzwert jenseits des Produktregals."],
  ["contest.jpg", "Contest", "Teilnahme als Aktivierung", "Der Wettbewerb verlaengert die Inspiration in User-Generated-Content und eigene Festrezepte."],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Maheev New Year Special Project 2017 - Case Study von Andrii Prokhorovych." />
    <title>Maheev New Year Campaign 2017 - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=maheev`}>Редактировать</a>
        <a class="button dark small" data-owner-only hidden href="https://www.edimdoma.ru/2017/maheev" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2017</p>
          <img class="client-logo" src={`${media}/logo.svg`} alt="Maheev" />
          <h1>Neujahr zu Hause als digitale Markenwelt</h1>
          <p class="intro">
            Eine festliche Kampagne, die Sortiment, Rezepte, redaktionelle Tipps und
            Wettbewerb in einer warmen New-Year-Erfahrung verbindet.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#konzept">02 Konzept</a>
          <a href="#highlights">03 Highlights</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Food & Beverage · New Year Campaign</p>
            <h2>Maheev macht den Festtisch planbar und inspirierend</h2>
            <p>
              Das Special Project fuehrt Nutzer vom Markensortiment ueber Rezeptideen
              bis zum Wettbewerb. Die Seite nutzt eine klare Saisonlogik: Produkte
              entdecken, Menue planen, Tipps lesen, eigenes Rezept einreichen.
            </p>
          </div>
          <div class="hero-media hero-stack">
            <img src={`${media}/hero-concept.jpg`} alt="Maheev New Year Festtisch mit Saucen, Salaten, Dessert und Rezeptplanung" />
            <span>Hero · Festtisch, Sortiment und Rezeptplanung</span>
          </div>
        </section>

        <section id="konzept" class="story-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Konzept</p>
            <h2>Ein saisonaler Guide vom Produktregal zum Festmenue</h2>
            <p>
              Die Kampagne kombiniert zwei Aufgaben: Maheev als breite Produktfamilie
              zeigen und direkt kulinarische Anwendungsideen liefern. Produkt-Slider,
              Rezeptkarte, Artikel und Contest funktionieren wie Stationen einer
              einzigen Festvorbereitung.
            </p>
          </div>
          <div class="quote">
            <p>„Gute Saisonkampagnen geben nicht nur Stimmung, sondern auch einen naechsten Schritt.“</p>
          </div>
        </section>

        <section class="product-section" aria-labelledby="products-title">
          <div class="section-copy">
            <p class="eyebrow">Sortiment</p>
            <h2 id="products-title">Produktkategorien als interaktive Buehne</h2>
          </div>
          <div class="product-stage">
            <img class="stage-bg" src={`${media}/goods.jpg`} alt="Maheev Produktbereich" loading="lazy" />
            <div class="product-row" aria-label="Maheev Produktkategorien">
              {products.map(([image, title, text]) => (
                <article>
                  <img src={`${media}/${image}`} alt={title} loading="lazy" />
                  <h3>{title}</h3>
                  <p>{text}</p>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section id="highlights" class="highlights">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was den Auftritt besonders macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="journey-section" aria-label="Kampagnenreise">
          <div class="section-copy">
            <p class="eyebrow">Dramaturgie</p>
            <h2>Vier Schritte vom Produkt zum eigenen Festrezept</h2>
          </div>
          <div class="journey-grid">
            {journeySteps.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="feature-section" aria-label="Kampagnenansichten">
          <article class="system-card">
            <p class="eyebrow">Originalmechaniken</p>
            <h2>Die Kampagne wird als Menue-Tool lesbar</h2>
            <p>
              Maheev wirkt hier nicht nur dekorativ saisonal. Sortiment, Karte, Artikel und
              Contest bilden eine echte Aktivierungsstrecke fuer den Neujahrstisch.
            </p>
          </article>
          <div class="feature-grid">
            {featureScreens.map(([image, label, title, text]) => (
              <article>
                <img src={`${media}/${image}`} alt={title} loading="lazy" />
                <div>
                  <span>{label}</span>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Eine festliche Kampagne mit klarer Aktivierung</h2>
            <p>
              Maheev wird als vielseitiger Helfer fuer den Neujahrstisch positioniert.
              Die Kombination aus Sortiment, Rezeptnavigation, redaktionellen Tipps und
              Wettbewerb gibt der Kampagne Nutzwert und Interaktion.
            </p>
            <a class="button light" data-owner-only hidden href="https://www.edimdoma.ru/2017/maheev" target="_blank" rel="noreferrer">
              Originalprojekt oeffnen
            </a>
          </div>
          <img class="sani" src={`${media}/sani.png`} alt="" loading="lazy" />
        </section>
      </article>
    </main>
    <MotionEnhance />

  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #fbf6ed;
    --paper: #fff;
    --ink: #111;
    --muted: #666;
    --line: rgba(17, 17, 17, .12);
    --accent: #e30613;
    --deep: #811015;
    --gold: #f5c15b;
    --cream: #fff5df;
    --radius: 10px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(251, 246, 237, .92);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(17, 17, 17, 0.18) !important;
    color: rgba(17, 17, 17, 0.46) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--accent);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 74px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 160px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(32px, 4.5vw, 68px); line-height: 1.02; max-width: 900px; }
  .intro { hyphens: auto; overflow-wrap: anywhere; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero {
    background:
      radial-gradient(circle at 12% 12%, rgba(245, 193, 91, .24), transparent 30%),
      radial-gradient(circle at 84% 18%, rgba(227, 6, 19, .14), transparent 28%),
      var(--bg);
    min-height: calc(100vh - 83px);
  }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media {
    background: linear-gradient(135deg, var(--deep), var(--accent));
    border-radius: 24px;
    box-shadow: 0 30px 90px rgba(129, 16, 21, .18);
    overflow: hidden;
    position: relative;
  }
  .hero-media > img:first-child { aspect-ratio: 16 / 8; object-fit: cover; width: 100%; }
  .hero-media span { color: #fff; display: block; font-size: 12px; font-weight: 900; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .story-section, .highlights, .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 850px; }
  .quote {
    background:
      radial-gradient(circle at 84% 18%, rgba(245, 193, 91, .34), transparent 26%),
      linear-gradient(135deg, var(--deep), var(--accent));
    border-radius: var(--radius);
    color: #fff;
    font-size: clamp(26px, 4vw, 52px);
    font-weight: 800;
    grid-column: 2;
    line-height: 1.12;
    margin-top: 28px;
    padding: clamp(28px, 5vw, 70px);
  }

  .product-section {
    background:
      radial-gradient(circle at 18% 0%, rgba(245, 193, 91, .18), transparent 28%),
      #fff;
  }
  .product-stage {
    border-radius: 24px;
    box-shadow: 0 28px 80px rgba(129, 16, 21, .1);
    margin-top: 48px;
    overflow: hidden;
    position: relative;
  }
  .stage-bg { aspect-ratio: 16 / 8; object-fit: cover; width: 100%; }
  .product-row {
    bottom: 28px;
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(4, 1fr);
    left: 28px;
    position: absolute;
    right: 28px;
  }
  .product-row article {
    background: rgba(255, 255, 255, .92);
    border: 1px solid rgba(227, 6, 19, .12);
    border-radius: 18px;
    box-shadow: 0 22px 60px rgba(80, 21, 10, .12);
    min-height: 220px;
    padding: 18px;
    text-align: center;
    transition: box-shadow .35s ease, transform .35s ease;
    backdrop-filter: blur(12px);
  }
  .product-row article:hover {
    box-shadow: 0 30px 76px rgba(80, 21, 10, .2);
    transform: translateY(-8px);
  }
  .product-row img { height: 150px; margin: -90px auto 16px; object-fit: contain; }
  .product-row h3 { font-size: 19px; line-height: 1.2; }
  .product-row p { color: var(--muted); font-size: 13px; line-height: 1.5; margin-top: 10px; }

  .highlight-grid { display: grid; gap: 18px; grid-column: 2; grid-template-columns: repeat(3, 1fr); margin-top: 24px; }
  .highlight-grid article { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); min-height: 260px; padding: 26px; }
  .highlight-grid span { color: var(--accent); font-size: 12px; font-weight: 900; }
  .highlight-grid h3 { font-size: 20px; line-height: 1.2; margin-top: 54px; }
  .highlight-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .journey-section {
    background:
      radial-gradient(circle at 88% 16%, rgba(245, 193, 91, .28), transparent 26%),
      linear-gradient(135deg, var(--deep), #b9161f);
    color: #fff;
  }
  .journey-section .eyebrow,
  .journey-grid p { color: rgba(255, 255, 255, .72); }
  .journey-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 48px;
  }
  .journey-grid article {
    background: rgba(255, 255, 255, .09);
    border: 1px solid rgba(255, 255, 255, .16);
    border-radius: 18px;
    min-height: 240px;
    padding: 24px;
  }
  .journey-grid span { color: var(--gold); font-size: 13px; font-weight: 950; }
  .journey-grid h3 { font-size: 24px; line-height: 1.08; margin-top: 58px; }
  .journey-grid p { font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .feature-section {
    background:
      linear-gradient(90deg, rgba(227, 6, 19, .06) 1px, transparent 1px),
      linear-gradient(180deg, #fbf6ed, #fff5df);
    background-size: 42px 42px, auto;
    display: grid;
    gap: 20px;
    grid-template-columns: .82fr 1.18fr;
  }
  .system-card,
  .feature-grid article {
    background: var(--paper);
    border-radius: 24px;
    box-shadow: 0 28px 80px rgba(129, 16, 21, .1);
    overflow: hidden;
  }
  .system-card {
    background:
      radial-gradient(circle at 84% 16%, rgba(245, 193, 91, .28), transparent 28%),
      linear-gradient(135deg, #fff, var(--cream));
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 520px;
    padding: clamp(28px, 4vw, 56px);
  }
  .system-card h2 { font-size: clamp(34px, 4vw, 58px); }
  .system-card p:last-child { color: var(--muted); font-size: 16px; line-height: 1.7; margin-top: 24px; max-width: 640px; }
  .feature-grid { display: grid; gap: 18px; }
  .feature-grid article {
    display: grid;
    grid-template-columns: minmax(220px, .82fr) minmax(0, 1fr);
  }
  .feature-grid img {
    aspect-ratio: 16 / 10;
    height: 100%;
    object-fit: cover;
    width: 100%;
  }
  .feature-grid article > div { align-self: end; padding: 28px; }
  .feature-grid span {
    color: var(--accent);
    display: block;
    font-size: 12px;
    font-weight: 950;
    letter-spacing: .08em;
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .feature-grid h3 { font-size: 28px; line-height: 1.08; }
  .feature-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }
  figcaption { color: var(--muted); font-size: 12px; font-weight: 800; padding: 16px; text-transform: uppercase; }

  .result { background: var(--deep); color: #fff; overflow: hidden; position: relative; }
  .result .eyebrow, .result-copy > p { color: #ffd6d6; }
  .result-copy { max-width: 900px; position: relative; z-index: 1; }
  .result .button { border-color: #fff; margin-top: 34px; }
  .sani { bottom: 28px; opacity: .72; position: absolute; right: clamp(24px, 6vw, 100px); width: 170px; }

  @media (max-width: 1100px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
    .product-row { grid-template-columns: repeat(2, 1fr); position: static; padding: 18px; }
    .product-row img { margin-top: 0; }
    .journey-grid { grid-template-columns: repeat(2, 1fr); }
    .feature-section { grid-template-columns: 1fr; }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    .header-actions { gap: 5px; }
    .case-sidebar { padding: 36px 18px; }
    .case-content > section { padding-left: 18px; padding-right: 18px; }
    .hero-copy, .story-section, .highlights, .result { grid-template-columns: 1fr; }
    .hero-copy .eyebrow, .quote, .highlight-grid { grid-column: 1; }
    .highlight-grid, .product-row, .journey-grid, .feature-grid article { grid-template-columns: 1fr; }
    .section-number { display: none; }
    .sani { display: none; }
  }
</style>
