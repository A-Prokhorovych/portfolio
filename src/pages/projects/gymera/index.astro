---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/gymera`;

const facts = [
  ["Projekt", "Gymera"],
  ["Bereich", "Fitness Tech"],
  ["Jahr", "2025"],
  ["Rolle", "Product Website, App UI, Design Kit"],
];

const highlights = [
  ["Segmentierte Produktstory", "Die Website zeigt Gymera nicht als einzelnes Geraet, sondern als System fuer Home Fitness, Hotels, Unternehmen, Trainer und Rehabilitation."],
  ["KI-gestuetzte Trainingslogik", "Dashboard und App-Einstieg machen Betreuung, Training Control, Fortschritt und personalisierte Programme sichtbar."],
  ["Skalierbarer Designbaukasten", "Farben, dunkle Oberflaechen, hellblaue Informationsflaechen und kompakte UI-Module bilden eine wiederholbare visuelle Sprache."],
];

const quickRead = [
  ["Aufgabe", "Gymera als KI-Fitnessprodukt schnell verstaendlich machen: fuer Website-Besucher, App-Nutzer und B2B-Entscheider."],
  ["Mein Beitrag", "Informationsarchitektur, visuelle Richtung, Landingpage-System, erste App- und Dashboard-Screens, kompakter UI Kit."],
  ["Ergebnis", "Ein Portfolio-Case, der in wenigen Sekunden Produkt, Zielgruppen, Interface-Logik und Designsystem zeigt."],
  ["Artefakte", "Produktwebsite, Segment-Landingpages, Dashboard-Konzept, Mobile Flow, Styleguide und Komponentenlogik."],
];

const contribution = [
  ["01", "Positionierung", "Ich habe Gymera nicht nur als Fitnessgeraet, sondern als Plattform fuer mehrere Nutzungsszenarien strukturiert."],
  ["02", "Website-System", "Ich habe die Landingpages so aufgebaut, dass jede Zielgruppe eine eigene Nutzenargumentation bekommt."],
  ["03", "App-Logik", "Ich habe die ersten UI-Screens auf Training, Feedback, Fortschritt und Steuerung verdichtet."],
  ["04", "Design Kit", "Ich habe Farben, Komponenten, Datenmodule und mobile Muster zu einem wiederholbaren System zusammengefuehrt."],
];

const productSections = [
  ["Home Fitness", "Privates Training mit platzsparendem Setup und persoenlicher Steuerung."],
  ["Hotel Fitness", "Premium-Fitness als Service fuer Gaeste ohne grossen Raumaufwand."],
  ["Corporate Fitness", "Gesundheit und Bewegung im Arbeitsalltag mit messbarem Nutzen."],
  ["Personal Trainer", "Ein System fuer individuelle Betreuung und skalierbare Trainingsplaene."],
  ["Rehabilitation", "Programme fuer Erholung, Aufbau und kontrollierte Bewegung."],
];

const metrics = [
  ["67%", "weniger Platzbedarf"],
  ["90%", "Funktionen abgedeckt"],
  ["1000+", "Workouts"],
  ["24/7", "digitale Betreuung"],
];

const tokens = [
  ["Primary", "#9f5cff"],
  ["Electric", "#3189ff"],
  ["Signal", "#98ff44"],
  ["Ink", "#05070a"],
  ["Cloud", "#edf5ff"],
  ["Line", "#d8e2ef"],
];

const productProof = [
  ["Hardware first", "Der Case beginnt nicht bei einem abstrakten Screen, sondern beim realen Geraet: Rahmen, Display, Plattform und Seilzugmechanik."],
  ["Visual direction", "Graphit, schwarzer Screen, aqua Glas und kontrollierte Studio-Lichter bilden die visuelle Bruecke zwischen Foto, 3D und Interface."],
  ["Website-ready story", "Die Produktinszenierung kann als Hero, Motion-Clip oder interaktive WebGL/canvas Szene in eine Landingpage ueberfuehrt werden."],
];

const caseFlow = [
  ["01", "Reference", "Fotos und Figma-Boards klaeren Material, Kontext und visuelle Tonalitaet."],
  ["02", "Render", "Die 3D-Geometrie wird auf einen dunklen Produktlook mit Macro-Fokus und Lichtkanten uebersetzt."],
  ["03", "Interface", "Dashboard, App und Website ergaenzen das Geraet um KI-Coaching, Training Control und Fortschritt."],
  ["04", "Portfolio", "Der Case zeigt Hardware, Motion, UI und Systemlogik als zusammenhaengende Produktentscheidung."],
];

const figmaScreens = [
  ["Homepage system", "figma-home.jpg", "Eine lange Produktstory mit Hero, Nutzenargumentation, Social Proof, Use Cases und Store-Einstieg."],
  ["Product functions", "figma-functions.jpg", "Funktionsseite fuer Platzersparnis, Geraetesteuerung, technische Daten und Vergleich zum Fitnessstudio."],
  ["AI functions", "figma-ai-functions.jpg", "AI Mirror, Echtzeit-Analyse, Fitnessprogramm, Dokumentation und Ernaehrungsplan als eigene Produktlogik."],
  ["Training control", "figma-training-control.jpg", "Realtime-Metriken, Leistungsfeedback und adaptive Trainingsdaten als visuelle Interface-Sprache."],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Gymera Fitness Tech Case Study - Product Website, App UI und Design Kit von Andrii Prokhorovych." />
    <title>Gymera Product Design - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#work`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=gymera`}>Редактировать</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2025</p>
          <div class="gymera-mark" aria-label="Gymera">GYMERA</div>
          <h1>Fitness-Technologie als Produkt, App und Designsystem</h1>
          <p class="intro">
            Ein Portfolio-Case fuer Gymera: Produktwebsite, erste App-Screens, Dashboard,
            mobile Experience und ein kompakter Styleguide in einer zusammenhaengenden Story.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Website</a>
          <a href="#beitrag">02 Beitrag</a>
          <a href="#produkt">03 Produkt</a>
          <a href="#app">04 App UI</a>
          <a href="#kit">05 Design Kit</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Fitness Tech · Product Experience</p>
            <h2>Ein KI-Fitnesssystem fuer mehrere Nutzungsszenarien</h2>
            <p>
              Gymera brauchte eine visuelle Produktlogik, die Hardware, Training, KI-Analyse
              und unterschiedliche Zielgruppen zusammenbringt. Der Case zeigt das System als
              Website, App-Oberflaeche und Designbaukasten.
            </p>
          </div>
          <div class="hero-media hero-3d" data-gymera-hero>
            <canvas id="gymera-hero-canvas" aria-hidden="true"></canvas>
            <img class="hero-3d-fallback" src={`${media}/product-detail.jpg`} alt="Gymera 3D Produktinszenierung mit graphitfarbenem Trainingsgeraet" />
            <div class="hero-3d-copy">
              <span class="hero-3d-kicker">Interactive product render</span>
              <strong>Graphite hardware · aqua glass · AI training interface</strong>
            </div>
            <span>3D Hero · Produktmodell, Lichtkanten und Macro-Fokus</span>
          </div>
        </section>

        <section class="product-render-section" aria-labelledby="product-render-title">
          <div class="section-copy">
            <p class="eyebrow">Hardware Story</p>
            <h2 id="product-render-title">Vom realen Geraet zur dunklen Produktinszenierung</h2>
            <p>
              Fuer den Case habe ich die Referenzfotos, den Figma-Look und die 3D-Dateien als
              eine gemeinsame Produktwelt gedacht: ein graphitfarbenes Trainingssystem mit
              schwarzem Display, aqua Plattform und praezisen Lichtkanten fuer Website-Hero,
              Motion und Macro-Details.
            </p>
          </div>

          <div class="render-gallery">
            <figure class="render-main">
              <img src={`${media}/product-detail.jpg`} alt="Gymera Produktdetail mit graphitfarbenem Rahmen und aqua Trainingsplattform" loading="lazy" />
              <figcaption>Reference detail · graphite body and aqua glass platform</figcaption>
            </figure>
            <figure>
              <img src={`${media}/rehab-context.jpg`} alt="Gymera Geraet im Rehabilitationskontext mit Patient und Therapeut" loading="lazy" />
              <figcaption>Context visual · rehabilitation and assisted training</figcaption>
            </figure>
            <figure>
              <img src={`${media}/home-training.jpg`} alt="Gymera Training in einem hellen Wohnraum" loading="lazy" />
              <figcaption>Use case · home training setup</figcaption>
            </figure>
          </div>

          <div class="proof-grid product-proof">
            {productProof.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="reel-section" aria-labelledby="reel-title">
          <div class="section-copy">
            <p class="eyebrow">Remotion Experiment</p>
            <h2 id="reel-title">Product Story als kurzer Motion-Reel</h2>
            <p>
              Das Reel folgt der Case-Logik aus dem Portfolio-Framework: Kontext, Aufgabe,
              Entscheidung und Ergebnis werden in wenigen Sekunden lesbar. So wirkt Gymera
              nicht wie eine reine Screensammlung, sondern wie ein Produkt mit klarer Rolle.
            </p>
          </div>
          <div class="reel-frame">
            <video controls preload="metadata" poster={`${media}/customer-overview.png`}>
              <source src={`${media}/reel-preview.mp4`} type="video/mp4" />
            </video>
            <span>Remotion Preview · Gymera Product Story Reel</span>
          </div>
        </section>

        <section class="flow-section" aria-labelledby="flow-title">
          <div class="section-copy">
            <p class="eyebrow">Case Aufbau</p>
            <h2 id="flow-title">Die Story fuehrt von Hardware zu Interface</h2>
            <p>
              Der Case ist so aufgebaut, dass Recruiter oder Kunden den Denkprozess schnell
              erkennen: erst Produkt und Kontext, dann die visuelle Richtung, danach Website,
              App-Logik und Designsystem.
            </p>
          </div>
          <div class="flow-grid">
            {caseFlow.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="figma-system-section" aria-labelledby="figma-system-title">
          <div class="section-copy">
            <p class="eyebrow">Figma Screens</p>
            <h2 id="figma-system-title">Aus den Figma-Frames wird eine klare Produktarchitektur</h2>
            <p>
              Die exportierten Frames zeigen, wie Gymera als Website-System gedacht ist:
              Einstieg, Funktionen, KI-Ebene, Training Control und reale Einsatzkontexte
              folgen derselben dunklen High-Tech-Sprache.
            </p>
          </div>

          <figure class="context-frame">
            <img src={`${media}/figma-gym-context.jpg`} alt="Gymera in einem hellen Fitnessraum als Einsatzkontext" loading="lazy" />
            <figcaption>Context frame · gym environment and product placement</figcaption>
          </figure>

          <div class="figma-screen-grid">
            {figmaScreens.map(([title, image, text]) => (
              <figure>
                <img src={`${media}/${image}`} alt={`Gymera Figma screen: ${title}`} loading="lazy" />
                <figcaption>
                  <strong>{title}</strong>
                  <span>{text}</span>
                </figcaption>
              </figure>
            ))}
          </div>

          <figure class="context-frame product-stage-frame">
            <img src={`${media}/figma-product-stage.jpg`} alt="Gymera Produktinszenierung mit dunklem Studio-Look und Interface-Screen" loading="lazy" />
            <figcaption>Product stage · dark render direction and interface atmosphere</figcaption>
          </figure>
        </section>

        <section class="quick-read" aria-label="5-second portfolio read">
          <div class="section-copy">
            <p class="eyebrow">5-second read</p>
            <h2>Was man sofort verstehen soll</h2>
          </div>
          <div class="quick-grid">
            {quickRead.map(([label, text]) => (
              <article>
                <span>{label}</span>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="beitrag" class="contribution-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Mein Beitrag</p>
            <h2>Ich zeige nicht nur Screens, sondern meine Design-Entscheidungen</h2>
            <p>
              Der Case ist bewusst wie ein Hiring-Review aufgebaut: erst Kontext und Rolle,
              dann die wichtigsten Produktentscheidungen, danach Screens und System. So wird
              sichtbar, welche Probleme ich geloest habe und nicht nur, wie die Oberflaeche aussieht.
            </p>
          </div>
          <div class="contribution-grid">
            {contribution.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="produkt" class="product-section">
          <div class="section-copy">
            <p class="eyebrow">Product Website</p>
            <h2>Eine Website, die verschiedene Fitness-Kontexte bedienen kann</h2>
            <p>
              Die Landingpages arbeiten mit derselben visuellen Grammatik, wechseln aber die
              Tonalitaet je nach Einsatzbereich: privat, Hotel, Unternehmen, Training oder
              Rehabilitation.
            </p>
          </div>
          <div class="segment-grid">
            {productSections.map(([title, text]) => (
              <article>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
          <figure class="wide-frame">
            <img src={`${media}/dashboard-overview.png`} alt="Gymera Website-System mit langen Produktseiten und Service-Modulen" loading="lazy" />
            <figcaption>Website-System · Produktseiten, Service Center, Showrooms und Vision</figcaption>
          </figure>
        </section>

        <section class="metrics-section" aria-label="Produktmetriken">
          <div class="metric-grid">
            {metrics.map(([value, label]) => (
              <article>
                <strong>{value}</strong>
                <span>{label}</span>
              </article>
            ))}
          </div>
        </section>

        <section id="app" class="app-section">
          <div class="section-copy">
            <p class="eyebrow">App und Dashboard</p>
            <h2>Erste Screens fuer Training, Steuerung und Fortschritt</h2>
            <p>
              Die App-Ebene konzentriert sich auf das, was Nutzer sofort verstehen muessen:
              aktueller Trainingsstatus, Programm, Bewegungskontrolle, KI-Feedback und
              Fortschritt ueber Zeit.
            </p>
          </div>

          <div class="interface-stage">
            <div class="dashboard-mock" aria-label="Gymera Dashboard Mockup">
              <div class="dashboard-top">
                <div>
                  <span>GYMERA Control</span>
                  <h3>Training Dashboard</h3>
                </div>
                <button type="button">Live Session</button>
              </div>
              <div class="dashboard-layout">
                <div class="panel session-panel">
                  <p class="panel-label">Current program</p>
                  <h4>Full Body AI</h4>
                  <div class="progress-ring"><span>86</span></div>
                  <p>Form score · adaptive resistance active</p>
                </div>
                <div class="panel chart-panel">
                  <p class="panel-label">Weekly load</p>
                  <div class="bars">
                    <span style="height: 44%"></span>
                    <span style="height: 62%"></span>
                    <span style="height: 38%"></span>
                    <span style="height: 74%"></span>
                    <span style="height: 88%"></span>
                    <span style="height: 57%"></span>
                    <span style="height: 69%"></span>
                  </div>
                </div>
                <div class="panel feed-panel">
                  <p class="panel-label">AI Coaching</p>
                  <ul>
                    <li>Balance correction detected</li>
                    <li>Resistance lowered for left shoulder</li>
                    <li>Next block: controlled rotation</li>
                  </ul>
                </div>
                <div class="panel control-panel">
                  <p class="panel-label">Device</p>
                  <h4>Gymera One</h4>
                  <div class="device-lines">
                    <span></span>
                    <span></span>
                    <span></span>
                  </div>
                </div>
              </div>
            </div>

            <div class="phone-mock" aria-label="Gymera Mobile Mockup">
              <div class="phone-screen">
                <div class="phone-status">
                  <span>9:41</span>
                  <span>● ● ●</span>
                </div>
                <div class="mobile-hero">
                  <span>Today</span>
                  <h3>Strength Control</h3>
                  <p>32 min · upper body</p>
                </div>
                <div class="mobile-score">
                  <strong>92%</strong>
                  <span>movement quality</span>
                </div>
                <div class="mobile-list">
                  <article>
                    <span></span>
                    <div>
                      <strong>Cable row</strong>
                      <p>3 sets · smart resistance</p>
                    </div>
                  </article>
                  <article>
                    <span></span>
                    <div>
                      <strong>Core rotation</strong>
                      <p>2 sets · posture control</p>
                    </div>
                  </article>
                  <article>
                    <span></span>
                    <div>
                      <strong>Recovery</strong>
                      <p>breathing and cooldown</p>
                    </div>
                  </article>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section class="highlights">
          <div class="section-number">04</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was der Case sichtbar macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="kit" class="kit-section">
          <div class="section-copy">
            <p class="eyebrow">Styleguide und UI Kit</p>
            <h2>Ein kompakter Designbaukasten fuer Website und App</h2>
            <p>
              Der Kit verbindet dunkle Produktinszenierung mit hellen Informationsflaechen.
              Violett, Blau und Signalgruen setzen Akzente fuer Aktionen, KI-Feedback und
              Trainingsmetriken.
            </p>
          </div>
          <div class="kit-grid">
            <article class="token-card">
              <h3>Color Tokens</h3>
              <div class="token-list">
                {tokens.map(([name, value]) => (
                  <div>
                    <span style={`background: ${value}`}></span>
                    <strong>{name}</strong>
                    <code>{value}</code>
                  </div>
                ))}
              </div>
            </article>
            <article class="component-card">
              <h3>Components</h3>
              <button type="button">Start workout</button>
              <button class="secondary" type="button">View analytics</button>
              <div class="mini-card">
                <span>AI recommendation</span>
                <strong>Reduce load by 8%</strong>
                <p>Detected asymmetry in the last set.</p>
              </div>
            </article>
            <article class="type-card">
              <h3>Typography</h3>
              <p class="display">Training intelligence</p>
              <p class="body-copy">Clear hierarchy for dense data, product storytelling and compact mobile controls.</p>
            </article>
          </div>
        </section>

        <section class="result">
          <div class="section-number">05</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Gymera wird als skalierbares Fitness-Tech-Produkt erlebbar</h2>
            <p>
              Der Portfolio-Case zeigt nicht nur einzelne Screens, sondern eine Produktwelt:
              Website-Story, App-Einstieg, Dashboard-Logik, mobile Nutzung und ein Styleguide,
              der die visuelle Sprache fuer weitere Screens tragfaehig macht.
            </p>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />
    <script src={`${media}/hero-mesh.js`}></script>
  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });

  const initGymeraHero = () => {
    const stage = document.querySelector("[data-gymera-hero]");
    const canvas = document.getElementById("gymera-hero-canvas");
    const mesh = window.GYMERA_HERO_MESH;
    document.documentElement.dataset.gymeraHeroMesh = String(mesh?.points?.length || 0);
    if (!stage || !(canvas instanceof HTMLCanvasElement) || !mesh?.points?.length) {
      stage?.classList.add("is-fallback");
      document.documentElement.dataset.gymeraHeroMode = "fallback";
      return;
    }

    const context = canvas.getContext("2d", { alpha: true });
    if (!context) {
      stage.classList.add("is-fallback");
      document.documentElement.dataset.gymeraHeroMode = "fallback";
      return;
    }
    document.documentElement.dataset.gymeraHeroMode = "canvas";

    const fills = [[34, 39, 46], [116, 214, 205], [15, 17, 21], [24, 27, 32], [92, 101, 112], [38, 43, 51]];
    const strokes = [[142, 156, 169], [190, 255, 248], [82, 86, 94], [82, 90, 99], [214, 220, 222], [154, 166, 178]];
    let camera = { p: [-0.08, -0.03, 0.04], d: 1.78, yaw: -0.72, pitch: 0.12 };
    let points2d = [];

    const lerp = (a, b, t) => a + (b - a) * t;
    const mix3 = (a, b, t) => [lerp(a[0], b[0], t), lerp(a[1], b[1], t), lerp(a[2], b[2], t)];
    const rgba = (rgb, alpha) => `rgba(${rgb[0]},${rgb[1]},${rgb[2]},${alpha})`;

    const resize = () => {
      const rect = canvas.getBoundingClientRect();
      const dpr = Math.min(2, window.devicePixelRatio || 1);
      canvas.width = Math.max(1, Math.floor(rect.width * dpr));
      canvas.height = Math.max(1, Math.floor(rect.height * dpr));
      context.setTransform(dpr, 0, 0, dpr, 0, 0);
    };

    const project = (point, time) => {
      const target = { p: [-0.08, -0.03, 0.04], d: 1.78, yaw: -0.72 + Math.sin(time * .0002) * .05, pitch: .12 + Math.cos(time * .00016) * .035 };
      camera.p = mix3(camera.p, target.p, .035);
      camera.d = lerp(camera.d, target.d, .035);
      camera.yaw = lerp(camera.yaw, target.yaw, .035);
      camera.pitch = lerp(camera.pitch, target.pitch, .035);

      const cy = Math.cos(camera.yaw);
      const sy = Math.sin(camera.yaw);
      const cp = Math.cos(camera.pitch);
      const sp = Math.sin(camera.pitch);
      const x = point[0] - camera.p[0];
      const y = point[1] - camera.p[1];
      const z = point[2] - camera.p[2];
      const x1 = x * cy - z * sy;
      const z1 = x * sy + z * cy;
      const y1 = y * cp - z1 * sp;
      const z2 = y * sp + z1 * cp;
      const width = canvas.clientWidth;
      const height = canvas.clientHeight;
      const scale = Math.min(width, height) * camera.d;
      const depth = 2.66 + z2;

      return {
        x: width * .66 + (x1 / depth) * scale,
        y: height * .59 - (y1 / depth) * scale,
        z: z2,
        depth,
      };
    };

    const normal = (a, b, c) => {
      const ux = b[0] - a[0];
      const uy = b[1] - a[1];
      const uz = b[2] - a[2];
      const vx = c[0] - a[0];
      const vy = c[1] - a[1];
      const vz = c[2] - a[2];
      const nx = uy * vz - uz * vy;
      const ny = uz * vx - ux * vz;
      const nz = ux * vy - uy * vx;
      const length = Math.hypot(nx, ny, nz) || 1;
      return [nx / length, ny / length, nz / length];
    };

    const drawPath = (poly) => {
      context.beginPath();
      context.moveTo(points2d[poly[0]].x, points2d[poly[0]].y);
      for (let index = 1; index < poly.length; index += 1) {
        context.lineTo(points2d[poly[index]].x, points2d[poly[index]].y);
      }
      context.closePath();
    };

    const draw = (time) => {
      const width = canvas.clientWidth;
      const height = canvas.clientHeight;
      context.clearRect(0, 0, width, height);

      const glow = context.createRadialGradient(width * .62, height * .34, 0, width * .62, height * .34, Math.max(width, height) * .65);
      glow.addColorStop(0, "rgba(218,238,242,.16)");
      glow.addColorStop(.34, "rgba(70,91,98,.07)");
      glow.addColorStop(1, "rgba(0,0,0,0)");
      context.fillStyle = glow;
      context.fillRect(0, 0, width, height);

      points2d = mesh.points.map((point) => project(point, time));
      const polys = mesh.polys
        .map((entry) => [entry, entry[0].reduce((sum, index) => sum + points2d[index].z, 0) / entry[0].length])
        .sort((a, b) => a[1] - b[1]);

      for (const [entry] of polys) {
        const poly = entry[0];
        const tag = entry[1];
        if (poly.some((index) => points2d[index].depth <= .2 || !Number.isFinite(points2d[index].x + points2d[index].y))) continue;
        const n = normal(mesh.points[poly[0]], mesh.points[poly[1]], mesh.points[poly[2]]);
        const key = Math.max(0, n[0] * -.34 + n[1] * .5 + n[2] * .76);
        const rim = Math.pow(Math.max(0, 1 - Math.abs(n[2])), 2.4);
        const base = fills[tag] || fills[0];
        const red = Math.min(255, base[0] + key * 64 + rim * 44);
        const green = Math.min(255, base[1] + key * 64 + rim * 44);
        const blue = Math.min(255, base[2] + key * 68 + rim * 50);
        drawPath(poly);
        context.fillStyle = `rgba(${red | 0},${green | 0},${blue | 0},${tag === 1 ? .7 : .84})`;
        context.fill();
      }

      context.save();
      context.globalCompositeOperation = "lighter";
      context.lineCap = "round";
      for (const edge of mesh.edges) {
        const a = points2d[edge[0]];
        const b = points2d[edge[1]];
        if (a.depth <= .2 || b.depth <= .2) continue;
        const tag = edge[2];
        const depth = Math.max(0, Math.min(1, (a.z + b.z) * .18 + .5));
        context.strokeStyle = rgba(strokes[tag] || strokes[0], tag === 1 ? .34 : .13 + depth * .18);
        context.lineWidth = tag === 1 ? 1.05 : .45;
        context.beginPath();
        context.moveTo(a.x, a.y);
        context.lineTo(b.x, b.y);
        context.stroke();
      }
      context.restore();

      const floor = context.createLinearGradient(0, height * .62, 0, height);
      floor.addColorStop(0, "rgba(122,222,214,0)");
      floor.addColorStop(.72, "rgba(122,222,214,.1)");
      floor.addColorStop(1, "rgba(122,222,214,.18)");
      context.fillStyle = floor;
      context.fillRect(0, height * .62, width, height * .38);

      requestAnimationFrame(draw);
    };

    resize();
    window.addEventListener("resize", resize);
    requestAnimationFrame(draw);
  };

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initGymeraHero, { once: true });
  } else {
    initGymeraHero();
  }
</script>

