---
const base = import.meta.env.BASE_URL;

const projects = [
  {
    number: "01",
    title: "Zahnarztpraxis",
    displayTitle: "Zahnarzt\u00ADpraxis",
    year: "2025",
    type: "Healthcare Website",
    image: `${base}projects/old-zahnarzt.jpg`,
    width: 1000,
    height: 1000,
    href: "https://prokha.webflow.io/works/zahnarztpraxis",
    external: true,
    summary: "Vertrauen, Orientierung und eine ruhige Nutzerführung für eine sensible Entscheidung.",
    contribution: "Konzept · UI Design · Responsive Layout",
  },
  {
    number: "02",
    title: "Panasonic",
    year: "2021",
    type: "Digital Product Campaign",
    image: `${base}projects/panasonic/hero.jpg`,
    width: 1920,
    height: 899,
    href: `${base}projects/panasonic/`,
    summary: "Technologie, Beratung und Rezeptinspiration in einer klaren digitalen Produktwelt.",
    contribution: "Art Direction · Campaign Design · Handoff",
  },
  {
    number: "03",
    title: "Luminarc",
    year: "2020–2021",
    type: "Seasonal Brand Campaigns",
    image: `${base}projects/luminarc/hero.jpg`,
    width: 1920,
    height: 1080,
    href: `${base}projects/luminarc/`,
    summary: "Zwei saisonale Markenwelten, die Produkt, Anwendung und Atmosphäre verbinden.",
    contribution: "Visual Concept · Web Design · Content System",
  },
];

const services = [
  ["01", "Campaign & Landing Pages", "Digitale Kampagnen, die Markenbotschaft und Nutzerführung in eine klare Dramaturgie übersetzen."],
  ["02", "Responsive Web Design", "Strukturierte Websites mit präziser Hierarchie, konsistentem Designsystem und sauberem Mobile-Verhalten."],
  ["03", "Design-to-Launch", "Prototyping, produktionsnahe Layouts und verlässliche Übergabe in enger Zusammenarbeit mit Entwicklungsteams."],
];

const brands = [
  ["panasonic.svg", "Panasonic"],
  ["luminarc.svg", "Luminarc"],
  ["hochland.svg", "Hochland"],
  ["kenwood.svg", "Kenwood"],
  ["brita.svg", "Brita"],
  ["dr.oetker.svg", "Dr. Oetker"],
  ["faberlic.svg", "Faberlic"],
  ["parmalat.svg", "Parmalat"],
];
---

<!doctype html>
<html lang="de">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <meta
      name="description"
      content="Alternative Portfolio-Version von Andrii Prokhorovych, Web Designer und Digital Campaign Designer in Ulm."
    />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Archivo:wght@400;500;600;700;800&family=Space+Grotesk:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <title>Alternative 01 — Andrii Prokhorovych</title>
  </head>
  <body>
    <a class="skip-link" href="#content">Zum Inhalt springen</a>

    <header class="site-header">
      <a class="wordmark" href={`${base}alternative/`} aria-label="Alternative Portfolio Startseite">
        <span>A/</span>PROKHA
      </a>
      <p class="concept-label">Alternative Portfolio · 01</p>
      <nav aria-label="Hauptnavigation">
        <a href="#work">Arbeiten</a>
        <a href="#profile">Profil</a>
        <a href="#contact">Kontakt</a>
      </nav>
      <a class="original-link" href={base}>Original ansehen <span aria-hidden="true">↗</span></a>
    </header>

    <main id="content">
      <section class="hero" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="kicker"><span></span> Web & Campaign Designer · Ulm</p>
          <h1 id="hero-title">
            Digitale Marken brauchen mehr als <em>schöne Seiten.</em>
          </h1>
          <div class="hero-intro">
            <p>
              Ich verbinde klare Nutzerführung, starke visuelle Konzepte und produktionsnahe Umsetzung zu
              digitalen Erlebnissen, die Marken verständlich und relevant machen.
            </p>
            <div class="hero-actions">
              <a class="button button-primary" href="#work">Ausgewählte Arbeiten</a>
              <a class="button button-secondary" href="mailto:prohorovichandrey@gmail.com">Projekt anfragen</a>
            </div>
          </div>
        </div>

        <figure class="hero-portrait">
          <img
            src={`${base}avatar.png`}
            alt="Portrait von Andrii Prokhorovych"
            width="1360"
            height="1100"
            fetchpriority="high"
          />
          <figcaption class="portrait-meta">
            <span>Andrii Prokhorovych</span>
            <span>Verfügbar für ausgewählte Projekte</span>
          </figcaption>
        </figure>

        <dl class="proof" aria-label="Erfahrung in Zahlen">
          <div><dt>Erfahrung</dt><dd>10+ Jahre</dd></div>
          <div><dt>Projekte</dt><dd>70+ Kampagnen</dd></div>
          <div><dt>Marken</dt><dd>40+ Kunden</dd></div>
          <div><dt>Fokus</dt><dd>Design → Launch</dd></div>
        </dl>
      </section>

      <section class="work section" id="work" aria-labelledby="work-title">
        <header class="section-heading">
          <p class="section-index">01 / Selected work</p>
          <div>
            <h2 id="work-title">Drei Projekte.<br />Drei unterschiedliche Aufgaben.</h2>
            <p>
              Nicht die Menge steht im Vordergrund, sondern die Entscheidung hinter dem Design: Kontext
              verstehen, Komplexität reduzieren und eine eigenständige Markenwelt aufbauen.
            </p>
          </div>
        </header>

        <div class="project-list">
          {projects.map((project, index) => (
            <article class={`project project-${index + 1}`}>
              <a
                class="project-media"
                href={project.href}
                target={project.external ? "_blank" : undefined}
                rel={project.external ? "noreferrer" : undefined}
                aria-label={`${project.title} Case Study ansehen`}
              >
                <img
                  src={project.image}
                  alt={`${project.title} Projektvorschau`}
                  width={project.width}
                  height={project.height}
                  loading="lazy"
                  decoding="async"
                />
                <span class="project-open" aria-hidden="true">Case ansehen ↗</span>
              </a>
              <div class="project-info">
                <p class="project-number">{project.number}</p>
                <div>
                  <p class="project-meta">{project.year} · {project.type}</p>
                  <h3>{project.displayTitle ?? project.title}</h3>
                  <p class="project-summary">{project.summary}</p>
                  <p class="project-contribution">{project.contribution}</p>
                </div>
              </div>
            </article>
          ))}
        </div>

        <a class="archive-link" href={base}>
          <span>Weitere Projekte im vollständigen Archiv</span>
          <span aria-hidden="true">→</span>
        </a>
      </section>

      <section class="profile section" id="profile" aria-labelledby="profile-title">
        <header class="section-heading profile-heading">
          <p class="section-index">02 / Profile</p>
          <div>
            <h2 id="profile-title">Erfahrung ist wertvoll, wenn sie Entscheidungen schneller macht.</h2>
          </div>
        </header>

        <div class="profile-grid">
          <p class="profile-lead">
            Seit mehr als zehn Jahren gestalte ich digitale Kampagnen und Websites für Consumer Brands,
            Produkte und Content-Plattformen.
          </p>
          <div class="profile-copy">
            <p>
              Mein Schwerpunkt liegt zwischen visueller Idee und realer Produktion: Ich entwickle Konzepte,
              strukturiere Inhalte, gestalte responsive Interfaces und begleite die Übergabe an Entwickler.
            </p>
            <p>
              So entstehen Lösungen, die nicht nur in einer Präsentation funktionieren, sondern auch im
              Browser, auf kleinen Screens und unter echten Projektbedingungen.
            </p>
            <a href={`${base}cv/andrii-prokhorovych-lebenslauf.pdf`} download>Lebenslauf herunterladen ↘</a>
          </div>
        </div>

        <div class="services" aria-label="Leistungen">
          {services.map(([number, title, description]) => (
            <article>
              <span>{number}</span>
              <h3>{title}</h3>
              <p>{description}</p>
            </article>
          ))}
        </div>
      </section>

      <section class="brands section" aria-labelledby="brands-title">
        <div class="brands-copy">
          <p class="section-index">03 / Selected clients</p>
          <h2 id="brands-title">Marken, für die ich digitale Kommunikation gestaltet habe.</h2>
        </div>
        <ul class="brand-grid" aria-label="Ausgewählte Kunden">
          {brands.map(([file, name]) => (
            <li>
              <img
                src={`${base}brands/logotypes/${encodeURIComponent(file)}`}
                alt={name}
                loading="lazy"
                decoding="async"
              />
            </li>
          ))}
        </ul>
      </section>

      <section class="contact section" id="contact" aria-labelledby="contact-title">
        <p class="section-index">04 / Contact</p>
        <div class="contact-main">
          <h2 id="contact-title">Lassen Sie uns über das nächste digitale Projekt sprechen.</h2>
          <a class="contact-mail" href="mailto:prohorovichandrey@gmail.com">
            prohorovichandrey@gmail.com <span aria-hidden="true">↗</span>
          </a>
        </div>
        <footer>
          <p>Andrii Prokhorovych · Web & Campaign Designer · Ulm</p>
          <div>
            <a href="https://www.linkedin.com/in/andrii-prokhorovych-216846204" target="_blank" rel="noreferrer">LinkedIn</a>
            <a href={base}>Original Portfolio</a>
          </div>
        </footer>
      </section>
    </main>
  </body>
</html>

<style>
  :root {
    color-scheme: light;
    --bg: #fafafa;
    --paper: #ffffff;
    --ink: #09090b;
    --muted: #5b5b63;
    --line: #d9d9df;
    --accent: #2457f5;
    --accent-dark: #173bb6;
    --soft: #eef1ff;
    --display: "Archivo", Arial, sans-serif;
    --body: "Space Grotesk", Arial, sans-serif;
  }

  * { box-sizing: border-box; }

  html { scroll-behavior: smooth; }

  body {
    margin: 0;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--body);
    -webkit-font-smoothing: antialiased;
  }

  a { color: inherit; text-decoration: none; }
  img { display: block; max-width: 100%; }
  p, h1, h2, h3, dl, dd { margin: 0; }

  .skip-link {
    background: var(--ink);
    color: white;
    left: 16px;
    padding: 12px 16px;
    position: fixed;
    top: 16px;
    transform: translateY(-180%);
    z-index: 100;
  }

  .skip-link:focus { transform: translateY(0); }

  :focus-visible {
    outline: 3px solid var(--accent);
    outline-offset: 4px;
  }

  .site-header {
    align-items: center;
    background: rgba(250, 250, 250, 0.94);
    border-bottom: 1px solid var(--line);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto auto auto;
    min-height: 72px;
    padding: 0 clamp(20px, 4vw, 64px);
    position: sticky;
    top: 0;
    z-index: 20;
    backdrop-filter: blur(16px);
  }

  .wordmark {
    font-family: var(--display);
    font-size: 24px;
    font-weight: 800;
    letter-spacing: -0.05em;
  }

  .wordmark span { color: var(--accent); }

  .concept-label {
    color: var(--muted);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  nav { display: flex; gap: 28px; }
  nav a, .original-link { font-size: 13px; font-weight: 600; }
  nav a, .original-link, .archive-link, .profile-copy a { transition: color 180ms ease; }
  nav a:hover, .original-link:hover, .profile-copy a:hover { color: var(--accent); }

  .original-link {
    align-items: center;
    border-left: 1px solid var(--line);
    display: flex;
    gap: 10px;
    min-height: 72px;
    padding-left: 28px;
  }

  .hero {
    --hero-bottom-gap: clamp(44px, 6vw, 80px);
    display: grid;
    grid-template-columns: minmax(0, 1.45fr) minmax(320px, 0.55fr);
    min-height: calc(100svh - 72px);
    padding: clamp(48px, 6vw, 96px) clamp(20px, 4vw, 64px) 0;
  }

  .hero-copy {
    align-content: space-between;
    border-right: 1px solid var(--line);
    display: grid;
    padding: 0 clamp(28px, 5vw, 80px) var(--hero-bottom-gap) 0;
  }

  .kicker, .section-index {
    color: var(--muted);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.09em;
    text-transform: uppercase;
  }

  .kicker { align-items: center; display: flex; gap: 10px; }
  .kicker span { background: var(--accent); border-radius: 50%; height: 8px; width: 8px; }

  h1, h2, h3 {
    font-family: var(--display);
    hyphens: auto;
    overflow-wrap: normal;
    word-break: normal;
    -webkit-hyphens: auto;
  }

  h1 {
    font-size: clamp(52px, 7.4vw, 126px);
    font-weight: 600;
    letter-spacing: -0.065em;
    line-height: 0.9;
    margin: clamp(56px, 9vh, 120px) 0 64px;
    max-width: 1320px;
  }

  h1 em {
    color: var(--accent);
    display: block;
    font-style: normal;
    font-weight: 500;
  }

  .hero-intro {
    align-items: end;
    display: grid;
    gap: 32px;
    grid-template-columns: minmax(260px, 560px) auto;
  }

  .hero-intro > p {
    font-size: clamp(18px, 1.45vw, 24px);
    line-height: 1.5;
  }

  .hero-actions { display: flex; flex-wrap: wrap; gap: 10px; justify-content: flex-end; }

  .button {
    align-items: center;
    border: 1px solid var(--ink);
    display: inline-flex;
    font-size: 13px;
    font-weight: 600;
    justify-content: center;
    min-height: 48px;
    padding: 0 20px;
    transition: background 180ms ease, color 180ms ease, border-color 180ms ease;
  }

  .button-primary { background: var(--ink); color: white; }
  .button-primary:hover { background: var(--accent); border-color: var(--accent); }
  .button-secondary:hover { background: var(--ink); color: white; }

  .hero-portrait {
    align-self: stretch;
    background: var(--bg);
    display: grid;
    grid-template-rows: minmax(0, 1fr) auto;
    margin: 0;
    min-height: 0;
    overflow: hidden;
    padding-bottom: var(--hero-bottom-gap);
  }

  .hero-portrait img {
    filter: grayscale(1) contrast(1.06);
    height: 100%;
    min-height: 540px;
    mix-blend-mode: multiply;
    object-fit: cover;
    object-position: 54% bottom;
    width: 100%;
  }

  .portrait-meta {
    align-items: center;
    background: var(--accent);
    border-top: 0;
    color: white;
    display: flex;
    font-size: 10px;
    font-weight: 600;
    justify-content: space-between;
    letter-spacing: 0.06em;
    min-height: 48px;
    padding: 0 14px;
    text-transform: uppercase;
  }

  .proof {
    align-self: end;
    border-top: 1px solid var(--line);
    display: grid;
    grid-column: 1 / -1;
    grid-template-columns: repeat(4, 1fr);
  }

  .proof div { border-right: 1px solid var(--line); padding: 22px 20px 24px 0; }
  .proof div:not(:first-child) { padding-left: 20px; }
  .proof div:last-child { border-right: 0; }
  .proof dt { color: var(--muted); font-size: 11px; margin-bottom: 8px; text-transform: uppercase; }
  .proof dd { font-family: var(--display); font-size: clamp(18px, 2vw, 28px); font-weight: 600; letter-spacing: -0.04em; }

  .section {
    border-top: 1px solid var(--line);
    padding: clamp(80px, 10vw, 150px) clamp(20px, 4vw, 64px);
  }

  .section-heading {
    display: grid;
    gap: 32px;
    grid-template-columns: minmax(180px, 0.33fr) minmax(0, 1fr);
    margin-bottom: clamp(64px, 8vw, 120px);
  }

  .section-heading > div {
    align-items: end;
    display: grid;
    gap: 28px;
    grid-template-columns: minmax(0, 1fr) minmax(260px, 0.45fr);
  }

  h2 {
    font-size: clamp(40px, 5.4vw, 86px);
    font-weight: 600;
    letter-spacing: -0.055em;
    line-height: 0.98;
  }

  .section-heading > div > p {
    color: var(--muted);
    font-size: 17px;
    line-height: 1.6;
    max-width: 540px;
  }

  .project-list { display: grid; gap: clamp(80px, 10vw, 160px); }

  .project {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, 1.5fr) minmax(280px, 0.5fr);
  }

  .project-2 { grid-template-columns: minmax(280px, 0.55fr) minmax(0, 1.45fr); }
  .project-2 .project-media { grid-column: 2; }
  .project-2 .project-info { grid-column: 1; grid-row: 1; }

  .project-media { background: #e9e9ec; display: block; overflow: hidden; position: relative; }
  .project-media img { aspect-ratio: 16 / 9; height: 100%; object-fit: cover; transition: transform 350ms ease; width: 100%; }
  .project-1 .project-media img { aspect-ratio: 16 / 10; object-position: center 24%; }
  .project-media:hover img { transform: scale(1.018); }

  .project-open {
    background: var(--accent);
    bottom: 0;
    color: white;
    font-size: 12px;
    font-weight: 600;
    padding: 14px 18px;
    position: absolute;
    right: 0;
    transform: translateY(100%);
    transition: transform 220ms ease;
  }

  .project-media:hover .project-open, .project-media:focus-visible .project-open { transform: translateY(0); }

  .project-info { border-top: 1px solid var(--ink); display: grid; gap: 20px; grid-template-columns: 44px 1fr; padding-top: 16px; }
  .project-info > div { min-width: 0; }
  .project-number, .project-meta, .project-contribution { color: var(--muted); font-size: 11px; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase; }
  .project-info h3 { font-size: clamp(34px, 4vw, 64px); letter-spacing: -0.055em; line-height: 1; margin: 18px 0 24px; }
  .project-summary { font-size: 17px; line-height: 1.55; max-width: 480px; }
  .project-contribution { border-top: 1px solid var(--line); margin-top: 30px; padding-top: 14px; }

  .archive-link {
    align-items: center;
    border-bottom: 1px solid var(--ink);
    display: flex;
    font-family: var(--display);
    font-size: clamp(22px, 3vw, 42px);
    font-weight: 600;
    justify-content: space-between;
    margin-top: clamp(80px, 10vw, 150px);
    padding-bottom: 18px;
  }

  .archive-link:hover { color: var(--accent); }

  .profile { background: var(--ink); color: white; }
  .profile .section-index { color: #96969e; }
  .profile-heading > div { display: block; }
  .profile-heading h2 { max-width: 1120px; }

  .profile-grid {
    border-top: 1px solid #35353a;
    display: grid;
    gap: 48px;
    grid-template-columns: 1fr 1fr;
    padding-top: 42px;
  }

  .profile-lead { font-family: var(--display); font-size: clamp(28px, 3.3vw, 52px); letter-spacing: -0.04em; line-height: 1.12; }
  .profile-copy { max-width: 650px; }
  .profile-copy p { color: #b8b8c0; font-size: 18px; line-height: 1.65; margin-bottom: 22px; }
  .profile-copy a { border-bottom: 1px solid white; display: inline-block; font-weight: 600; margin-top: 18px; padding-bottom: 7px; }
  .profile-copy a:hover { color: #8ca7ff; }

  .services { display: grid; gap: 1px; grid-template-columns: repeat(3, 1fr); margin-top: clamp(80px, 10vw, 140px); }
  .services article { border: 1px solid #35353a; margin-right: -1px; padding: 28px; }
  .services span { color: #8ca7ff; font-size: 12px; }
  .services h3 { font-size: clamp(22px, 2vw, 31px); letter-spacing: -0.035em; margin: 70px 0 20px; }
  .services p { color: #a9a9b2; line-height: 1.6; }

  .brands { display: grid; gap: 64px; grid-template-columns: minmax(260px, 0.55fr) minmax(0, 1.45fr); }
  .brands-copy h2 { font-size: clamp(34px, 4vw, 62px); margin-top: 32px; }
  .brand-grid { display: grid; grid-template-columns: repeat(4, 1fr); list-style: none; margin: 0; padding: 0; }
  .brand-grid li { align-items: center; border: 1px solid var(--line); display: flex; justify-content: center; margin: 0 -1px -1px 0; min-height: 150px; padding: 28px; }
  .brand-grid img { filter: grayscale(1); max-height: 46px; max-width: 130px; opacity: 0.7; width: 100%; }

  .contact { background: var(--accent); color: white; padding-bottom: 32px; }
  .contact .section-index { color: #dbe3ff; }
  .contact-main { align-items: end; display: grid; gap: 40px; grid-template-columns: minmax(0, 1.4fr) minmax(280px, 0.6fr); margin: clamp(60px, 9vw, 130px) 0; }
  .contact h2 { font-size: clamp(48px, 7vw, 112px); max-width: 1200px; }
  .contact-mail { border-bottom: 1px solid white; display: flex; font-size: clamp(16px, 1.5vw, 22px); justify-content: space-between; overflow-wrap: anywhere; padding-bottom: 14px; }
  .contact footer { border-top: 1px solid rgba(255, 255, 255, 0.45); display: flex; font-size: 12px; justify-content: space-between; padding-top: 24px; }
  .contact footer div { display: flex; gap: 28px; }
  .contact a:hover { color: #dbe3ff; }

  @media (max-width: 1050px) {
    .concept-label { display: none; }
    .site-header { grid-template-columns: 1fr auto auto; }
    .hero { grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr); }
    .hero-intro { align-items: start; grid-template-columns: 1fr; }
    .hero-actions { justify-content: flex-start; }
    .section-heading > div { align-items: start; grid-template-columns: 1fr; }
    .project, .project-2 { grid-template-columns: minmax(0, 1.2fr) minmax(240px, 0.8fr); }
    .brand-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 760px) {
    .site-header { grid-template-columns: 1fr auto; min-height: 64px; }
    nav { display: none; }
    .original-link { min-height: 64px; padding-left: 18px; }
    .hero { display: flex; flex-direction: column; min-height: auto; padding-top: 40px; }
    .hero-copy { border-right: 0; display: block; padding: 0 0 42px; }
