---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/gymera`;

const facts = [
  ["Projekt", "Gymera"],
  ["Bereich", "Fitness Tech"],
  ["Jahr", "2025"],
  ["Rolle", "Product Story, Website System, Visual Direction"],
];

const highlights = [
  ["Vom schwachen Ausgangsmaterial zur Marke", "Ich habe ein nicht praesentables chinesisches Produktumfeld in eine europaeische Fitness-Tech-Story uebersetzt."],
  ["Segmentierte Produktstory", "Die Website zeigt Gymera nicht als einzelnes Geraet, sondern als System fuer Home, Hotels, Offices, Clubs, Trainer und Rehabilitation."],
  ["KI als Verkaufsargument", "AI Mirror, Training Control, Dashboard und App-Screens machen sichtbar, warum das Produkt mehr als ein klassischer Trainer ist."],
];

const quickRead = [
  ["Aufgabe", "Ein chinesisches KI-Fitnessgeraet ohne physisches Muster fuer den europaeischen Markt glaubwuerdig positionieren."],
  ["Mein Beitrag", "Research, visuelle Rekonstruktion, europaeische Bildsprache, Website-Architektur, Segment-Landingpages, AI-Story und Service-Map."],
  ["Ergebnis", "Aus verstreuten Quellen wurde eine verkaufbare Produktwelt: Marke, Use Cases, App-Logik, Dealer-CTA und europaeische Vertriebsstruktur."],
  ["Warum relevant", "Der Case zeigt, dass ich nicht nur Oberflaechen gestalte, sondern ein unklares Produkt in eine nachvollziehbare Marktstory uebersetze."],
];

const contribution = [
  ["01", "Research", "Ich habe oeffentlich verfuegbares Material gesammelt, sortiert und als Basis fuer eine neue europaeische Produktkommunikation genutzt."],
  ["02", "Visual Direction", "Ich habe das Geraet mit 3D, Photobashing und AI-generierten Szenen in hochwertigere Kontexte uebersetzt."],
  ["03", "Website-System", "Ich habe aus einem einzelnen Produkt mehrere Zielgruppenpfade gebaut: Home, Office, Hotel, Club, Trainer und Reha."],
  ["04", "AI & Service", "Ich habe AI-Funktionen, Brand Story, Dealer-CTA und europaeische Showroom-Logik als verkaufsrelevante Module gedacht."],
];

const productSections = [
  ["Home Fitness", "Privates Training mit platzsparendem Setup und persoenlicher Steuerung."],
  ["Hotel Fitness", "Premium-Fitness als Service fuer Gaeste ohne grossen Raumaufwand."],
  ["Corporate Fitness", "Gesundheit und Bewegung im Arbeitsalltag mit messbarem Nutzen."],
  ["Personal Trainer", "Ein System fuer individuelle Betreuung und skalierbare Trainingsplaene."],
  ["Rehabilitation", "Programme fuer Erholung, Aufbau und kontrollierte Bewegung."],
];

const metrics = [
  ["67%", "weniger Platzbedarf"],
  ["90%", "Funktionen abgedeckt"],
  ["1000+", "Workouts"],
  ["24/7", "digitale Betreuung"],
];

const tokens = [
  ["Primary", "#9f5cff"],
  ["Electric", "#3189ff"],
  ["Signal", "#98ff44"],
  ["Ink", "#05070a"],
  ["Cloud", "#edf5ff"],
  ["Line", "#d8e2ef"],
];

const productProof = [
  ["Kein Produkt vor Ort", "Es gab kein physisches Geraet fuer ein eigenes Shooting. Die Produktwirkung musste aus vorhandenen Referenzen rekonstruiert werden."],
  ["Visuelle Uebersetzung", "Graphit, schwarzer Screen, aqua Glas und kontrollierte Studio-Lichter bilden die Bruecke zwischen chinesischer Quelle, 3D und europaeischer Website."],
  ["Website-ready story", "Die Produktinszenierung funktioniert als Hero, Motion-Clip, WebGL/canvas Szene und als Beweis fuer eine hochwertigere Markenrichtung."],
];

const caseFlow = [
  ["01", "Ausgangslage", "Der Kunde wollte das chinesische KI-Trainingsgeraet als Partner oder Distributor in Europa verkaufen."],
  ["02", "Problem", "Es gab kein eigenes Geraet, kein Shooting und nur schwaches Originalmaterial aus chinesischen Produktquellen."],
  ["03", "Strategie", "Ich habe Material recherchiert, neu inszeniert und daraus eine europaeische Premium-Fitness-Tech-Erzaehlung gebaut."],
  ["04", "System", "Website, Segmentseiten, AI-Funktionen, Brand Story, Service-Map und Dealer-CTA wurden als ein Vertriebsprodukt gedacht."],
];

const briefCards = [
  ["Business context", "Der Kunde wollte ein bestehendes chinesisches AI-Fitnessgeraet nach Europa bringen und als lokaler Partner, Distributor oder Dealer auftreten."],
  ["Main constraint", "Das Geraet war nicht verfuegbar. Es gab kein eigenes Fotoshooting, keine europaeischen Lifestyle-Bilder und nur begrenzt belastbare Produktassets."],
  ["Design challenge", "Meine Aufgabe war, aus offenen Quellen, 3D/AI-Visuals und Figma-Frames eine praesentable europaeische Produktwelt zu bauen."],
  ["Hiring signal", "Der Case zeigt Research, Art Direction, Informationsarchitektur und Business-Denken unter realen Constraints."],
];

const sourceStrategy = [
  ["01 Audit", "Ich habe vorhandene chinesische Website- und Produktmaterialien geprueft: Was ist brauchbar, was wirkt billig, was muss neu erzaehlt werden?"],
  ["02 Rebuild", "Produkt, Details und Raumsituationen wurden mit 3D, Retusche, Photobashing und AI-generierten Erweiterungen in bessere Kompositionen gebracht."],
  ["03 Europeanize", "Die Bildwelt wurde auf europaeische Zielgruppen, helle Wohnraeume, Offices, Hotels, Reha-Kontexte und Premium-Fitness ausgerichtet."],
  ["04 Sell", "Jede Seite fuehrt auf ein Geschaeftsziel: Interesse wecken, Segment erklaeren, Vertrauen schaffen und zum Dealer-Kontakt fuehren."],
];

const immersionIdeas = [
  ["Immersion statt Pflichttraining", "Gymera sollte sich nicht wie ein weiterer Fitnessapparat anfuehlen, sondern wie ein Einstieg in einen Trainingszustand."],
  ["Surreale Trainingswelten", "Yoga in einer Wasserlilien-Landschaft oder Rudern wie in einem Kajak-Setting waren bewusste Bildcodes fuer Fokus, Flow und mentale Flucht aus dem Raum."],
  ["AI als Begleiter", "Der Nutzer trainiert nicht allein: Analyse, Korrektur, Programmvorschlaege und Fortschritt werden als digitaler Coach inszeniert."],
];

const figmaScreens = [
  ["Product functions", "figma-functions.jpg", "center center", "Funktionsseite fuer Platzersparnis, Geraetesteuerung, technische Daten und Vergleich zum Fitnessstudio."],
  ["AI functions", "figma-ai-functions.jpg", "center center", "AI Mirror, Echtzeit-Analyse, Fitnessprogramm, Dokumentation und Ernaehrungsplan als eigene Produktlogik."],
  ["Training control", "figma-training-control.jpg", "bottom center", "Realtime-Metriken, Leistungsfeedback und adaptive Trainingsdaten als visuelle Interface-Sprache."],
];

const rescueSlides = [
  ["Open view", "product-views/open.png"],
  ["Closed view", "product-views/closed.png"],
  ["Side view", "product-views/side.png"],
];

const featureBridgeSlides = [
  ["Feature bridge 1", "feature-bridge/bridge-1.jpg"],
  ["Feature bridge 2", "feature-bridge/bridge-2.jpg"],
  ["Feature bridge 3", "feature-bridge/bridge-3.jpg"],
];

const einsatzSlides = [
  ["House Fitness", "einsatzbereiche/house-fitness.jpg"],
  ["Hotel Fitness", "einsatzbereiche/hotel-fitness.jpg"],
  ["Office Fitness", "einsatzbereiche/office-fitness.jpg"],
  ["Personal Trainer", "einsatzbereiche/personal-trainer.jpg"],
  ["Rehabilitation", "einsatzbereiche/rehabilitation.jpg"],
];

const usageV1Slides = [
  ["Home", "usage-v1/slide-1.jpg"],
  ["Hotel", "usage-v1/slide-2.jpg"],
  ["Corporate", "usage-v1/slide-3.jpg"],
  ["Trainer", "usage-v1/slide-4.jpg"],
];

const usageV2Slides = [
  ["Home", "usage-v2/slide-1.jpg"],
  ["Country house", "usage-v2/slide-2.jpg"],
  ["Office", "usage-v2/slide-3.jpg"],
  ["Gym", "usage-v2/slide-4.jpg"],
  ["Yacht", "usage-v2/slide-5.jpg"],
  ["Premium estate", "usage-v2/slide-6.jpg"],
];

const coverageSlides = [
  ["Europe", "coverage-new/europa.svg"],
  ["Germany", "coverage-new/germany.svg"],
  ["France", "coverage-new/france.svg"],
  ["Belgium", "coverage-new/belgium.svg"],
  ["Italy", "coverage-new/italy.svg"],
  ["Showrooms", "coverage-new/showrooms-europa.svg"],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Gymera Fitness Tech Case Study - Product Website, App UI und Design Kit von Andrii Prokhorovych." />
    <title>Gymera Product Design - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base} data-case-nav-trigger aria-controls="case-sidebar" aria-expanded="false">
        <span>PROKHA</span>
      </a>
      <a class="back-link" href={`${base}#work`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=gymera`}>Редактировать</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar" id="case-sidebar" data-case-sidebar>
        <div>
          <p class="eyebrow">Case Study · 2025</p>
          <div class="gymera-mark" aria-label="Gymera">
            <img src={`${media}/logo.svg`} alt="Gymera logo" />
          </div>
          <h1>Fitness-Technologie als Produkt, App und Designsystem</h1>
          <p class="intro">
            Ein Portfolio-Case fuer Gymera: Produktwebsite, erste App-Screens, Dashboard,
            mobile Experience und ein kompakter Styleguide in einer zusammenhaengenden Story.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Website</a>
          <a href="#beitrag">02 Beitrag</a>
          <a href="#produkt">03 Produkt</a>
          <a href="#app">04 App UI</a>
          <a href="#kit">05 Design Kit</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div
            class="hero-media hero-sequence"
            data-gymera-sequence
          >
            <div class="hero-sequence-bg" aria-hidden="true"></div>
            <img class="hero-sequence-logo" src={`${media}/logo.svg`} alt="" loading="eager" aria-hidden="true" />
            <video class="hero-sequence-video" autoplay muted loop playsinline preload="auto" poster={`${media}/blender-renders/gymera-turntable-transparent-frames/frame_0001.png`}>
              <source src={`${media}/blender-renders/gymera-turntable-transparent-alpha.webm`} type="video/webm" />
            </video>
            <img
              class="hero-sequence-frame"
              src={`${media}/blender-renders/gymera-turntable-transparent-frames/frame_0001.png`}
              alt="Gymera 3D Produktsequenz mit rotierendem Trainingsgeraet"
              loading="eager"
              decoding="async"
            />
            <div class="hero-sequence-copy">
              <span class="hero-sequence-kicker">Fitness Tech · Product Experience</span>
              <h2>Aus einem chinesischen Trainingsgeraet wird eine europaeische Produktstory</h2>
              <p>
                Der Kunde wollte ein AI-Fitnessgeraet aus China in Europa verkaufen. Das Problem:
                kein physisches Produkt, kein eigenes Shooting, nur ein wenig praesentabler Originalauftritt.
                Meine Aufgabe war, daraus eine glaubwuerdige Marke, Website-Struktur und visuelle Welt
                fuer europaeische Kunden zu bauen.
              </p>
            </div>
            <span class="hero-sequence-caption">PNG sequence · transparent render · graphite hardware · aqua glass</span>
          </div>
        </section>

        <section class="brief-section" aria-labelledby="brief-title">
          <div class="section-copy">
            <p class="eyebrow">Real brief</p>
            <h2 id="brief-title">Die eigentliche Aufgabe war nicht nur Design, sondern Produkt-Uebersetzung</h2>
            <p>
              Gymera war zu diesem Zeitpunkt weniger ein fertiger europaeischer Brand als eine
              Business-Idee: ein bestehendes AI-Trainingsgeraet sollte in Europa vertrieben werden.
              Ich musste also nicht nur eine Oberflaeche gestalten, sondern erst einmal zeigen,
              warum dieses Produkt fuer europaeische Nutzer, Hotels, Offices, Trainer und Reha-Zentren
              interessant sein koennte.
            </p>
          </div>
          <div class="brief-grid">
            {briefCards.map(([title, text]) => (
              <article>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="product-render-section" aria-labelledby="product-render-title">
          <div class="section-copy">
            <p class="eyebrow">Asset rescue</p>
            <h2 id="product-render-title">Aus schwachen Quellen wurde eine praesentable Produktwelt</h2>
            <p>
              Weil kein eigenes Produkt fuer Foto oder Video verfuegbar war, habe ich das vorhandene
              Material wie ein Rohmaterial behandelt: recherchieren, auswaehlen, nachbauen, retuschieren
              und in eine wertigere Bildsprache uebersetzen. 3D, Photobashing und AI-Erweiterungen
              halfen zuerst, das Geraet selbst sauber zu zeigen: offen, geschlossen und seitlich,
              ohne Modelle oder Lifestyle-Kontext.
            </p>
          </div>

          <figure class="rescue-showcase">
            <div class="auto-slider rescue-slider">
              {rescueSlides.map(([label, image]) => (
                <img src={`${media}/${image}`} alt={`Gymera visual reconstruction: ${label}`} loading="lazy" />
              ))}
            </div>
            <figcaption>Asset rescue · Produktansichten auf weissem Grund: offen, geschlossen und seitlich</figcaption>
          </figure>

          <div class="proof-grid product-proof">
            {productProof.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="source-strategy-section" aria-labelledby="source-strategy-title">
          <div class="section-copy">
            <p class="eyebrow">Process</p>
            <h2 id="source-strategy-title">Wie ich aus offenen Quellen ein verkaufbares System gebaut habe</h2>
            <p>
              Die wichtigste Designleistung lag im Kuratieren und Uebersetzen: Was aus China kam,
              musste nicht nur schoener werden, sondern fuer den europaeischen Markt anders argumentieren.
              Deshalb wurde aus einem Produkt eine modulare Website mit Use Cases, AI-Vorteilen,
              Brand Story, Service-Logik und Dealer-Kontakt.
            </p>
          </div>
          <div class="source-grid">
            {sourceStrategy.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="reel-section" aria-labelledby="reel-title">
          <div class="section-copy">
            <p class="eyebrow">Visual concept</p>
            <h2 id="reel-title">Training sollte sich wie Eintauchen anfuehlen, nicht wie Pflichtprogramm</h2>
            <p>
              Ein Teil der Bildwelt war bewusst weniger dokumentarisch und mehr atmosphaerisch:
              Wasser, Licht, Yoga, Rudern, konzentrierte Koerperhaltung. Die Idee dahinter:
              Gymera verkauft nicht nur Bewegung, sondern den Moment, in dem man den Raum vergisst
              und in den Trainingsprozess eintaucht.
            </p>
          </div>
          <div class="reel-frame">
            <video controls preload="metadata" poster={`${media}/customer-overview.png`}>
              <source src={`${media}/reel-preview.mp4`} type="video/mp4" />
            </video>
            <span>Remotion Preview · Gymera Product Story Reel</span>
          </div>
          <div class="immersion-grid">
            {immersionIdeas.map(([title, text]) => (
              <article>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="flow-section" aria-labelledby="flow-title">
          <div class="section-copy">
            <p class="eyebrow">Case Aufbau</p>
            <h2 id="flow-title">Die Story fuehrt von Hardware zu Interface</h2>
            <p>
              Der Case ist so aufgebaut, dass Recruiter oder Kunden den Denkprozess schnell
              erkennen: erst Produkt und Kontext, dann die visuelle Richtung, danach Website,
              App-Logik und Designsystem.
            </p>
          </div>
          <div class="flow-grid">
            {caseFlow.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="figma-system-section" aria-labelledby="figma-system-title">
          <div class="section-copy">
            <p class="eyebrow">Figma Screens</p>
            <h2 id="figma-system-title">Aus der Produktidee wurde eine Website-Architektur</h2>
            <p>
              Die Website war nicht als einfache Landingpage gedacht. Sie sollte Home, Produkt,
              KI-Funktionen, Training Control, Use Cases, Brand Story, Service, Kaufen und Showrooms
              verbinden. So wird aus einem importierten Geraet ein europaeisches Vertriebsprodukt
              mit mehreren Einstiegen fuer unterschiedliche Zielgruppen.
            </p>
          </div>

          <figure class="context-frame">
            <img src={`${media}/figma-gym-context.jpg`} alt="Gymera in einem hellen Fitnessraum als Einsatzkontext" loading="lazy" />
            <figcaption>Context frame · gym environment and product placement</figcaption>
          </figure>

          <figure class="homepage-scroll-frame">
            <div class="homepage-scroll-window">
              <img src={`${media}/figma-home.jpg`} alt="Gymera homepage system scrolling from hero to footer" loading="eager" />
            </div>
            <figcaption>Homepage system · automatischer Scroll vom Einstieg bis zum Seitenende</figcaption>
          </figure>

          <div class="figma-screen-grid">
            {figmaScreens.map(([title, image, position, text]) => (
              <figure>
                <img src={`${media}/${image}`} alt={`Gymera Figma screen: ${title}`} loading="lazy" style={`--screen-position: ${position}`} />
                <figcaption>
                  <strong>{title}</strong>
                  <span>{text}</span>
                </figcaption>
              </figure>
            ))}
          </div>

          <figure class="context-frame product-stage-frame">
            <img src={`${media}/figma-product-stage.jpg`} alt="Gymera Produktinszenierung mit dunklem Studio-Look und Interface-Screen" loading="lazy" />
            <figcaption>Product stage · dark render direction and interface atmosphere</figcaption>
          </figure>
        </section>

        <section class="brand-map-section" aria-labelledby="brand-map-title">
          <div class="section-copy">
            <p class="eyebrow">Brand and IA</p>
            <h2 id="brand-map-title">Nicht nur Gymera, sondern auch der Brand des Distributors</h2>
            <p>
              Neben dem Produkt brauchte die Seite auch Vertrauen in den europaeischen Anbieter:
              Wer verkauft das Geraet, warum ist er Partner, wie kam das Produkt vom Prototyp zur
              Umsetzung und wo kann man Beratung bekommen? Logo, Farben und Sitemap zeigen diese
              zweite Ebene: Produktmarke plus Anbieter-Story.
            </p>
          </div>

          <div class="brand-color-stage">
            <img src={`${media}/brandcolor.svg`} alt="Gymera Brandcolor Figma board" loading="lazy" />
            <p>Brendcolor.svg zeigt die visuelle Spannweite: dunkles Tech-Fundament, Electric Blue, Gruen fuer Aktivitaet und violette CTA-Flächen. Der Block bleibt dunkel, damit die Farben wie eine Produktbuehne wirken, aber die Farbtafeln selbst stehen auf einer hellen Flaeche und bleiben lesbar.</p>
          </div>

          <div class="brand-story-grid">
            <figure class="brand-artifact value-artifact">
              <img src={`${media}/value-infographic.svg`} alt="Gymera values infographic developed for brand communication" loading="eager" />
            </figure>
            <figure class="brand-artifact history-artifact">
              <img src={`${media}/brand-history.svg`} alt="Gymera brand history and product evolution visual" loading="eager" />
            </figure>
          </div>

          <figure class="map-pan-frame">
            <div class="map-pan-track">
              <img src={`${media}/map.svg`} alt="Gymera sitemap map showing page structure and content routes" loading="eager" />
              <img src={`${media}/map.svg`} alt="" loading="eager" aria-hidden="true" />
            </div>
            <figcaption>Map.svg · Sitemap, Seitenlogik und Navigationsarchitektur fuer die Produktwebsite</figcaption>
          </figure>
        </section>

        <section class="interlude-section" aria-label="Visuelle Trennbilder">
          <figure class="interlude-poster interlude-poster-main">
            <img src={`${media}/interlude-1.jpg`} alt="Atmosphaerische Gymera Yoga-Visualisierung" loading="lazy" />
            <video autoplay muted loop playsinline preload="metadata">
              <source src={`${media}/interlude-video-small.mp4`} type="video/mp4" />
            </video>
            <figcaption>Kleinen Motion Einsatz · bewusst klein gehalten wegen Source-Qualitaet</figcaption>
          </figure>
          <figure class="feature-bridge-stage">
            <div class="auto-slider feature-bridge-slider instant-three-slider">
              {featureBridgeSlides.map(([label, image]) => (
                <img src={`${media}/${image}`} alt={`Gymera feature bridge: ${label}`} loading="lazy" />
              ))}
            </div>
            <figcaption>Feature bridge · drei kompakte Uebergangsvarianten fuer Produktvorteile</figcaption>
          </figure>
        </section>

        <section class="usage-comparison-section" aria-labelledby="usage-comparison-title">
          <div class="section-copy">
            <p class="eyebrow">Segment strategy</p>
            <h2 id="usage-comparison-title">Use Cases als Einstieg in innere Landingpages</h2>
            <p>
              Ein wichtiger Teil der Website war die Frage: Wo kann man diesen Trainer ueberhaupt
              einsetzen? Deshalb plante ich innere Seiten fuer Home, Hotels, Offices, Fitnessclubs,
              Trainer, Reha und weitere Premium-Kontexte. Der Block sollte Besucher nicht nur
              inspirieren, sondern sie in den passenden Zielgruppenpfad fuehren.
            </p>
          </div>

          <div class="einsatz-layout">
            <div class="auto-slider einsatz-slider instant-five-slider">
              {einsatzSlides.map(([label, image]) => (
                <img src={`${media}/${image}`} alt={`Gymera Einsatzbereiche page: ${label}`} loading="eager" />
              ))}
            </div>
            <div class="einsatz-copy">
              <span>Final direction</span>
              <h3>Fuenf Segmentseiten statt einer allgemeinen Produktseite</h3>
              <p>
                Am Ende fuehrte die Website in fuenf klare Zielgruppenpfade:
                House Fitness, Hotel Fitness, Office Fitness, Personal Trainer und Rehabilitation.
                Diese Seiten und ihr visueller Stil wurden als eigene, von mir entwickelte
                Einsatzbereiche aufgebaut.
              </p>
            </div>
          </div>
        </section>

        <section class="coverage-section" aria-labelledby="coverage-title">
          <div class="section-copy">
            <p class="eyebrow">Sales coverage</p>
            <h2 id="coverage-title">Sales Coverage als Vertrauenslayer</h2>
            <p>
              Der Coverage-Slider zeigt, dass Gymera nicht nur als einzelnes Geraet gedacht ist,
              sondern als europaeisches Vertriebs- und Showroom-System. Die Karten koennen im
              Produktcase erklaeren, wo Beratung, Testtraining und regionale Praesenz stattfinden.
            </p>
          </div>
          <div class="coverage-showroom-stage">
            <div class="auto-slider coverage-slider">
              {coverageSlides.map(([label, image]) => (
                <img src={`${media}/${image}`} alt={`Gymera sales coverage: ${label}`} loading="eager" />
              ))}
            </div>
          </div>
        </section>

        <section class="quick-read" aria-label="5-second portfolio read">
          <div class="section-copy">
