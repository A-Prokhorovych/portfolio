---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/maguro-2018`;

const facts = [
  ["Kunde", "Maguro"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2018"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Drei Säulen eines Lebensstils", "Ernährung, Bewegung und Motivation bilden eine ganzheitliche Struktur statt einer rein produktbezogenen Kampagne."],
  ["Umfangreiche Seafood-Küche", "Dutzende leichte Rezepte mit Fisch und Meeresfrüchten machen die gesunde Positionierung konkret und alltagstauglich."],
  ["Aktivität mit Anleitung", "Trainings, Yoga, Pilates und saisonale Sportideen ergänzen das Ernährungsthema um praktische Bewegung."],
];

const platformCards = [
  ["recipe-system.jpg", "Essen", "Seafood-Rezepte als Alltagssystem", "Die Rezeptwelt zeigt Maguro nicht als einzelnes Produkt, sondern als leichtes, variierbares Essen nach dem Training."],
  ["training-system.jpg", "Laufen", "Bewegung mit klarer Anleitung", "Matte, Schuhe, Tracker und Trainingsmodule uebersetzen Motivation in konkrete Routinen."],
  ["content-hub.jpg", "Leben", "Content-Hub fuer Haltung und Plan", "Artikel, Routen, Rezeptkarten und Fortschritt bilden den redaktionellen Rahmen der Kampagne."],
];

const journeySteps = [
  ["01", "Impuls", "Der Hero setzt Energie: Meer, Lauf, frisches Essen."],
  ["02", "Rezept", "Seafood wird ueber visuelle Karten direkt nutzbar."],
  ["03", "Training", "Sportmodule erweitern die Marke in Bewegung."],
  ["04", "Routine", "Motivation und Planung halten den Nutzer im Special."],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Maguro Healthy Lifestyle Campaign 2018 - Case Study von Andrii Prokhorovych." />
    <title>Maguro Healthy Lifestyle Campaign 2018 - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=maguro-2018`}>Редактировать</a>
        <a class="button dark small" data-owner-only hidden href="https://www.edimdoma.ru/2018/maguro" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2018</p>
          <img class="client-logo" src={`${media}/logo.png`} alt="Maguro" />
          <h1>Ernährung, Bewegung und Motivation in Balance</h1>
          <p class="intro">
            Eine umfassende Healthy-Lifestyle-Plattform, die Seafood-Rezepte, Sportübungen
            und motivierende Inhalte unter dem Motto „Essen! Laufen! Leben!“ verbindet.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#konzept">02 Konzept</a>
          <a href="#highlights">03 Highlights</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Food & Beverage · Healthy Lifestyle</p>
            <h2>Gesund leben ohne Verbote und Verzicht</h2>
            <p>
              Maguro und Edim Doma übersetzen gesunden Lebensstil in drei konkrete Bereiche.
              Leichte Seafood-Gerichte geben Energie, Schritt-für-Schritt-Übungen fördern
              Aktivität und redaktionelle Inhalte helfen bei einer positiven Routine.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero-concept.jpg`} alt="Maguro Healthy Lifestyle Hero mit Seafood-Bowl, Meer und Laufmotiv" />
            <span>Hero · Seafood, Bewegung und Meer</span>
          </div>
        </section>

        <section id="konzept" class="story-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Konzept</p>
            <h2>Dynamik und Energie als visuelles Leitmotiv</h2>
            <p>
              Der Hero zeigt eine Läuferin im warmen Gegenlicht und setzt das starke Motto
              gross in die Landschaft. Anthrazit, Rot und die klare Sans-Serif-Typografie
              verbinden Sportästhetik mit der maritimen Markenwelt von Maguro.
            </p>
          </div>
          <div class="quote">
            <p>„Healthy Lifestyle funktioniert als Geschichte, wenn Essen, Bewegung und Haltung zusammen gedacht werden.“</p>
          </div>
        </section>

        <section class="platform-section" aria-labelledby="platform-title">
          <div class="section-copy">
            <p class="eyebrow">Plattformlogik</p>
            <h2 id="platform-title">Essen, Laufen, Leben als drei eigene Screens</h2>
            <p>
              Statt den Startscreen mehrfach zu zeigen, bekommt jede Kampagnensaeule ein
              eigenes Bild. So liest man sofort, dass Maguro hier Rezepte, Training und
              Motivation zu einer aktiven Routine verbindet.
            </p>
          </div>
          <div class="platform-grid">
            {platformCards.map(([image, label, title, text]) => (
              <article>
                <div class="platform-image">
                  <img src={`${media}/${image}`} alt={title} loading="lazy" />
                </div>
                <div class="platform-copy">
                  <span>{label}</span>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section id="highlights" class="highlights">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was den Auftritt besonders macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="journey-section" aria-label="Kampagnenreise">
          <div class="section-copy">
            <p class="eyebrow">Dramaturgie</p>
            <h2>Wie aus einem Motto ein Content-System wird</h2>
          </div>
          <div class="journey-grid">
            {journeySteps.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="showcase-section" aria-label="Kampagnenansichten">
          <article class="system-card">
            <p class="eyebrow">Original + Case-Logik</p>
            <h2>Der alte Startscreen bleibt Referenz, nicht Wiederholung</h2>
            <p>
              Die Seite zeigt das Original einmal und zerlegt danach die Idee in klare
              Ebenen: Seafood-Rezepte, Trainingsroutine und motivierende Content-Strecke.
            </p>
          </article>
          <figure class="original-screen">
            <img src={`${media}/hero.jpg`} alt="Originaler Maguro Kampagnenstartscreen" loading="lazy" />
            <figcaption>Originalscreen · Kampagnenstart und Motto</figcaption>
          </figure>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Eine Content-Plattform für nachhaltige Motivation</h2>
            <p>
              Das Special erweitert die Marke weit über einzelne Seafood-Produkte hinaus.
              Rezepte, Übungsserien und motivierende Artikel schaffen wiederkehrenden Nutzen
              und positionieren Maguro als Begleiter eines aktiven Alltags.
            </p>
            <a class="button light" data-owner-only hidden href="https://www.edimdoma.ru/2018/maguro" target="_blank" rel="noreferrer">
              Originalprojekt oeffnen
            </a>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />

  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f3f4f2;
    --paper: #fff;
    --ink: #080808;
    --muted: #61656a;
    --line: #dadcda;
    --accent: #d71f3a;
    --accent-dark: #171b20;
    --sea: #0f5f75;
    --sand: #f0d6a4;
    --radius: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img, video { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(243, 244, 242, .9);
    border-bottom: 1px solid rgba(218, 220, 218, .75);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(8, 8, 8, 0.18) !important;
    color: rgba(8, 8, 8, 0.46) !important;
  }

  .edit-page:hover,
  .edit-page:focus-visible {
    border-color: var(--ink) !important;
    color: var(--ink) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 70px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 100px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(32px, 4.5vw, 68px); line-height: 1.02; max-width: 900px; }
  .intro { hyphens: auto; overflow-wrap: anywhere; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero {
    background:
      radial-gradient(circle at 78% 22%, rgba(215, 31, 58, .16), transparent 28%),
      radial-gradient(circle at 12% 70%, rgba(15, 95, 117, .16), transparent 30%),
      var(--bg);
    min-height: calc(100vh - 83px);
  }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media {
    background: var(--accent-dark);
    border-radius: 24px;
    box-shadow: 0 30px 90px rgba(23, 27, 32, .18);
    overflow: hidden;
  }
  .hero-media img { aspect-ratio: 16 / 9; object-fit: cover; width: 100%; }
  .hero-media span { color: #fff; display: block; font-size: 12px; font-weight: 900; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .story-section, .highlights, .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 850px; }
  .quote {
    background:
      radial-gradient(circle at 82% 20%, rgba(215, 31, 58, .36), transparent 28%),
      linear-gradient(135deg, var(--accent-dark), #2f3640);
    border-radius: var(--radius);
    color: #fff;
    font-size: clamp(26px, 4vw, 52px);
    font-weight: 800;
    grid-column: 2;
    line-height: 1.12;
    margin-top: 28px;
    padding: clamp(28px, 5vw, 70px);
  }

  .platform-section {
    background:
      radial-gradient(circle at 16% 14%, rgba(15, 95, 117, .18), transparent 28%),
      linear-gradient(135deg, #fff, #eef2f2);
  }

  .platform-grid {
    display: grid;
    gap: 20px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 48px;
  }

  .platform-grid article {
    background: var(--paper);
    border: 1px solid rgba(23, 27, 32, .08);
    border-radius: 22px;
    box-shadow: 0 24px 80px rgba(23, 27, 32, .09);
    overflow: hidden;
    transition: box-shadow .35s ease, transform .35s ease;
  }

  .platform-grid article:hover {
    box-shadow: 0 32px 90px rgba(23, 27, 32, .16);
    transform: translateY(-8px);
  }

  .platform-image {
    aspect-ratio: 4 / 3;
    background: var(--accent-dark);
    overflow: hidden;
  }

  .platform-image img {
    height: 100%;
    object-fit: cover;
    transition: transform .45s ease;
    width: 100%;
  }

  .platform-grid article:hover .platform-image img { transform: scale(1.05); }
  .platform-copy { padding: 26px; }
  .platform-copy span {
    color: var(--accent);
    display: block;
    font-size: 12px;
    font-weight: 950;
    letter-spacing: .08em;
    margin-bottom: 14px;
    text-transform: uppercase;
  }
  .platform-copy h3 { font-size: 25px; line-height: 1.05; }
  .platform-copy p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .highlight-grid { display: grid; gap: 18px; grid-column: 2; grid-template-columns: repeat(3, 1fr); margin-top: 24px; }
  .highlight-grid article { background: var(--paper); border: 1px solid var(--line); border-radius: var(--radius); min-height: 260px; padding: 26px; }
  .highlight-grid span { color: var(--muted); font-size: 12px; font-weight: 900; }
  .highlight-grid h3 { font-size: 20px; line-height: 1.2; margin-top: 54px; }
  .highlight-grid p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .journey-section {
    background:
      radial-gradient(circle at 88% 18%, rgba(215, 31, 58, .26), transparent 26%),
      linear-gradient(135deg, var(--accent-dark), #2b3139);
    color: #fff;
  }

  .journey-section .eyebrow,
  .journey-grid p { color: rgba(255, 255, 255, .68); }

  .journey-grid {
    display: grid;
    gap: 16px;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    margin-top: 48px;
  }

  .journey-grid article {
    background: rgba(255, 255, 255, .08);
    border: 1px solid rgba(255, 255, 255, .14);
    border-radius: 18px;
    min-height: 240px;
    padding: 24px;
  }

  .journey-grid span { color: var(--sand); font-size: 13px; font-weight: 950; }
  .journey-grid h3 { font-size: 24px; line-height: 1.08; margin-top: 58px; }
  .journey-grid p { font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .showcase-section {
    background:
      linear-gradient(90deg, rgba(15, 95, 117, .08) 1px, transparent 1px),
      linear-gradient(180deg, #f3f4f2, #e8eeee);
    background-size: 44px 44px, auto;
    display: grid;
    gap: 20px;
    grid-template-columns: 1.2fr .8fr;
  }

  .showcase-section figure,
  .system-card {
    background: var(--paper);
    border-radius: 24px;
    box-shadow: 0 28px 80px rgba(23, 27, 32, .1);
    overflow: hidden;
  }

  .system-card {
    background:
      radial-gradient(circle at 84% 14%, rgba(215, 31, 58, .16), transparent 28%),
      linear-gradient(135deg, #fff, #eef2f2);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 420px;
    padding: clamp(28px, 4vw, 56px);
  }

  .system-card h2 { font-size: clamp(36px, 4vw, 62px); }
  .system-card p:last-child { color: var(--muted); font-size: 16px; line-height: 1.7; margin-top: 24px; max-width: 640px; }

  .showcase-section img { aspect-ratio: 16 / 10; object-fit: cover; width: 100%; }
  figcaption { color: var(--muted); font-size: 12px; font-weight: 800; padding: 16px; text-transform: uppercase; }

  .result {
    background:
      radial-gradient(circle at 20% 18%, rgba(15, 95, 117, .34), transparent 25%),
      linear-gradient(135deg, #8e1427, var(--accent));
    color: #fff;
  }
  .result .eyebrow, .result-copy > p { color: #c6d1ce; }
  .result-copy { max-width: 900px; }
  .result .button { border-color: #fff; margin-top: 34px; }

  @media (max-width: 1100px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
    .platform-grid { grid-template-columns: 1fr; }
    .journey-grid { grid-template-columns: repeat(2, 1fr); }
    .showcase-section { grid-template-columns: 1fr; }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    .header-actions { gap: 5px; }
    .case-sidebar { padding: 36px 18px; }
    .case-content > section { padding-left: 18px; padding-right: 18px; }
    .hero-copy, .story-section, .highlights, .result { grid-template-columns: 1fr; }
    .hero-copy .eyebrow, .quote, .highlight-grid { grid-column: 1; }
    .highlight-grid, .journey-grid { grid-template-columns: 1fr; }
    .section-number { display: none; }
  }
</style>
