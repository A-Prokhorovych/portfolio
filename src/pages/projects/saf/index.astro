---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/saf`;

const facts = [
  ["Kunde", "Lesaffre / SAF"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2017"],
  ["Rolle", "Web & Campaign Design"],
];

const products = [
  ["prod-01.png", "Lux Extra", "Presshefe als vertrauter Einstieg fuer klassische Hausbaeckerei."],
  ["prod-02.png", "SAF-Moment", "Schnelle Trockenhefe fuer alltaegliche Rezepte und einfache Aktivierung."],
  ["prod-03.png", "Fuer Pizza", "Ein klares Produktversprechen fuer Teig, Kruste und italienische Rezepte."],
  ["prod-04.png", "Fuer Suesses", "Spezialhefe fuer Brioche, Kuchen, Zopf und aromatische Backideen."],
  ["prod-05.png", "SAF-Levure", "Aktive Trockenhefe als separater Produktpfad fuer erfahrene Nutzer."],
];

const mechanics = [
  ["Produktlogik", "Die Seite erklaert die Unterschiede der Hefetypen nicht trocken, sondern ueber konkrete Backmomente."],
  ["Backtipps", "Editoriale Artikel geben dem Produkt Nutzwert: Fehler vermeiden, Teig verstehen, besser backen."],
  ["Rezepte", "Piroggen, Brote und Kuchen zeigen die Anwendung direkt dort, wo die Zielgruppe Inspiration sucht."],
  ["Contest", "Der Wettbewerb macht aus einer Produktseite eine Aktivierung mit Einsendungen und Preisen."],
];

const recipes = [
  ["recipe-01.jpg", "Piroggen Picknick"],
  ["recipe-02.jpg", "Apfel-Johannisbeer-Kuchen"],
  ["recipe-03.jpg", "Adjarisches Khachapuri"],
  ["recipe-04.jpg", "Knoblauchbrot mit Kraeutern"],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="SAF / Lesaffre Case Study - Backkampagne mit Produktlinie, Rezepten und Wettbewerb von Andrii Prokhorovych." />
    <title>SAF Lesaffre Campaign - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=saf`}>Редактировать</a>
        <a class="button dark small" data-owner-only hidden href="https://www.edimdoma.ru/2017/saf" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2017</p>
          <div class="yeast-mark">
            <img src={`${media}/logo.png`} alt="Lesaffre Logo" />
          </div>
          <h1>Backkampagne mit Produktfamilie, Rezeptnutzen und Wettbewerb</h1>
          <p class="intro">
            Fuer Lesaffre entstand ein Special Project rund um SAF-Hefe: Produktunterschiede,
            Backtipps, Rezeptinspiration und ein Wettbewerb wurden in eine freundliche
            Kampagnenseite fuer Hausbaeckerinnen und Hausbaecker uebersetzt.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Ueberblick</a>
          <a href="#produkte">02 Produkte</a>
          <a href="#mechanik">03 Mechanik</a>
          <a href="#rezepte">04 Rezepte</a>
          <a href="#ergebnis">05 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Food & Beverage · Baking Campaign</p>
            <h2>Hefe wird greifbar, wenn sie in Rezepten und Entscheidungen auftaucht</h2>
            <p>
              Die Kampagne musste nicht nur schoen aussehen. Sie musste erklaeren, welche
              Hefe wofuer passt, Vertrauen in das Backen schaffen und Menschen motivieren,
              eigene Rezepte mit der Marke zu teilen.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero.jpg`} alt="SAF Lesaffre Kampagnenhero mit Teig, Hefe und Rezeptnavigation" />
            <span>Originalbereich · Produktfamilie, Tipps, Rezepte und Contest</span>
          </div>
        </section>

        <section id="produkte" class="products-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Produktfamilie</p>
            <h2>Aus fuenf Packungen wird eine einfache Entscheidung am Backtisch</h2>
            <p>
              Statt alle Produkte gleich zu behandeln, zeigt die Seite eine kleine
              Sortimentsdramaturgie: klassische Presshefe, schnelle Trockenhefe und
              Spezialvarianten fuer Pizza oder suesse Teige.
            </p>
          </div>
          <div class="product-stage" aria-label="SAF Produktlinie">
            {products.map(([image, title, text], index) => (
              <article style={`--i:${index}`}>
                <img src={`${media}/${image}`} alt={`SAF ${title} Produktpackung`} loading="lazy" />
                <div>
                  <span>{String(index + 1).padStart(2, "0")}</span>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section id="mechanik" class="mechanics-section">
          <div class="section-copy">
            <p class="eyebrow">Campaign Mechanics</p>
            <h2>Die Seite fuehrt vom Produkt zur Handlung</h2>
            <p>
              Die Struktur arbeitet wie ein kleiner Funnel: erst Orientierung im Sortiment,
              dann Hilfe beim Backen, danach Rezepte als Anwendung und am Ende ein Contest,
              der die Community aktiviert.
            </p>
          </div>
          <div class="mechanic-grid">
            {mechanics.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="rezepte" class="recipes-section">
          <div class="section-number">04</div>
          <div class="section-copy">
            <p class="eyebrow">Recipe Proof</p>
            <h2>Rezepte machen den Nutzen der Hefe sichtbar</h2>
            <p>
              Der Rezeptbereich zeigt direkt, was mit dem Produkt entsteht: herzhafte
              Piroggen, Kuchen, Khachapuri und Brot. So wird aus Packungsdesign ein
              konkretes Versprechen fuer den Alltag.
            </p>
          </div>
          <div class="recipe-board">
            {recipes.map(([image, title]) => (
              <figure>
                <img src={`${media}/${image}`} alt={`SAF Rezept ${title}`} loading="lazy" />
                <figcaption>{title}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">05</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Ein Special Project, das Produktwissen in Appetit uebersetzt</h2>
            <p>
              SAF bekommt keine isolierte Markenflaeche, sondern ein komplettes
              Aktivierungssystem: Sortiment, Know-how, Rezepte und Wettbewerb greifen
              ineinander und zeigen, warum die Marke beim Backen gebraucht wird.
            </p>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />
  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #f8f0dc;
    --paper: #fffaf0;
    --ink: #13253a;
    --muted: #69758a;
    --line: rgba(19, 37, 58, .13);
    --blue: #0088c8;
    --deep-blue: #00508f;
    --red: #e52b2f;
    --cream: #fff4cf;
    --wheat: #f3bd59;
    --radius: 10px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(255, 250, 240, .92);
    border-bottom: 1px solid var(--line);
    backdrop-filter: blur(18px);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
  }
  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { min-height: 42px; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(19, 37, 58, .18) !important;
    color: rgba(19, 37, 58, .46) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--blue);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .yeast-mark {
    align-items: center;
    background: #eef1f2;
    border: 1px solid rgba(19, 37, 58, .08);
    border-radius: 16px 16px 16px 4px;
    box-shadow: 0 18px 34px rgba(19, 37, 58, .08);
    display: inline-flex;
    height: 72px;
    justify-content: center;
    margin-bottom: 30px;
    padding: 0 18px;
    width: 142px;
  }
  .yeast-mark img {
    height: auto;
    opacity: .86;
    width: 108px;
  }
  h1 { font-size: clamp(25px, 2.25vw, 38px); line-height: 1.08; }
  h2 { font-size: clamp(34px, 4.5vw, 72px); letter-spacing: -.055em; line-height: .98; max-width: 980px; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; gap: 18px; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 430px); margin-bottom: 58px; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media, .product-stage article, .mechanic-grid article, .recipe-board figure {
    background: #fff;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: 0 30px 90px rgba(19, 37, 58, .12);
    overflow: hidden;
  }
  .hero-media img { aspect-ratio: 18 / 10; object-fit: cover; object-position: center; width: 100%; }
  .hero-media span, figcaption {
    color: var(--muted);
    display: block;
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    padding: 16px 18px;
    text-transform: uppercase;
  }

  .products-section {
    background:
      radial-gradient(circle at 88% 12%, rgba(229, 43, 47, .16), transparent 24%),
      linear-gradient(180deg, #fff9e8, #f7efd8);
    display: grid;
    gap: 36px;
    grid-template-columns: 70px minmax(0, 1fr);
  }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 900px; }
  .product-stage {
    display: grid;
    gap: 16px;
    grid-column: 2;
    grid-template-columns: repeat(5, 1fr);
    margin-top: 18px;
  }
  .product-stage article {
    background:
      radial-gradient(circle at 50% 22%, rgba(0, 136, 200, .12), transparent 42%),
      #fff;
    display: grid;
    grid-template-rows: 230px auto;
    min-height: 430px;
    padding-top: 24px;
    transform: translateY(calc((var(--i) % 2) * 22px));
  }
  .product-stage img {
    align-self: end;
    justify-self: center;
    max-height: 210px;
    object-fit: contain;
    width: min(82%, 220px);
  }
  .product-stage div { border-top: 1px solid var(--line); padding: 22px; }
  .product-stage span { color: var(--red); font-size: 12px; font-weight: 950; }
  .product-stage h3 { font-size: 24px; line-height: 1.05; margin-top: 10px; }
  .product-stage p { color: var(--muted); font-size: 14px; line-height: 1.58; margin-top: 12px; }

  .mechanics-section {
    background:
      linear-gradient(135deg, rgba(0, 136, 200, .9), rgba(0, 80, 143, .95)),
      var(--deep-blue);
    color: #fff;
  }
  .mechanics-section .eyebrow,
  .mechanics-section .section-copy > p:last-child { color: rgba(255, 255, 255, .74); }
  .mechanic-grid { display: grid; gap: 16px; grid-template-columns: repeat(4, 1fr); margin-top: 48px; }
  .mechanic-grid article {
    background: rgba(255, 255, 255, .1);
    border-color: rgba(255, 255, 255, .2);
    box-shadow: none;
    min-height: 280px;
    padding: 24px;
  }
  .mechanic-grid span { color: var(--wheat); font-size: 12px; font-weight: 950; }
  .mechanic-grid h3 { font-size: 26px; line-height: 1.05; margin-top: 82px; }
  .mechanic-grid p { color: rgba(255, 255, 255, .72); font-size: 14px; line-height: 1.58; margin-top: 14px; }

  .recipes-section {
    background: #fffaf0;
    display: grid;
    gap: 36px;
    grid-template-columns: 70px minmax(0, 1fr);
  }
  .recipe-board {
    display: grid;
    gap: 18px;
    grid-column: 2;
    grid-template-columns: repeat(4, 1fr);
    margin-top: 18px;
  }
  .recipe-board img { aspect-ratio: 3 / 4; object-fit: cover; width: 100%; }

  .result {
    background:
      radial-gradient(circle at 82% 18%, rgba(243, 189, 89, .22), transparent 28%),
      linear-gradient(135deg, #122d4d, #04182e);
    color: #fff;
    display: grid;
    gap: 36px;
    grid-template-columns: 70px minmax(0, 1fr);
  }
  .result .eyebrow, .result-copy > p { color: rgba(255, 255, 255, .74); }
  .result-copy { max-width: 980px; }

  @media (max-width: 1180px) {
    .site-header { grid-template-columns: 1fr auto; }
    .back-link { display: none; }
    main { grid-template-columns: 1fr; }
    .case-sidebar { height: auto; position: static; }
    .case-sidebar nav { display: none; }
    .hero { min-height: auto; }
    .hero-copy { grid-template-columns: 1fr; }
    .product-stage { grid-template-columns: repeat(2, 1fr); }
    .mechanic-grid, .recipe-board { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 720px) {
    .site-header { padding: 14px 18px; }
    .brand { font-size: 20px; }
    .button.small { font-size: 11px; min-height: 38px; padding: 0 10px; }
    main, .case-sidebar, .case-content { max-width: 100vw; min-width: 0; width: 100%; }
    .case-sidebar { overflow: hidden; padding: 36px 18px; }
    .case-content { overflow: hidden; }
    .case-content > section { max-width: 100vw; padding-left: 18px; padding-right: 18px; width: 100%; }
    .products-section, .recipes-section, .result { grid-template-columns: minmax(0, 1fr); }
    .hero-copy .eyebrow, .product-stage, .recipe-board { grid-column: 1; }
    .product-stage, .mechanic-grid, .recipe-board { grid-template-columns: 1fr; }
    .product-stage article { min-height: auto; transform: none; }
    .section-number { display: none; }
    .hero-media img { aspect-ratio: 4 / 3; }
    h2 { font-size: clamp(32px, 12vw, 48px); }
  }
</style>
