---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/dr-langhammer`;

const facts = [
  ["Client", "Dr. Langhammer"],
  ["Role", "Lead Web Designer"],
  ["Timeline", "6 weeks"],
  ["Platform", "WordPress"],
  ["Responsibilities", "UX, UI, IA, Design System, Handoff"],
];

const heroFacts = [
  ["Role", "Lead Web Designer"],
  ["Duration", "6 weeks"],
  ["Platform", "WordPress"],
  ["Deliverables", "UX · UI · Information Architecture · Design System · Developer Handoff"],
];

const contextPoints = [
  ["The clinic had grown", "New services, treatment pages and practice content had been added over time."],
  ["Navigation became inconsistent", "Patients could find information, but the structure asked them to understand the clinic before choosing a path."],
  ["Trust signals were scattered", "Doctor, rooms, lab, reviews and service proof existed, but did not work as one calm first impression."],
  ["Mobile needed faster orientation", "Patients needed quick answers: who is the doctor, what is offered, how do I call, where is the practice."],
];

const businessGoals = [
  ["Understand services faster", "Make treatment areas easier to scan without reading through a large menu first."],
  ["Reduce information overload", "Shorten the decision path by repeating one clear content structure across service pages."],
  ["Increase trust", "Use real photography, calm hierarchy and visible practice proof."],
  ["Support appointment booking", "Keep contact and appointment intent close to the moments where patients decide."],
  ["Prepare scalable content", "Create a page system that can support future treatments without becoming inconsistent again."],
];

const discoveryItems = [
  ["Content audit", "Reviewed old service content and identified repeated page needs."],
  ["Navigation audit", "Mapped the legacy menu and the choices patients had to decode."],
  ["Competitor review", "Compared local healthcare sites to keep the result calm, credible and familiar."],
  ["Photography review", "Selected real practice images that could carry trust instead of generic clinic claims."],
];

const changes = [
  ["Homepage", "General welcome page with slider-led presentation.", "A trust-first landing page with hero, service spectrum, practice tour, jameda/job teasers and direct contact."],
  ["Zahnarztpraxis", "Practice page with philosophy and team anchors.", "Clearer practice story: philosophy, team, atmosphere and doctor-led trust signals."],
  ["Implantologie", "One core page with anchors for Implantate and Navigierte Implantologie.", "A stronger treatment pillar with visible subtopics, plus CEREC 3D as an additional high-value technology page."],
  ["Aesthetische Zahnheilkunde", "One service page with Veneers, Kronen and Bleaching anchors.", "A more scannable service family where each treatment feels reachable from navigation and page modules."],
  ["Prophylaxe", "Prophylaxis page with Zahnreinigung and Implantatprophylaxe.", "Modernized prevention story with AIRFLOW Zahnreinigung and implant aftercare as explicit user journeys."],
  ["Praxislabor", "A separate advantage, but not central to the first impression.", "In-house lab reframed as a differentiator for precision, speed and quality control."],
  ["Kontakt & Anfahrt", "Functional contact page.", "Conversion module with address, phone, email, opening hours and appointment intent available early."],
  ["Jobs", "Not a strong visible destination in the older navigation.", "Recruiting becomes part of the website product: the site now serves patients and potential employees."],
];

const newPages = [
  ["Home", "/"],
  ["Zahnarztpraxis", "/zahnarztpraxis/"],
  ["Implantologie", "/implantologie/"],
  ["Aesthetische Zahnheilkunde", "/asthetische-zahnheilkunde/"],
  ["Prophylaxe", "/prophylaxe/"],
  ["Praxislabor", "/praxislabor/"],
  ["Services", "/services/"],
  ["Jobs", "/jobs/"],
  ["Kontakt", "/kontakt/"],
  ["CEREC 3D", "/cerec-3d/"],
  ["AIRFLOW Zahnreinigung", "/airflow-zahnreinigung/"],
  ["Impressum & Datenschutz", "/impressum-datenschutz/"],
];

const principles = [
  ["Calm before conversion", "A dental website has to reduce tension before asking for action."],
  ["Services as orientation", "The service structure is built around patient questions, not internal categories."],
  ["Real practice atmosphere", "Photography carries proof: rooms, reception, lab and people feel more trustworthy than generic claims."],
  ["Accessible rhythm", "Large type, short paragraphs and repeated contact patterns support older patients and mobile use."],
  ["Minimal by purpose", "The interface stays quiet so medical information, trust signals and contact actions remain easy to read."],
];

const components = [
  ["Hero", "Logo, headline, appointment CTA and real practice photography."],
  ["Service cards", "Treatment pillars with subtopics and benefit-led descriptions."],
  ["Navigation", "A clearer structure for core pages, treatments, proof and legal content."],
  ["CTA", "Repeated appointment and phone patterns for decision moments."],
  ["Forms", "Contact entry points prepared as reusable WordPress sections."],
  ["Gallery", "Practice photography modules for rooms, lab and treatment atmosphere."],
  ["Testimonials", "Review and trust areas positioned as supporting proof, not decoration."],
];

const serviceCards = [
  ["Implantologie", "Fixed teeth, guided planning and CEREC technology.", "implantologie.jpg"],
  ["Aesthetik", "Veneers, inlays, crowns and whitening with a natural appearance.", "aesthetic.jpg"],
  ["Prophylaxe", "Professional cleaning, AIRFLOW and long-term implant care.", "current-chairs.jpg"],
];

const slideNotes = [
  ["First screen", "Before uses the archived WordPress homepage. After shows the 2025 redesign as a full page with clearer hierarchy, photography and service entry points."],
  ["Service choice", "Instead of making people decode a wide dropdown, the redesign gives them simple directions: implants, aesthetics, prophylaxis and lab."],
  ["Appointment path", "On mobile the page stops behaving like a brochure. Phone, address, opening hours and appointment intent become the fastest route."],
];

const beforePhotos = [
  ["Old doctor slide", "before-doctor.jpg"],
  ["Old waiting area", "before-waiting.jpg"],
  ["Old reception slide", "before-reception.jpg"],
];

const afterPhotos = [
  ["New hero", "hero-current.jpg"],
  ["Practice tour", "current-tour-01.jpg"],
  ["Treatment room", "current-chairs.jpg"],
  ["Practice corridor", "current-gang.jpg"],
];

const figmaLayouts = [
  ["Home page", "home-preview.jpg", "home.jpg"],
  ["Zahnarztpraxis", "zahnarztpraxis-preview.jpg", "zahnarztpraxis.jpg"],
  ["Implantologie", "implantologie-preview.jpg", "implantologie.jpg"],
  ["CEREC 3D", "cerec-3d-preview.jpg", "cerec-3d.jpg"],
  ["Aesthetische Zahnheilkunde", "aesthetische-zahnheilkunde-preview.jpg", "aesthetische-zahnheilkunde.jpg"],
  ["Prophylaxe", "prophylaxe-preview.jpg", "prophylaxe.jpg"],
  ["AIRFLOW Zahnreinigung", "airflow-zahnreinigung-preview.jpg", "airflow-zahnreinigung.jpg"],
  ["Praxislabor", "praxislabor-preview.jpg", "praxislabor.jpg"],
  ["Services", "services-preview.jpg", "services.jpg"],
  ["Kontakt", "kontakt-preview.jpg", "kontakt.jpg"],
];

const designTokens = [
  ["h1", "Lora Regular", "160 / 90 / -2"],
  ["h2", "Lora Regular", "64 / 120 / -2"],
  ["h3", "Raleway Bold", "30 / 120"],
  ["h4", "Raleway Bold", "16 / 100 / 10"],
  ["h5", "Raleway Italic", "18 / 160 / 3"],
  ["h6", "Raleway Regular", "14 / 160 / 3"],
  ["p", "Raleway Regular", "20 / 160 / 1"],
];

const figmaColors = [
  ["#F78F21", "#F78F21"],
  ["#005588", "#005588"],
  ["#2C3941", "#2C3941"],
  ["#E6F2F9", "#E6F2F9"],
  ["#FAF5EF", "#FAF5EF"],
  ["#F78F21", "#F78F21 50%"],
  ["#FFFFFF", "#FFFFFF"],
];

const clientFixes = [
  "Remove hero H1 titles on image banners",
  "Fix stretched square doctor photos across browsers",
  "Replace the Jameda homepage banner with the current image",
  "Improve link visibility and dropdown font sizing",
  "Compress footer navigation spacing",
  "Make appointment buttons call-ready",
  "Tune headline-to-paragraph spacing",
  "Fix slider cropping to 1500 x 844",
];

const sitemapGroups = [
  ["Core", ["Home", "Zahnarztpraxis", "Kontakt"]],
  ["Treatments", ["Implantologie", "CEREC 3D", "Aesthetische Zahnheilkunde", "Prophylaxe", "AIRFLOW Zahnreinigung"]],
  ["Practice proof", ["Praxislabor", "Services", "Jobs"]],
  ["Legal", ["Impressum", "Datenschutz"]],
];

const prototypeSteps = [
  ["01", "Audit old navigation", "Map what patients had to decode in the 2024/old WordPress structure."],
  ["02", "Group repeated page logic", "Use one reusable service-page pattern for treatments with similar content needs."],
  ["03", "Prototype mobile intent", "Prioritize phone, address, opening hours and appointment CTA on small screens."],
  ["04", "Handoff page system", "Document typography, colors, components, spacing and QA fixes in Figma."],
];

const roleCards = [
  ["Role", "Lead Web Designer"],
  ["Client", "Dental Clinic"],
  ["Timeline", "6 weeks"],
  ["Platform", "WordPress"],
  ["Responsibilities", "UX · UI · Information Architecture · Design System · Developer Handoff"],
];

const constraints = [
  ["Existing WordPress", "The redesign had to work with a production CMS and real implementation limits."],
  ["Large legacy content", "Old service content needed a clearer structure without losing useful information."],
  ["Limited photography", "The image system had to rely on existing brand and practice material instead of generic stock visuals."],
  ["Legacy navigation", "The old menu had many valid topics, but the grouping needed to become easier for patients."],
  ["Existing branding", "Logo, color direction and medical trust cues stayed recognizable."],
  ["SEO preservation", "The new sitemap had to respect existing page intent and patient search behavior."],
];

const outcomeSkills = [
  "Information Architecture",
  "UX Thinking",
  "Responsive Design",
  "UI System",
  "Design System",
  "Developer Handoff",
  "WordPress Production",
  "Developer Collaboration",
];

const developmentItems = [
  ["Prepared for WordPress", "Sections were designed to work as reusable production blocks."],
  ["Reusable components", "Repeated page patterns reduced implementation decisions for similar service pages."],
  ["Responsive behaviour", "Desktop and mobile layouts use the same content logic with adapted density."],
  ["Spacing rules", "Section rhythm, card spacing and footer density were tuned for implementation."],
  ["Typography scale", "The Figma style guide documents headline, label and paragraph hierarchy."],
  ["Developer handoff", "Components, page logic and QA notes were prepared for production work."],
];

const reflectionItems = [
  ["What worked", "The strongest decision was treating the project as a website system, not as a single homepage redesign."],
  ["What I would simplify next", "I would make the appointment flow even more direct by testing one persistent contact pattern across treatment pages."],
  ["What it proves", "The case demonstrates project ownership: context, constraints, structure, UI system and production handoff."],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta
      name="description"
      content="Dr. Langhammer website redesign case study by Andrii Prokhorovych: UX audit, information architecture, healthcare UI system and responsive design."
    />
    <title>Dr. Langhammer Website Case Study - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#work`}>
        <span aria-hidden="true">←</span>
        Back to portfolio
      </a>
      <a class="button small" href={`${base}archive/`}>Archive</a>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · Healthcare</p>
          <img class="client-logo" src={`${media}/logo.png`} alt="Dr. Langhammer logo" width="300" height="114" />
          <h1>Dr. Langhammer website redesign</h1>
          <p class="intro">
            Designing a calmer patient journey through information architecture.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-study navigation">
          <a href="#overview">01 Overview</a>
          <a href="#context">02 Context</a>
          <a href="#strategy">03 Strategy</a>
          <a href="#figma">04 UI System</a>
          <a href="#development">05 Development</a>
          <a href="#result">06 Outcome</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="overview" class="hero">
          <div class="hero-copy">
            <p class="eyebrow">Dr. Langhammer · Healthcare Website System</p>
            <h2>Redesigned information architecture for a growing dental clinic.</h2>
            <p>
              I helped turn a content-heavy dental website into a clearer system for
              service discovery, trust building and appointment intent.
            </p>
          </div>

          <div class="hero-stage">
            <figure class="hero-media">
              <img src={`${media}/before-woman.jpg`} alt="Archived waiting area hero image with patient from the previous Dr. Langhammer website" width="1800" height="1059" />
              <figcaption>Homepage visual reference · patient-facing practice atmosphere</figcaption>
            </figure>
            <div class="hero-panel">
              <img src={`${media}/logo.png`} alt="" width="300" height="114" />
              <p>Dental Practice in Ulm</p>
              <strong>Implantology · Aesthetic dentistry · Prophylaxis · In-house dental lab</strong>
            </div>
          </div>

          <div class="metric-grid" aria-label="Project summary">
            {heroFacts.map(([value, label]) => (
              <article>
                <strong>{value}</strong>
                <span>{label}</span>
              </article>
            ))}
          </div>
        </section>

        <section class="role-section">
          <div class="role-card-grid" aria-label="Project role and scope">
            {roleCards.map(([label, value]) => (
              <article>
                <span>{label}</span>
                <strong>{value}</strong>
              </article>
            ))}
          </div>
        </section>

        <section id="context" class="split-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Context</p>
            <h2>The clinic had grown over time. The website needed a clearer way to guide patients.</h2>
            <p>
              The old site already contained useful service information, practice proof
              and appointment details. The challenge was to make those pieces work as
              one understandable system instead of a collection of pages.
            </p>
          </div>
          <div class="audit-grid">
            {contextPoints.map(([title, text]) => (
              <article>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="goals-section">
          <div class="section-copy">
            <p class="eyebrow">Business goals</p>
            <h2>The redesign had to solve orientation, trust and appointment intent at the same time.</h2>
          </div>
          <div class="goal-grid">
            {businessGoals.map(([title, text]) => (
              <article>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="constraints-section">
          <div class="section-copy">
            <p class="eyebrow">Constraints</p>
            <h2>Real website work means improving the system without losing what already works.</h2>
          </div>
          <div class="constraints-grid">
            {constraints.map(([title, text]) => (
              <article>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="discovery-section">
          <div class="section-copy">
            <p class="eyebrow">Discovery</p>
            <h2>Before designing screens, I audited content, navigation and visual trust signals.</h2>
          </div>
          <div class="audit-grid discovery-grid">
            {discoveryItems.map(([title, text]) => (
              <article>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="decision-section">
          <div class="decision-card">
            <p class="eyebrow">Key design decision</p>
            <h2>Instead of redesigning pages, the project focused on creating one scalable website system.</h2>
            <p>
              This decision connected the sitemap, service cards, typography, photography
              and responsive layouts into one reusable structure for future WordPress pages.
            </p>
          </div>
        </section>

        <section id="strategy" class="sitemap-prototype-section">
          <div class="section-copy">
            <p class="eyebrow">Strategy & information architecture</p>
            <h2>Instead of redesigning isolated pages, I built a scalable website system.</h2>
            <p>
              Most pages share one logic: trust signal, service explanation, proof and
              contact route. That makes the website easier to maintain and easier for
              patients to learn as they move between services.
            </p>
          </div>

          <div class="sitemap-prototype-grid">
            <div class="sitemap-board" aria-label="Current website map">
              {sitemapGroups.map(([group, items]) => (
                <article>
                  <span>{group}</span>
                  <ul>
                    {items.map((item) => <li>{item}</li>)}
                  </ul>
                </article>
              ))}
            </div>

            <div class="prototype-board" aria-label="Prototype stages">
              {prototypeSteps.map(([number, title, text]) => (
                <article>
                  <span>{number}</span>
                  <div>
                    <h3>{title}</h3>
                    <p>{text}</p>
                  </div>
                </article>
              ))}
            </div>
          </div>
        </section>

        <section class="slide-story" aria-label="Visual before and after slides">
          <div class="section-copy slide-intro">
            <p class="eyebrow">Visual story</p>
            <h2>Before and after, shown as pages instead of paragraphs.</h2>
            <p>
              I turned the case into a set of presentation-like slides, so the change is
              visible at a glance: what the user saw first, how services were reorganized
              and how the mobile path became shorter.
            </p>
          </div>

          <article class="case-slide hero-compare">
            <div class="slide-label">
              <span>Slide 01</span>
              <h3>Full homepage: old WordPress page vs 2025 redesign</h3>
            </div>
            <div class="browser-pair long-page-pair">
              <figure class="browser-frame before-frame long-page-frame">
                <figcaption>Before · Wayback February 27, 2024</figcaption>
                <div class="browser-chrome"><i></i><i></i><i></i></div>
                <img src={`${media}/before-2024-fullpage.png`} alt="Full old Dr. Langhammer homepage screenshot from February 2024 Wayback archive" width="1440" height="7835" loading="lazy" />
              </figure>
              <figure class="browser-frame after-frame long-page-frame">
                <figcaption>After · 2025 redesign</figcaption>
                <div class="browser-chrome"><i></i><i></i><i></i></div>
                <img src={`${media}/after-2025-fullpage.png`} alt="Full new Dr. Langhammer homepage screenshot from the 2025 redesign" width="1440" height="7159" loading="lazy" />
              </figure>
            </div>
            <p class="slide-note">{slideNotes[0][1]}</p>
          </article>

          <article class="case-slide photo-compare-slide">
            <div class="slide-label">
              <span>Slide 02</span>
              <h3>Photography: old archive atmosphere vs new 2025 material</h3>
            </div>
            <div class="photo-compare-grid">
              <div class="photo-column before-photos">
                <span>Before · archive</span>
                {beforePhotos.map(([label, image]) => (
                  <figure>
                    <img src={`${media}/${image}`} alt={`${label} from old Dr. Langhammer website`} width="1800" height="1059" loading="lazy" />
                    <figcaption>{label}</figcaption>
                  </figure>
                ))}
              </div>
              <div class="photo-column after-photos">
                <span>After · Figma / new site</span>
                {afterPhotos.map(([label, image]) => (
                  <figure>
                    <img src={`${media}/${image}`} alt={`${label} from new Dr. Langhammer visual system`} width="1860" height="1047" loading="lazy" />
                    <figcaption>{label}</figcaption>
                  </figure>
                ))}
              </div>
            </div>
            <p class="slide-note">The case now shows the real visual change: old archived slider photography against the cleaner 2025 image system used in Figma and on the new site.</p>
          </article>

          <article class="case-slide service-compare">
            <div class="slide-label">
              <span>Slide 03</span>
              <h3>Services: from nested anchors to scannable choices</h3>
            </div>
            <div class="service-before-after">
              <div class="old-menu">
                <span>Before navigation</span>
                <strong>Leistungen</strong>
                <ul>
                  <li>Implantologie → Implantate → Navigierte Implantologie</li>
                  <li>Aesthetische Zahnheilkunde → Veneers → Kronen → Bleaching</li>
                  <li>Prophylaxe → Zahnreinigung → Implantatprophylaxe</li>
                </ul>
              </div>
              <div class="new-services">
                {serviceCards.map(([title, text, image]) => (
                  <article>
                    <img src={`${media}/${image}`} alt={`${title} service page visual`} width="1860" height="1047" loading="lazy" />
                    <div>
                      <span>After</span>
                      <h4>{title}</h4>
                      <p>{text}</p>
                    </div>
                  </article>
                ))}
              </div>
            </div>
            <p class="slide-note">{slideNotes[1][1]}</p>
          </article>

          <article class="case-slide mobile-compare">
            <div class="slide-label">
              <span>Slide 04</span>
              <h3>Mobile: from browsing to booking intent</h3>
            </div>
            <div class="video-kicker">
              <span>Responsive prototype</span>
              <p>Homepage, treatments and contact pages scroll in a loop as real mobile screenshots.</p>
            </div>
            <figure class="mobile-video-showcase">
              <video
                src={`${media}/langhammer-mobile-showcase.mp4`}
                poster={`${media}/langhammer-mobile-showcase-poster.jpg`}
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
            </figure>
            <p class="slide-note">{slideNotes[2][1]}</p>
          </article>

          <article class="case-slide desktop-compare">
            <div class="slide-label">
              <span>Slide 05</span>
              <h3>Desktop: new page system working across key sections</h3>
            </div>
            <div class="video-kicker">
              <span>Desktop prototype</span>
              <p>Homepage, treatment, lab and contact pages move as a compact desktop overview.</p>
            </div>
            <figure class="mobile-video-showcase desktop-video-showcase">
              <video
                src={`${media}/langhammer-desktop-showcase.mp4`}
                poster={`${media}/langhammer-desktop-showcase-poster.jpg`}
                autoplay
                muted
                loop
                playsinline
                preload="metadata"
              ></video>
            </figure>
          </article>
        </section>

        <section id="figma" class="figma-section">
          <div class="section-copy">
            <p class="eyebrow">UI system</p>
            <h2>This was designed as a full website system, not a single landing screen.</h2>
            <p>
              The Figma file contains the page layouts, a style guide, responsive states,
              mobile menu screens, components, photo assets and review notes. I turned
              those ingredients into a portfolio-friendly story so the design work is visible.
            </p>
          </div>

          <div class="figma-deck">
            <article class="style-guide-card">
              <div class="figma-window-head">
                <span>Style guide</span>
                <strong>1908 x 1941</strong>
              </div>
              <div class="type-specimen">
                <span>Fonts</span>
                <strong>h1 - Lora: Reg. 160/90/-2</strong>
                <p>h2 - Lora: Regular 64/120/-2</p>
              </div>
              <div class="token-list">
                {designTokens.map(([label, font, spec]) => (
                  <div>
                    <span>{label}</span>
                    <strong>{font}</strong>
                    <em>{spec}</em>
                  </div>
                ))}
              </div>
              <div class="style-colors">
                <span>Colors</span>
                <div class="figma-color-grid">
                  {figmaColors.map(([color, label]) => (
                    <i style={`--swatch:${color}`}>
                      <em>{label}</em>
                    </i>
                  ))}
                </div>
              </div>
            </article>

            <article class="layout-index-card">
              <div class="figma-window-head">
                <span>Layouts</span>
                <strong>10 page previews</strong>
              </div>
              <div class="layout-preview-grid">
                {figmaLayouts.map(([label, preview, full], index) => (
                  <a href={`${media}/layout-screens/${full}`} target="_blank" rel="noreferrer">
                    <img src={`${media}/layout-screens/${preview}`} alt={`${label} mobile layout preview`} width="520" height="650" loading="lazy" />
                    <span>{index + 1}. {label}</span>
                  </a>
                ))}
              </div>
            </article>

            <article class="review-notes-card">
              <div class="figma-window-head">
                <span>Client iteration</span>
                <strong>QA notes</strong>
              </div>
              <ul>
                {clientFixes.map((item) => <li>{item}</li>)}
              </ul>
            </article>
          </div>
        </section>

        <section class="photo-strip" aria-label="Practice photography">
          <figure>
            <img src={`${media}/waiting-room.jpg`} alt="Waiting room of Dr. Langhammer dental practice" width="1501" height="845" loading="lazy" />
            <figcaption>New waiting area</figcaption>
