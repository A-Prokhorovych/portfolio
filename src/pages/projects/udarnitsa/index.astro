---
import MotionEnhance from "../../../components/MotionEnhance.astro";

const base = import.meta.env.BASE_URL;
const media = `${base}projects/udarnitsa`;

const facts = [
  ["Kunde", "Udarnitsa"],
  ["Plattform", "Edim Doma"],
  ["Jahr", "2018"],
  ["Rolle", "Web & Campaign Design"],
];

const highlights = [
  ["Roter Markenanker", "Die diagonale Udarnitsa-Lasche wird zum wiederkehrenden Signal und fuehrt durch Hero, Teeritual und Wettbewerb."],
  ["Suesse als Anlass", "Zephyr, Pastila und Marmelandia werden nicht katalogisiert, sondern als kleine Momente am Tisch inszeniert."],
  ["Instagram als Mechanik", "Der Social-Block wird als kuratierte Story gezeigt, ohne das alte Interface eins zu eins nachzubauen."],
];

const sweetMoments = [
  ["product-scharmel.jpg", "Scharmel", "Luftiger Zephyr", "Zephyr und Schokoglasur als weicher, nostalgischer Tea-Time-Moment."],
  ["product-pastila.jpg", "Pastila", "Fruchtige Leichtigkeit", "Pastila bekommt ein helles Morgenbild und wirkt nicht wie ein Ausschnitt aus dem Hero."],
  ["product-marmelandia.jpg", "Marmelandia", "Bunte Fruchtgummis", "Marmeladen-Stuecke werden als farbiger Akzent fuer Party und Tischdeko gezeigt."],
];

const originalSlides = [
  ["original-scharmel-slide.jpg", "Scharmel · Kaffee, Blumen und Packung"],
  ["original-pastila-slide.jpg", "Pastila · heller Lifestyle-Slide"],
  ["original-marmelandia-slide.jpg", "Marmelandia · gedeckter Tisch und Fruchtgummi"],
];

const contestSteps = [
  ["01", "Story", "Ein Social-Teaser erklaert die Idee: Fruehlingsstimmung, Tee und kleine Geheimnisse rund um Suessigkeiten."],
  ["02", "Mood", "Pastellverlauf, Smartphone-Karte und fliegende Sweets greifen die Sprache des Specials auf."],
  ["03", "Artikel", "Die darunterliegenden Karten fuehren von Instagram-Idee zu Lifehacks und saisonalen Tipps."],
  ["04", "Community", "Der Fotokontext bleibt erhalten, wirkt aber im Portfolio ruhiger und moderner."],
];
---

<html lang="de">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content="Udarnitsa Sweet Spring Campaign 2018 - Case Study von Andrii Prokhorovych." />
    <title>Udarnitsa Sweet Spring Campaign 2018 - Andrii Prokhorovych</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href={base}>PROKHA</a>
      <a class="back-link" href={`${base}#projects`}>
        <span aria-hidden="true">←</span>
        Zurueck zu den Projekten
      </a>
      <div class="header-actions">
        <a class="button light small edit-page" data-owner-only data-edit-only hidden href={`${base}editor/?project=udarnitsa`}>Редактировать</a>
        <a class="button dark small" href="https://www.edimdoma.ru/2018/udarnitsa" target="_blank" rel="noreferrer">Original ansehen</a>
      </div>
    </header>

    <main>
      <aside class="case-sidebar">
        <div>
          <p class="eyebrow">Case Study · 2018</p>
          <img class="client-logo" src={`${media}/logo.svg`} alt="Udarnitsa" />
          <h1>Eine süsse Frühlingskampagne rund ums Teetrinken</h1>
          <p class="intro">
            Eine leichte saisonale Kampagne, die Produktgeschichten, Tea-Party-Ideen,
            Food-Fotografie, Lifestyle-Tipps und einen Community-Fotowettbewerb zu einer
            kleinen digitalen Fruehlingsbuehne verbindet.
          </p>
        </div>

        <dl>
          {facts.map(([label, value]) => (
            <div>
              <dt>{label}</dt>
              <dd>{value}</dd>
            </div>
          ))}
        </dl>

        <nav aria-label="Case-Study-Navigation">
          <a href="#ueberblick">01 Überblick</a>
          <a href="#konzept">02 Konzept</a>
          <a href="#highlights">03 Highlights</a>
          <a href="#ergebnis">04 Ergebnis</a>
        </nav>
      </aside>

      <article class="case-content">
        <section id="ueberblick" class="hero">
          <div class="floating-sweets" aria-hidden="true">
            <span class="sweet-orb orb-one"></span>
            <span class="sweet-orb orb-two"></span>
            <span class="sweet-orb orb-three"></span>
          </div>
          <div class="hero-copy">
            <p class="eyebrow">Food & Beverage · Seasonal Campaign</p>
            <h2>Leichte Süssigkeiten werden zum Frühlingsritual</h2>
            <p>
              Der neue Case schaerft das, was im Original schon angelegt war: Udarnitsa ist
              nicht nur Packshot und Slider, sondern ein Anlass fuer Tee, Gespraech,
              Fruehlingsdeko und teilbare Bilder.
            </p>
          </div>
          <div class="hero-media">
            <img src={`${media}/hero-concept.jpg`} alt="Udarnitsa Hero-Konzept mit Tee, Fruehlingssuessigkeiten und rotem Markenband" />
            <span>Hero · neue Fruehlingsbuehne fuer den Case</span>
          </div>
        </section>

        <section id="konzept" class="story-section">
          <div class="section-number">02</div>
          <div class="section-copy">
            <p class="eyebrow">Konzept</p>
            <h2>Frühlingsleichtigkeit trifft nostalgische Markenwärme</h2>
            <p>
              Das Markenrot bleibt der Anker, aber die Seite erzaehlt jetzt in klaren
              Ebenen: Tee-Moment, drei Produktrollen, Lifehack-Ideen und Fotowettbewerb.
              So wirkt das Special weniger wie ein einzelner Screenshot und mehr wie ein
              Kampagnensystem.
            </p>
          </div>
          <div class="quote">
            <p>„Eine kleine Süssigkeit wird zur Geschichte, wenn sie einen Moment am Tisch ausloest.“</p>
          </div>
        </section>

        <section class="sweet-system" aria-labelledby="sweet-title">
          <div class="section-copy">
            <p class="eyebrow">Produktrollen</p>
            <h2 id="sweet-title">Drei Suesse, drei Aufgaben im Fruehlingsbild</h2>
            <p>
              Statt den gesamten Slider zu wiederholen, bekommt jede Produktwelt eine klare
              Rolle. Dadurch sieht man schneller, warum die Kampagne mehr ist als ein
              saisonaler Header.
            </p>
          </div>
          <div class="sweet-grid">
            {sweetMoments.map(([image, label, title, text]) => (
              <article class="sweet-card">
                <div class="sweet-image">
                  <img src={`${media}/${image}`} alt={title} loading="lazy" />
                </div>
                <div class="sweet-copy">
                  <span>{label}</span>
                  <h3>{title}</h3>
                  <p>{text}</p>
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="original-slides" aria-labelledby="original-title">
          <div class="section-copy">
            <p class="eyebrow">Originalmaterial · Drei Slides</p>
            <h2 id="original-title">Die echten Kampagnenbilder gehoeren sichtbar in den Case</h2>
            <p>
              Die Seite zeigt jetzt die drei starken Originalmotive aus dem Special:
              Scharmel, Pastila und Marmelandia. So bleibt die Arbeit nah am realen
              Projekt und verliert sich nicht in generischen Bildern.
            </p>
          </div>
          <div class="original-strip">
            {originalSlides.map(([image, caption]) => (
              <figure>
                <img src={`${media}/${image}`} alt={caption} loading="lazy" />
                <figcaption>{caption}</figcaption>
              </figure>
            ))}
          </div>
        </section>

        <section class="instagram-stage" aria-labelledby="instagram-title">
          <div class="section-copy">
            <p class="eyebrow">Instagram-Block · neu interpretiert</p>
            <h2 id="instagram-title">Social-Idee statt altem Instagram-Embed</h2>
            <p>
              Das Original hatte einen Instagram-Bereich. Im Portfolio bleibt die Mechanik
              erhalten, aber als moderne Placeholder-Buehne: Smartphone-Karte,
              Beitragskacheln, Candy-Pattern und fliegende Suessigkeiten.
            </p>
          </div>
          <div class="instagram-board">
            <figure class="instagram-reference">
              <img src={`${media}/original-instagram.jpg`} alt="Originaler Instagram-Bereich des Udarnitsa Specials" loading="lazy" />
              <figcaption>Originalscreen · Social-Bereich des Specials</figcaption>
            </figure>
            <div class="mock-social" aria-label="Instagram Placeholder">
              <div class="phone-shell">
                <div class="phone-top">
                  <span></span>
                  <strong>sweet spring</strong>
                  <span></span>
                </div>
                <div class="phone-visual">
                  <img src={`${media}/original-floating-sweets.jpg`} alt="Fliegende Suessigkeiten aus dem Originalpattern" loading="lazy" />
                </div>
                <div class="phone-actions">
                  <span></span>
                  <span></span>
                  <span></span>
                </div>
                <p>Placeholder fuer kuratierte Social-Posts, passend zum Portfolio-Look.</p>
              </div>
              <div class="social-copy">
                <span>Instagram secrets</span>
                <h3>Fruehlingsposts mit Zephyr, Pastila und Marmelandia</h3>
                <p>
                  Statt ein veraltetes Interface zu zeigen, inszeniert der Block die Idee:
                  kleine Tipps, Rezeptkarten und User-Motive, die aus dem Special in Social
                  Media weiterwandern.
                </p>
              </div>
            </div>
          </div>
        </section>

        <section id="highlights" class="highlights">
          <div class="section-number">03</div>
          <div class="section-copy">
            <p class="eyebrow">Highlights</p>
            <h2>Was den Auftritt besonders macht</h2>
          </div>
          <div class="highlight-grid">
            {highlights.map(([title, text], index) => (
              <article>
                <span>{String(index + 1).padStart(2, "0")}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="contest-lab" aria-labelledby="contest-title">
          <div class="section-copy">
            <p class="eyebrow">Fotokonkurs</p>
            <h2 id="contest-title">Der Wettbewerb wird als Aktivierung sichtbar</h2>
            <p>
              Der Portfolio-Case erklaert nun nicht nur, dass es einen Wettbewerb gab,
              sondern warum er fuer die Kampagne wichtig war: Er uebersetzt den Teemoment
              in User-Fotos und verlaengert die Markenwelt in die Community.
            </p>
          </div>
          <figure class="contest-shot">
            <img src={`${media}/contest-activation.jpg`} alt="Fotowettbewerb mit Einsendungen, Tee und Udarnitsa Suessigkeiten" loading="lazy" />
            <figcaption>Contest-Visual · kuratierte Einsendungen statt abstrakter Mechanik</figcaption>
          </figure>
          <div class="contest-grid">
            {contestSteps.map(([number, title, text]) => (
              <article>
                <span>{number}</span>
                <h3>{title}</h3>
                <p>{text}</p>
              </article>
            ))}
          </div>
        </section>

        <section id="ergebnis" class="result">
          <div class="section-number">04</div>
          <div class="result-copy">
            <p class="eyebrow">Ergebnis</p>
            <h2>Eine saisonale Markenwelt mit Community-Effekt</h2>
            <p>
              Das Special verbindet Produktwissen, emotionales Storytelling und konkrete
              Aktivierung. Im Case sind die staerksten Elemente jetzt sichtbar getrennt:
              neuer Hero, Teeritual, Produktrollen und Fotowettbewerb.
            </p>
            <a class="button light" data-owner-only hidden href="https://www.edimdoma.ru/2018/udarnitsa" target="_blank" rel="noreferrer">
              Originalprojekt oeffnen
            </a>
          </div>
        </section>
      </article>
    </main>
    <MotionEnhance />

  </body>
</html>

<script>
  const params = new URLSearchParams(location.search);
  const ownerParam = params.get("owner");
  const editParam = params.get("edit");
  if (ownerParam === "1") localStorage.setItem("prokha-owner-mode", "1");
  if (ownerParam === "0") localStorage.removeItem("prokha-owner-mode");
  localStorage.removeItem("prokha-edit-links");

  let editLinksVisible = editParam === "1";
  const revealOwnerControls = () => {
    const isOwner = localStorage.getItem("prokha-owner-mode") === "1";
    const showEditLinks = isOwner && editLinksVisible;
    document.querySelectorAll("[data-owner-only]").forEach((element) => {
      element.hidden = !isOwner;
    });
    document.querySelectorAll("[data-edit-only]").forEach((element) => {
      element.hidden = !showEditLinks;
    });
  };

  revealOwnerControls();

  let editCommand = "";
  document.addEventListener("keydown", (event) => {
    if (event.metaKey || event.ctrlKey || event.altKey || event.target instanceof HTMLInputElement || event.target instanceof HTMLTextAreaElement) return;
    editCommand = (editCommand + event.key.toLowerCase()).slice(-4);
    if (editCommand === "edit") {
      editLinksVisible = true;
      revealOwnerControls();
    }
  });
</script>

<style>
  :root {
    color-scheme: light;
    --bg: #fff8f0;
    --paper: #fff;
    --ink: #080808;
    --muted: #6a5553;
    --line: #ead6cf;
    --accent: #b71922;
    --accent-dark: #7f0d14;
    --peach: #ffe1c7;
    --rose: #f8d5d8;
    --radius: 8px;
    font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  * { box-sizing: border-box; }
  html { scroll-behavior: smooth; }
  body { margin: 0; background: var(--bg); color: var(--ink); }
  a { color: inherit; text-decoration: none; }
  p, h1, h2, h3, dl, dd, figure { margin: 0; }
  img, video { display: block; max-width: 100%; }
  [hidden] { display: none !important; }

  .site-header {
    align-items: center;
    background: rgba(255, 248, 240, .9);
    border-bottom: 1px solid rgba(234, 214, 207, .75);
    display: grid;
    gap: 24px;
    grid-template-columns: 1fr auto 1fr;
    left: 0;
    padding: 20px clamp(20px, 4vw, 72px);
    position: sticky;
    right: 0;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(18px);
  }

  .brand { font-size: 28px; font-weight: 900; }
  .back-link { font-size: 14px; font-weight: 800; }
  .back-link span { margin-right: 8px; }
  .button {
    align-items: center;
    border: 1px solid var(--ink);
    border-radius: var(--radius);
    display: inline-flex;
    font-size: 14px;
    font-weight: 800;
    justify-content: center;
    min-height: 48px;
    padding: 0 24px;
  }
  .button.dark { background: var(--ink); color: #fff; }
  .button.light { background: transparent; }
  .button.small { justify-self: end; min-height: 42px; }
  .header-actions { display: flex; gap: 8px; justify-self: end; }
  .edit-page {
    background: transparent !important;
    border-color: rgba(8, 8, 8, 0.18) !important;
    color: rgba(8, 8, 8, 0.46) !important;
  }

  .edit-page:hover,
  .edit-page:focus-visible {
    border-color: var(--ink) !important;
    color: var(--ink) !important;
  }

  main { display: grid; grid-template-columns: minmax(280px, 25vw) minmax(0, 1fr); }
  .case-sidebar {
    align-content: space-between;
    background: var(--paper);
    border-right: 1px solid var(--line);
    display: grid;
    gap: 44px;
    height: calc(100vh - 83px);
    padding: clamp(36px, 4vw, 64px) clamp(24px, 3vw, 48px);
    position: sticky;
    top: 83px;
  }
  .eyebrow {
    color: var(--muted);
    font-size: 12px;
    font-weight: 900;
    letter-spacing: .08em;
    margin-bottom: 16px;
    text-transform: uppercase;
  }
  .client-logo { height: 70px; margin-bottom: 32px; object-fit: contain; object-position: left center; width: 100px; }
  h1 { font-size: clamp(25px, 2.25vw, 38px); hyphens: auto; line-height: 1.08; overflow-wrap: anywhere; }
  h2 { font-size: clamp(32px, 4.5vw, 68px); line-height: 1.02; max-width: 900px; }
  .intro { hyphens: auto; overflow-wrap: anywhere; }
  .intro, .section-copy > p:last-child, .result-copy > p {
    color: var(--muted);
    font-size: 16px;
    line-height: 1.7;
    margin-top: 22px;
  }
  dl { border-top: 1px solid var(--line); }
  dl div { border-bottom: 1px solid var(--line); display: flex; justify-content: space-between; padding: 11px 0; }
  dt { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  dd { font-size: 13px; font-weight: 800; text-align: right; }
  nav { display: grid; gap: 10px; }
  nav a { color: var(--muted); font-size: 12px; font-weight: 800; text-transform: uppercase; }
  nav a:hover { color: var(--ink); }

  .case-content > section { border-bottom: 1px solid var(--line); padding: clamp(56px, 7vw, 110px) clamp(24px, 6vw, 100px); }
  .hero { min-height: calc(100vh - 83px); }
  .hero { position: relative; }
  .floating-sweets {
    inset: 0;
    overflow: hidden;
    pointer-events: none;
    position: absolute;
    z-index: 0;
  }
  .sweet-orb {
    background: var(--paper);
    border-radius: 999px;
    box-shadow: 0 24px 60px rgba(127, 13, 20, .16);
    display: block;
    opacity: .74;
    position: absolute;
  }
  .sweet-orb::before {
    border-radius: inherit;
    content: "";
    inset: 16%;
    position: absolute;
  }
  .orb-one {
    height: 94px;
    left: 7%;
    top: 44%;
    width: 94px;
  }
  .orb-one::before { background: radial-gradient(circle at 35% 35%, #fff, #7a342c 54%, #2b1110 100%); }
  .orb-two {
    height: 130px;
    right: -30px;
    top: 10%;
    width: 130px;
  }
  .orb-two::before {
    background:
      radial-gradient(circle at 50% 50%, transparent 0 42%, #fff7ef 43% 48%, transparent 49%),
      conic-gradient(from 20deg, #fff7ef, #f3b3bc, #fff7ef, #f3b3bc, #fff7ef);
  }
  .orb-three {
    border-radius: 52% 48% 46% 54%;
    bottom: 8%;
    height: 96px;
    right: 15%;
    transform: rotate(-18deg);
    width: 136px;
  }
  .orb-three::before { background: linear-gradient(135deg, #ffd84d, #ef6c3a 54%, #b81823); border-radius: 52% 48% 46% 54%; }
  .hero-copy { display: grid; gap: 28px; grid-template-columns: 1fr minmax(260px, 420px); margin-bottom: 58px; }
  .hero-copy, .hero-media { position: relative; z-index: 1; }
  .hero-copy .eyebrow { grid-column: 1 / -1; }
  .hero-copy p:last-child { align-self: end; color: var(--muted); font-size: 17px; line-height: 1.7; }
  .hero-media {
    background: linear-gradient(135deg, var(--rose), var(--peach));
    border-radius: 24px;
    box-shadow: 0 28px 80px rgba(127, 13, 20, .16);
    overflow: hidden;
  }
  .hero-media img { aspect-ratio: 16 / 9; object-fit: cover; width: 100%; }
  .hero-media span { color: var(--accent-dark); display: block; font-size: 12px; font-weight: 900; letter-spacing: .08em; padding: 16px 18px; text-transform: uppercase; }

  .story-section, .highlights, .result { display: grid; gap: 36px; grid-template-columns: 70px minmax(0, 1fr); }
  .section-number { color: var(--muted); font-size: 13px; font-weight: 900; padding-top: 4px; }
  .section-copy { max-width: 850px; }
  .quote {
    background:
      radial-gradient(circle at 82% 18%, rgba(255, 255, 255, .24), transparent 24%),
      linear-gradient(135deg, var(--accent-dark), var(--accent) 62%, #e86638);
    border-radius: var(--radius);
    color: #fff;
    font-size: clamp(26px, 4vw, 52px);
    font-weight: 800;
    grid-column: 2;
    line-height: 1.12;
    margin-top: 28px;
    padding: clamp(28px, 5vw, 70px);
  }

  .sweet-system {
    background:
      radial-gradient(circle at 16% 12%, rgba(183, 25, 34, .12), transparent 24%),
      linear-gradient(135deg, #fffdf8, #fff0e1);
  }
  .sweet-grid {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 48px;
  }
  .sweet-card {
    background: #fff;
    border: 1px solid rgba(183, 25, 34, .16);
    border-radius: 22px;
    overflow: hidden;
    position: relative;
    transition: box-shadow .35s ease, transform .35s ease;
  }
  .sweet-card:hover {
    box-shadow: 0 24px 70px rgba(127, 13, 20, .16);
    transform: translateY(-8px);
  }
  .sweet-image {
    aspect-ratio: 4 / 3;
    background: var(--rose);
    overflow: hidden;
  }
  .sweet-image img {
    height: 100%;
    object-fit: cover;
    transition: transform .45s ease;
    width: 100%;
  }
  .sweet-card:hover .sweet-image img {
    transform: scale(1.08);
  }
  .sweet-copy {
    padding: 26px;
  }
  .sweet-card span {
    color: var(--accent);
    display: block;
    font-size: 11px;
    font-weight: 900;
    letter-spacing: .08em;
    text-transform: uppercase;
  }
  .sweet-card h3 {
    font-size: 25px;
    line-height: 1.08;
    margin-top: 18px;
    max-width: 260px;
  }
  .sweet-card p { color: var(--muted); font-size: 14px; line-height: 1.6; margin-top: 14px; }

  .original-slides {
    background:
      radial-gradient(circle at 88% 12%, rgba(183, 25, 34, .1), transparent 22%),
      #fffdf8;
  }
  .original-strip {
    display: grid;
    gap: 18px;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    margin-top: 48px;
  }
  .original-strip figure {
    background: #fff;
    border: 1px solid rgba(183, 25, 34, .12);
    border-radius: 22px;
    box-shadow: 0 20px 60px rgba(127, 13, 20, .08);
    overflow: hidden;
  }
  .original-strip img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
    width: 100%;
  }

  .instagram-stage {
    background:
      radial-gradient(circle at 8% 20%, rgba(255, 255, 255, .34), transparent 24%),
      linear-gradient(135deg, #d486c7, #ff9e88 58%, #fff7ef 58%);
  }
  .instagram-board {
    display: grid;
    gap: 24px;
    grid-template-columns: minmax(0, .95fr) minmax(320px, 1.05fr);
    margin-top: 48px;
  }
  .instagram-reference,
  .mock-social {
    background: rgba(255, 255, 255, .86);
    border-radius: 24px;
    box-shadow: 0 28px 80px rgba(127, 13, 20, .16);
    overflow: hidden;
  }
  .instagram-reference img {
    aspect-ratio: 16 / 10;
    object-fit: cover;
    object-position: center top;
    width: 100%;
  }
  .mock-social {
    align-items: center;
